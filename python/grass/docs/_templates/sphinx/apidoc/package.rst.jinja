{%- macro automodule(modname, options, noindex=False) -%}
.. automodule:: {{ modname }}
{%- for option in options %}
   :{{ option }}:
{%- endfor %}
{%- if noindex %}
   :no-index:
{%- endif %}
{%- endmacro %}

{%- macro toctree(docnames) -%}
.. toctree::
   :maxdepth: {{ maxdepth }}
{% for docname in docnames %}
   {{ docname }}
{%- endfor %}
{%- endmacro %}

{%- if is_namespace %}
{{- [pkgname, "namespace"] | join(" ") | e | heading }}
{% else %}
{{- [pkgname, "package"] | join(" ") | e | heading }}
{% endif %}

{%- if is_namespace %}
.. py:module:: {{ pkgname }}
{% endif %}

{%- if modulefirst and not is_namespace %}
{# Root grass package keeps full index; subpackages use no-index to avoid
   duplicating index entries that the parent already generates recursively. #}
{%- set _pkg_noindex = pkgname != "grass" %}
{{ automodule(pkgname, automodule_options, noindex=_pkg_noindex) }}
{% endif %}

{%- if subpackages %}
Subpackages
-----------

{{ toctree(subpackages) }}
{% endif %}

{%- if submodules %}
Submodules
~~~~~~~~~~~~~~~
{% if separatemodules %}
{{ toctree(submodules) }}
{% else %}
{%- for submodule in submodules %}
{% if show_headings %}
{{- [submodule, "module"] | join(" ") | e | heading(2) }}
{% endif %}
{{ automodule(submodule, automodule_options, noindex=True) }}
{% endfor %}
{%- endif %}
{%- endif %}

{%- if not modulefirst and not is_namespace %}
Module contents
---------------

{# Root grass package keeps full index; subpackages use no-index to avoid
   duplicating index entries that the parent already generates recursively. #}
{%- set _pkg_noindex = pkgname != "grass" %}
{{ automodule(pkgname, automodule_options, noindex=_pkg_noindex) }}
{% endif %}
