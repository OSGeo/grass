msgid "Total area: %G (%d areas)\n"
msgstr "कुल क्षेत्रफल: %G (%d क्षेत्र)\\n\n"

#, c-format
msgid "Total area: %G (%d areas)"
msgstr "कुल क्षेत्रफल: %G (%d क्षेत्र)"

