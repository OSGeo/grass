#, c-format
msgid "Virtual raster map <%s> created."
msgstr "वर्चुअल रैस्टर मानचित्र <%s> बनाया गया।"

msgid "mosaic"
msgstr "मोज़ेक"

msgid "virtual raster"
msgstr "आभासी रेखापुंज"

msgid "Build a VRT (Virtual Raster) from the list of input raster maps."
msgstr "इनपुट रैस्टर मानचित्रों की सूची से एक वीआरटी (वर्चुअल रैस्टर) बनाएं।"

msgid "Name of input raster files"
msgstr "इनपुट रैस्टर फ़ाइलों का नाम"

#, c-format
msgid "%s= and %s= are mutually exclusive"
msgstr "%s= और %s= परस्पर अनन्य हैं"

#, c-format
msgid "Please specify %s= or %s="
msgstr "कृपया %s= या %s= निर्दिष्ट करें"

#, c-format
