msgstr "श्रेणी के बिना सुविधाएँ निर्यात करना..।"

#, c-format
msgid "Unable to export features. No category index for layer %d."
msgstr "सुविधाएँ निर्यात करने में असमर्थ. परत %d के लिए कोई श्रेणी सूचकांक नहीं।"

#, c-format
msgid "Cannot select attributes sorted by %s"
