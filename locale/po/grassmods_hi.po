msgid "texture"
msgstr "बनावट"

msgid "Generate images with textural features from a raster map."
msgstr "रैस्टर मानचित्र से बनावट संबंधी विशेषताओं के साथ छवियां बनाएं।"

msgid "The size of moving window (odd and >= 3)"
msgstr "चलती हुई विंडो का आकार (विषम और >=3)"

msgid "The distance between two samples (>= 1)"
msgstr "दो नमूनों के बीच की दूरी (>= 1)"

msgid "The distance must be smaller than the size of the moving window"
msgstr "दूरी चलती खिड़की के आकार से छोटी होनी चाहिए"

