msgstr "ओवरलैपिंग क्षेत्र: %G (%d क्षेत्र)\\n\n"

#, c-format
msgid "Overlapping area: %G (%d areas)"
msgstr "ओवरलैपिंग क्षेत्र: %G (%d क्षेत्र)"

