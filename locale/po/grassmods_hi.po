msgid "error running r.stats"
msgstr "r.stats चलाने में त्रुटि"

msgid "hazard"
msgstr "खतरा"

msgid "flood"
msgstr "बाढ़"

msgid "Fills lake at given point to given level."
msgstr "दिए गए बिंदु से दिए गए स्तर तक झील को भरता है।"

msgid "Water level"
msgstr "पानी की सतह"

msgid "Seed point coordinates"
msgstr "बीज बिंदु निर्देशांक"

msgid "Either this coordinates pair or a seed map have to be specified"
msgstr "या तो यह निर्देशांक युग्म या बीज मानचित्र निर्दिष्ट करना होगा"

msgid "Seed"
msgstr "बीज"

msgid "Input raster map with given starting point(s) (at least 1 cell > 0)"
msgstr "दिए गए प्रारंभिक बिंदु (बिंदुओं) के साथ इनपुट रास्टर मानचित्र (कम से कम 1 सेल > 0)"

msgid "Either this parameter or a coordinates pair have to be specified"
msgstr "या तो यह पैरामीटर या निर्देशांक युग्म निर्दिष्ट करना होगा"

msgid "Use negative depth values for lake raster map"
msgstr "झील रेखापुंज मानचित्र के लिए नकारात्मक गहराई मानों का उपयोग करें"

msgid "Overwrite seed map with result (lake) map"
msgstr "परिणाम (झील) मानचित्र के साथ बीज मानचित्र को अधिलेखित करें"

msgid "Both seed map and coordinates cannot be specified"
msgstr "बीज मानचित्र और निर्देशांक दोनों निर्दिष्ट नहीं किए जा सकते"

msgid "Seed map or seed coordinates must be set!"
msgstr "बीज मानचित्र या बीज निर्देशांक निर्धारित होना चाहिए!"

msgid "Seed coordinates and output map lake= must be set!"
msgstr "बीज निर्देशांक और आउटपुट मानचित्र Lake= सेट होना चाहिए!"

msgid "Both lake and overwrite cannot be specified"
msgstr "लेक और ओवरराइट दोनों को निर्दिष्ट नहीं किया जा सकता"

msgid "Output lake map or overwrite flag must be set!"
msgstr "आउटपुट झील मानचित्र या अधिलेखित ध्वज सेट किया जाना चाहिए!"

msgid "Seed point outside the current region"
msgstr "वर्तमान क्षेत्र के बाहर बीज बिंदु"

msgid "G_malloc: out of memory"
msgstr "G_malloc: स्मृति से बाहर"

msgid "Given water level at seed point is below earth surface. Increase water level or move seed point."
msgstr "बीज बिंदु पर जल का स्तर पृथ्वी की सतह से नीचे दिया गया है। जल स्तर बढ़ाएं या बीज बिंदु को स्थानांतरित करें।"

#, c-format
msgid "Lake depth from %f to %f (specified water level is taken as zero)"
msgstr "झील की गहराई %f से %f तक (निर्दिष्ट जल स्तर शून्य के रूप में लिया जाता है)"

#, c-format
msgid "Lake area %f square meters"
msgstr "झील क्षेत्र %f वर्ग मीटर"

#, c-format
msgid "Lake volume %f cubic meters"
msgstr "झील का आयतन %f घन मीटर"

msgid "Volume is correct only if lake depth (terrain raster map) is in meters"
msgstr "आयतन तभी सही है जब झील की गहराई (इलाके का रेखापुंज मानचित्र) मीटर में हो"

msgid "latitude"
msgstr "अक्षांश"

msgid "longitude"
msgstr "देशान्तर"

msgid "Creates a latitude/longitude raster map."
msgstr "एक अक्षांश/देशांतर रेखापुंज मानचित्र बनाता है।"

msgid "Name for output latitude or longitude raster map"
msgstr "आउटपुट अक्षांश या देशांतर रेखापुंज मानचित्र का नाम"

msgid "Longitude output"
msgstr "देशांतर आउटपुट"

msgid "Unable to get projection info of current location"
msgstr "वर्तमान स्थान की प्रक्षेपण जानकारी प्राप्त करने में असमर्थ"

msgid "Unable to get projection units of current location"
msgstr "वर्तमान स्थान की प्रक्षेपण इकाइयाँ प्राप्त करने में असमर्थ"

msgid "Unable to get projection key values of current location"
msgstr "वर्तमान स्थान के प्रक्षेपण कुंजी मान प्राप्त करने में असमर्थ"

