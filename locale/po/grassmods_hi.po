msgstr "इनपुट निर्देशांक"

msgid "Name of input coordinate file"
msgstr "इनपुट समन्वय फ़ाइल का नाम"

msgid "Name for output coordinate file (omit to send to stdout)"
msgstr "आउटपुट समन्वय फ़ाइल का नाम (stdout पर भेजने के लिए छोड़ें)"

