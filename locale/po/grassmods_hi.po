#, c-format
msgid ""
"Resolution too unbalanced:\n"
"atan2(%f deg, %f deg) =%f < %f tolerance\n"
"please resample input map"
msgstr "रिज़ॉल्यूशन बहुत असंतुलित:\\natan2(%f डिग्री, %f डिग्री) =%f < %f सहनशीलता\\nकृपया इनपुट मैप का पुनः नमूना लें"

#, c-format
msgid "Resolution too unbalanced (%f x %f); please resample input map"
msgstr "रिज़ॉल्यूशन बहुत असंतुलित (%f x %f); कृपया इनपुट मानचित्र का पुनः नमूनाकरण करें"

msgid "Calculates geomorphons (terrain forms) and associated geometry using machine vision approach."
msgstr "मशीन विज़न दृष्टिकोण का उपयोग करके जियोमोर्फोन (इलाके के रूप) और संबंधित ज्यामिति की गणना करता है।"

msgid "geomorphons"
msgstr "भू-आकृति"

msgid "terrain patterns"
msgstr "भू-भाग पैटर्न"

msgid "machine vision geomorphometry"
msgstr "मशीन विज़न जियोमोर्फोमेट्री"

msgid "Outer search radius"
msgstr "बाहरी खोज त्रिज्या"

msgid "Inner search radius"
msgstr "आंतरिक खोज त्रिज्या"

msgid "Flatness threshold (degrees)"
msgstr "समतलता सीमा (डिग्री)"

msgid "Flatness distance, zero for none"
msgstr "समतल दूरी, किसी के लिए शून्य"

msgid "Comparison mode for zenith/nadir line-of-sight search"
msgstr "ज़ेनिथ/नादिर लाइन-ऑफ़-विज़न खोज के लिए तुलना मोड"

msgid "Use meters to define search units (default is cells)"
msgstr "खोज इकाइयों को परिभाषित करने के लिए मीटर का उपयोग करें (डिफ़ॉल्ट सेल है)"

msgid "Use extended form correction"
msgstr "विस्तारित प्रपत्र सुधार का उपयोग करें"

msgid "Coordinates to profile"
msgstr "प्रोफ़ाइल से समन्वय करता है"

msgid "Profile"
msgstr "प्रोफ़ाइल"

msgid "Profile output file name (\"-\" for stdout)"
msgstr "प्रोफ़ाइल आउटपुट फ़ाइल नाम (\\\"-\\\" stdout के लिए)"

msgid "Profile output format"
msgstr "प्रोफ़ाइल आउटपुट स्वरूप"

#, c-format
msgid "Failed parsing <%s>"
msgstr "पार्सिंग विफल <%s>"

#, c-format
msgid "At least one output is required, e.g. %s"
msgstr "कम से कम एक आउटपुट आवश्यक है, उदा. %s"

msgid "The coordinates are outside of the computational region"
msgstr "निर्देशांक कम्प्यूटेशनल क्षेत्र के बाहर हैं"

#, c-format
msgid "Failed to open output file <%s>: %d (%s)"
msgstr "आउटपुट फ़ाइल खोलने में विफल <%s>: %d (%s)"

msgid "Search radius size must cover at least 1 cell"
msgstr "खोज त्रिज्या का आकार कम से कम 1 सेल को कवर करना चाहिए"

msgid "Skip radius size must be at least 1 cell lower than radius"
msgstr "छोड़ें त्रिज्या का आकार त्रिज्या से कम से कम 1 सेल कम होना चाहिए"

msgid "Flatness threshold must be grater than 0"
msgstr "समतलता सीमा 0 से अधिक होनी चाहिए"

msgid "Flatness distance should be between skip and search radius. Otherwise ignored"
msgstr "समतलता की दूरी स्किप और खोज त्रिज्या के बीच होनी चाहिए। अन्यथा नजरअंदाज कर दिया गया"

#, c-format
msgid "There may be a notable processing delay because the computational region is %lu times larger than necessary"
msgstr "प्रसंस्करण में उल्लेखनीय देरी हो सकती है क्योंकि कम्प्यूटेशनल क्षेत्र आवश्यकता से %lu गुना बड़ा है"

msgid "Unknown output data type"
msgstr "अज्ञात आउटपुट डेटा प्रकार"

