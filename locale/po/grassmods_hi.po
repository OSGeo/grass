msgstr "ऊंचाई रेखापुंज मानचित्र लोड हो रहा है..।"

msgid "Loading input raster maps..."
msgstr "इनपुट रेखापुंज मानचित्र लोड हो रहे हैं..।"

msgid "Elevation raster map is NULL but accumulation map is not NULL"
msgstr "ऊंचाई रेखापुंज मानचित्र शून्य है लेकिन संचय मानचित्र शून्य नहीं है"

msgid "stream network"
msgstr "स्ट्रीम नेटवर्क"

msgid "Performs stream network extraction."
msgstr "स्ट्रीम नेटवर्क निष्कर्षण करता है।"

msgid "Name of input accumulation raster map"
msgstr "इनपुट संचय रेखापुंज मानचित्र का नाम"

msgid "Stream extraction will use provided accumulation instead of calculating it anew"
msgstr "स्ट्रीम निष्कर्षण नए सिरे से गणना करने के बजाय प्रदान किए गए संचय का उपयोग करेगा"

msgid "Name of input raster map with real depressions"
msgstr "वास्तविक अवसादों के साथ इनपुट रेखापुंज मानचित्र का नाम"

msgid "Streams will not be routed out of real depressions"
msgstr "धाराओं को वास्तविक अवसादों से बाहर नहीं निकाला जाएगा"

msgid "Minimum flow accumulation for streams"
msgstr "धाराओं के लिए न्यूनतम प्रवाह संचय"

msgid "Must be > 0"
msgstr "> 0 होना चाहिए"

msgid "Use SFD above this threshold"
msgstr "इस सीमा से ऊपर एसएफडी का प्रयोग करें"

msgid "If accumulation is larger than d8cut, SFD is used instead of MFD. Applies only if no accumulation map is given."
msgstr "यदि संचय d8cut से बड़ा है, तो MFD के बजाय SFD का उपयोग किया जाता है। केवल तभी लागू होता है जब कोई संचय मानचित्र नहीं दिया गया हो।"

msgid "Montgomery exponent for slope, disabled with 0"
msgstr "ढलान के लिए मोंटगोमरी प्रतिपादक, 0 के साथ अक्षम"

msgid "Montgomery: accumulation is multiplied with pow(slope,mexp) and then compared with threshold"
msgstr "मोंटगोमरी: संचय को पाउ (ढलान, एमईएक्सपी) से गुणा किया जाता है और फिर दहलीज के साथ तुलना की जाती है"

msgid "Delete stream segments shorter than stream_length cells"
msgstr "स्ट्रीम_लेंथ सेल से छोटे स्ट्रीम सेगमेंट हटाएं"

msgid "Applies only to first-order stream segments (springs/stream heads)"
msgstr "केवल प्रथम-क्रम स्ट्रीम खंडों (स्प्रिंग्स/स्ट्रीम हेड्स) पर लागू होता है"

msgid "Name for output raster map with unique stream ids"
msgstr "अद्वितीय स्ट्रीम आईडी के साथ आउटपुट रैस्टर मानचित्र का नाम"

msgid "Name for output vector map with unique stream ids"
msgstr "अद्वितीय स्ट्रीम आईडी के साथ आउटपुट वेक्टर मानचित्र का नाम"

msgid "Name for output raster map with flow direction"
msgstr "प्रवाह दिशा के साथ आउटपुट रैस्टर मानचित्र का नाम"

#, c-format
msgid "Threshold must be > 0 but is %f"
msgstr "थ्रेसहोल्ड > 0 होना चाहिए लेकिन %f है"

#, c-format
msgid "d8cut must be positive or zero but is %f"
msgstr "d8cut धनात्मक या शून्य होना चाहिए लेकिन %f है"

#, c-format
msgid "Montgomery exponent must be positive or zero but is %f"
msgstr "मोंटगोमरी प्रतिपादक धनात्मक या शून्य होना चाहिए लेकिन %f है"

#, c-format
msgid "Montgomery exponent is %f, recommended range is 0.0 - 3.0"
msgstr "मोंटगोमरी प्रतिपादक %f है, अनुशंसित सीमा 0.0 - 3.0 है"

#, c-format
msgid "Minimum stream length must be positive or zero but is %d"
msgstr "न्यूनतम स्ट्रीम लंबाई धनात्मक या शून्य होनी चाहिए लेकिन %d है"

#, c-format
msgid "Memory must be positive but is %d"
msgstr "मेमोरी सकारात्मक होनी चाहिए लेकिन %d है"

msgid "At least one output raster maps must be specified"
msgstr "कम से कम एक आउटपुट रैस्टर मानचित्र निर्दिष्ट किया जाना चाहिए"

#, c-format
msgid "%.2f%% of data are kept in memory"
msgstr "%%% डेटा मेमोरी में रखा जाता है"

#, c-format
msgid "Will need up to %.2f MB of disk space"
msgstr "%2f एमबी तक डिस्क स्थान की आवश्यकता होगी"

#, c-format
msgid "Will need up to %.2f GB (%.0f MB) of disk space"
msgstr "%2f GB (%0f MB) तक डिस्क स्थान की आवश्यकता होगी"

msgid "Creating temporary files..."
msgstr "अस्थायी फ़ाइलें बनाई जा रही हैं..।"

msgid "Unable to load input raster map(s)"
msgstr "इनपुट रास्टर मानचित्र लोड करने में असमर्थ"

msgid "No non-NULL cells in input raster map(s)"
msgstr "इनपुट रैस्टर मानचित्र में कोई गैर-शून्य कक्ष नहीं"

msgid "Unable to initialize search"
msgstr "खोज आरंभ करने में असमर्थ"

msgid "Unable to sort elevation raster map values"
msgstr "उन्नयन रेखापुंज मानचित्र मानों को क्रमबद्ध करने में असमर्थ"

msgid "Unable to calculate flow accumulation"
msgstr "प्रवाह संचय की गणना करने में असमर्थ"

msgid "Unable to extract streams"
msgstr "स्ट्रीम निकालने में असमर्थ"

msgid "Unable to thin streams"
msgstr "धाराओं को पतला करने में असमर्थ"

msgid "Unable to delete short stream segments"
msgstr "लघु स्ट्रीम खंड हटाने में असमर्थ"

msgid "Unable to write output raster maps"
msgstr "आउटपुट रैस्टर मानचित्र लिखने में असमर्थ"

msgid "seg_put_row(): could not write segment file"
msgstr "seg_put_row(): सेगमेंट फ़ाइल नहीं लिख सका"

#, c-format
msgid "Stream_no %d and n_stream_nodes %<PRId64> out of sync"
msgstr "Stream_no %d और n_stream_nodes %<PRId64> समन्वयन से बाहर"

#, c-format
msgid "BUG: stream node %d has only 1 tributary: %d"
msgstr "बग: स्ट्रीम नोड %d में केवल 1 सहायक नदी है: %d"

msgid "Calculating flow accumulation..."
msgstr "प्रवाह संचय की गणना की जा रही है..।"

#, c-format
msgid "MFD: cumulative proportion of flow distribution not 1.0 but %f"
msgstr "एमएफडी: प्रवाह वितरण का संचयी अनुपात 1.0 नहीं बल्कि %f"

msgid "Extracting streams..."
msgstr "धाराएँ निकाली जा रही हैं..।"

msgid "Bug in stream extraction"
msgstr "धारा निष्कर्षण में बग"

msgid "Can't use Montgomery's method, no stream direction found"
msgstr "मोंटगोमरी की विधि का उपयोग नहीं किया जा सकता, कोई धारा दिशा नहीं मिली"

#, c-format
msgid "MFD: A * path already processed when setting drainage direction: %<PRId64> of %<PRId64> cells"
msgstr "एमएफडी: जल निकासी दिशा निर्धारित करते समय एक * पथ पहले ही संसाधित हो चुका है: %<PRId64> कोशिकाओं में से %<PRId64>"

msgid "Thinning stream segments..."
msgstr "धारा खंडों का पतला होना..।"

#, c-format
msgid "%d of %<PRId64> stream segments were thinned"
msgstr "%<PRId64> धारा खंडों में से %d पतले हो गए"

msgid "sun energy"
msgstr "सूर्य ऊर्जा"

msgid "shadow"
msgstr "छाया"

msgid "Solar irradiance and irradiation model."
msgstr "सौर विकिरण और विकिरण मॉडल।"

msgid "Computes direct (beam), diffuse and reflected solar irradiation raster maps for given day, latitude, surface and atmospheric conditions. Solar parameters (e.g. sunrise, sunset times, declination, extraterrestrial irradiance, daylight length) are saved in the map history file. Alternatively, a local time can be specified to compute solar incidence angle and/or irradiance raster maps. The shadowing effect of the topography is optionally incorporated."
msgstr "दिए गए दिन, अक्षांश, सतह और वायुमंडलीय स्थितियों के लिए प्रत्यक्ष (बीम), फैलाना और प्रतिबिंबित सौर विकिरण रेखापुंज मानचित्रों की गणना करता है। सौर पैरामीटर (जैसे सूर्योदय, सूर्यास्त का समय, झुकाव, अलौकिक विकिरण, दिन के उजाले की लंबाई) मानचित्र इतिहास फ़ाइल में सहेजे जाते हैं। वैकल्पिक रूप से, सौर घटना कोण और/या विकिरण रेखापुंज मानचित्रों की गणना के लिए एक स्थानीय समय निर्दिष्ट किया जा सकता है। स्थलाकृति का छायांकन प्रभाव वैकल्पिक रूप से शामिल किया गया है।"

msgid "Name of the input elevation raster map [meters]"
msgstr "इनपुट उन्नयन रेखापुंज मानचित्र का नाम [मीटर]"

msgid "Name of the input aspect map (terrain aspect or azimuth of the solar panel) [decimal degrees]"
msgstr "इनपुट पहलू मानचित्र का नाम (इलाके का पहलू या सौर पैनल का दिगंश) [दशमलव डिग्री]"

msgid "A single value of the orientation (aspect), 270 is south"
msgstr "अभिविन्यास (पहलू) का एक एकल मान, 270 दक्षिण है"

msgid "Name of the input slope raster map (terrain slope or solar panel inclination) [decimal degrees]"
msgstr "इनपुट ढलान रेखापुंज मानचित्र का नाम (इलाके का ढलान या सौर पैनल झुकाव) [दशमलव डिग्री]"

msgid "A single value of inclination (slope)"
msgstr "झुकाव का एक ही मान (ढलान)"

msgid "Name of the Linke atmospheric turbidity coefficient input raster map [-]"
msgstr "लिंके वायुमंडलीय मैलापन गुणांक इनपुट रेखापुंज मानचित्र का नाम [-]"

msgid "A single value of the Linke atmospheric turbidity coefficient [-]"
msgstr "लिंके वायुमंडलीय मैलापन गुणांक का एक एकल मान [-]"

msgid "Name of the ground albedo coefficient input raster map [-]"
msgstr "ज़मीन का नाम अल्बेडो गुणांक इनपुट रेखापुंज मानचित्र [-]"

msgid "A single value of the ground albedo coefficient [-]"
msgstr "ग्राउंड अल्बेडो गुणांक का एक एकल मान [-]"

msgid "Name of input raster map containing latitudes [decimal degrees]"
msgstr "अक्षांशों वाले इनपुट रेखापुंज मानचित्र का नाम [दशमलव डिग्री]"

msgid "Name of input raster map containing longitudes [decimal degrees]"
msgstr "देशांतर युक्त इनपुट रेखापुंज मानचित्र का नाम [दशमलव डिग्री]"

msgid "Name of real-sky beam radiation coefficient (thick cloud) input raster map [0-1]"
msgstr "वास्तविक-आकाश किरण विकिरण गुणांक (मोटा बादल) इनपुट रेखापुंज मानचित्र का नाम [0-1]"

msgid "Name of real-sky diffuse radiation coefficient (haze) input raster map [0-1]"
msgstr "वास्तविक आकाश विसरित विकिरण गुणांक (धुंध) इनपुट रेखापुंज मानचित्र का नाम [0-1]"

msgid "The horizon information input map basename"
msgstr "क्षितिज सूचना इनपुट मानचित्र आधारनाम"

msgid "Output incidence angle raster map (mode 1 only)"
msgstr "आउटपुट घटना कोण रेखापुंज मानचित्र (केवल मोड 1)"

msgid "Output beam irradiance [W.m-2] (mode 1) or irradiation raster map [Wh.m-2.day-1] (mode 2)"
msgstr "आउटपुट बीम विकिरण [W.m-2] (मोड 1) या विकिरण रेखापुंज मानचित्र [Wh.m-2.दिन-1] (मोड 2)"

msgid "Output diffuse irradiance [W.m-2] (mode 1) or irradiation raster map [Wh.m-2.day-1] (mode 2)"
msgstr "आउटपुट फैलाना विकिरण [W.m-2] (मोड 1) या विकिरण रेखापुंज मानचित्र [Wh.m-2.day-1] (मोड 2)"

msgid "Output ground reflected irradiance [W.m-2] (mode 1) or irradiation raster map [Wh.m-2.day-1] (mode 2)"
msgstr "आउटपुट ग्राउंड परावर्तित विकिरण [W.m-2] (मोड 1) या विकिरण रेखापुंज मानचित्र [Wh.m-2.दिन-1] (मोड 2)"

msgid "Output global (total) irradiance/irradiation [W.m-2] (mode 1) or irradiance/irradiation raster map [Wh.m-2.day-1] (mode 2)"
msgstr "आउटपुट वैश्विक (कुल) विकिरण/विकिरण [W.m-2] (मोड 1) या विकिरण/विकिरण रेखापुंज मानचित्र [Wh.m-2.दिन-1] (मोड 2)"

msgid "Output insolation time raster map [h] (mode 2 only)"
msgstr "आउटपुट सूर्यातप समय रेखापुंज मानचित्र [एच] (केवल मोड 2)"

msgid "No. of day of the year (1-365)"
msgstr "वर्ष के दिन की संख्या (1-365)"

msgid "Time step when computing all-day radiation sums [decimal hours]"
msgstr "पूरे दिन के विकिरण योग की गणना करते समय समय चरण [दशमलव घंटे]"

msgid "Declination value (overriding the internally computed value) [radians]"
msgstr "गिरावट मूल्य (आंतरिक रूप से गणना किए गए मूल्य को ओवरराइड करते हुए) [रेडियन]"

msgid "Solar constant [W/m^2]"
msgstr "सौर स्थिरांक [W/m^2]"

msgid "Local (solar) time (to be set for mode 1 only) [decimal hours]"
msgstr "स्थानीय (सौर) समय (केवल मोड 1 के लिए सेट किया जाएगा) [दशमलव घंटे]"

msgid "Number of threads which will be used for parallel computing"
msgstr "थ्रेड्स की संख्या जिनका उपयोग समानांतर कंप्यूटिंग के लिए किया जाएगा"

msgid "Read the input files in this number of chunks"
msgstr "इस संख्या में खंडों में इनपुट फ़ाइलें पढ़ें"

msgid "Civil time zone value, if none, the time will be local solar time"
msgstr "नागरिक समय क्षेत्र मान, यदि कोई नहीं है, तो समय स्थानीय सौर समय होगा"

msgid "Do not incorporate the shadowing effect of terrain"
msgstr "इलाके के छाया प्रभाव को शामिल न करें"

msgid "Use the low-memory version of the program"
msgstr "प्रोग्राम के कम-मेमोरी संस्करण का उपयोग करें"

#, c-format
msgid "<%d> is not valid number of threads. Number of threads will be set to <%d>"
msgstr "<%d> धागों की मान्य संख्या नहीं है. थ्रेड्स की संख्या <%d> पर सेट की जाएगी"

#, c-format
msgid "Number of threads <%d>"
msgstr "धागों की संख्या <%d>"

msgid "You must give the longitude raster if you use civil time"
msgstr "यदि आप नागरिक समय का उपयोग करते हैं तो आपको देशांतर रेखापुंज अवश्य देना होगा"

msgid "Error reading civil time zone value"
msgstr "नागरिक समय क्षेत्र मान पढ़ने में त्रुटि"

msgid "Invalid civil time zone value"
msgstr "अमान्य नागरिक समय क्षेत्र मान"

msgid "insol_time and incidout are incompatible options"
msgstr "insol_time और incidout असंगत विकल्प हैं"

msgid "Error reading time step size"
msgstr "समय चरण आकार पढ़ने में त्रुटि"

msgid "Invalid time step size"
msgstr "अमान्य समय चरण आकार"

msgid "Error reading horizon step size"
msgstr "क्षितिज चरण आकार पढ़ने में त्रुटि"

msgid "The horizon step size must be greater than 0."
msgstr "क्षितिज चरण का आकार 0 से अधिक होना चाहिए।"

msgid "If you use the horizon option you must also set the 'horizonstep' parameter."
msgstr "यदि आप क्षितिज विकल्प का उपयोग करते हैं तो आपको 'क्षितिज चरण' पैरामीटर भी सेट करना होगा।"

msgid "Time and insol_time are incompatible options"
msgstr "समय और insol_time असंगत विकल्प हैं"

msgid "Mode 1: instantaneous solar incidence angle & irradiance using a set local time"
msgstr "मोड 1: एक निर्धारित स्थानीय समय का उपयोग करके तात्कालिक सौर घटना कोण और विकिरण"

msgid "incidout requires time parameter to be set"
msgstr "इनसाइडआउट के लिए समय पैरामीटर सेट करने की आवश्यकता होती है"

msgid "Mode 2: integrated daily irradiation for a given day of the year"
msgstr "मोड 2: वर्ष के किसी दिए गए दिन के लिए एकीकृत दैनिक विकिरण"

#, c-format
msgid "Using Linke constant: %lf"
msgstr "लिंक स्थिरांक का उपयोग करना: %lf"

#, c-format
msgid "Using Linke map <%s>"
