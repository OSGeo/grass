#, c-format
msgid "%.2f KB of disk space for temp files."
msgstr "अस्थायी फ़ाइलों के लिए %2f KB डिस्क स्थान।"

#, c-format
msgid "%d byte of disk space for temp files."
msgid_plural "%d bytes of disk space for temp files."
msgstr[0] ""
msgstr[1] ""

msgid "Maximum value of a raster map is NULL."
msgstr "रेखापुंज मानचित्र का अधिकतम मान शून्य है।"

msgid "Temporarily changing the region to desired resolution ..."
msgstr "क्षेत्र को वांछित रिज़ॉल्यूशन में अस्थायी रूप से बदला जा रहा है..।"

msgid "Changing back to the original region ..."
msgstr "मूल क्षेत्र में वापस परिवर्तन..।"

msgid "Percent complete: "
msgstr "पूर्ण प्रतिशत: "

#, c-format
msgid "dnorm in mainc after grid before out1= %f"
msgstr "आउट1 से पहले ग्रिड के बाद मेनसी में dnorm = %f"

msgid "split_and_interpolate() failed"
msgstr "स्प्लिट_एंड_इंटरपोलेट() विफल"

#, c-format
msgid "dnorm in mainc after grid before out2= %f"
msgstr "आउट2 से पहले ग्रिड के बाद मेनसी में dnorm= %f"

msgid "Unable to write raster maps -- try increasing cell size"
msgstr "रेखापुंज मानचित्र लिखने में असमर्थ - सेल आकार बढ़ाने का प्रयास करें"

#, c-format
msgid "Error writing temporary file <%s>"
msgstr "अस्थायी फ़ाइल <%s> लिखने में त्रुटि"

msgid "Resamples raster map layers to a coarser grid using aggregation."
msgstr "एकत्रीकरण का उपयोग करके रेखापुंज मानचित्र परतों को एक मोटे ग्रिड में पुन: नमूना करता है।"

msgid "Aggregation method"
msgstr "एकत्रीकरण विधि"

msgid "Weight according to area (slower)"
msgstr "क्षेत्र के अनुसार वजन (धीमा)"

msgid "GRASS raster map layer data resampling capability."
msgstr "GRASS रेखापुंज मानचित्र परत डेटा पुन: नमूनाकरण क्षमता।"

msgid "Name of an input layer"
msgstr "एक इनपुट परत का नाम"

msgid "Name of an output layer"
msgstr "आउटपुट परत का नाम"

msgid "Creating new cats file..."
msgstr "नई बिल्लियाँ फ़ाइल बनाई जा रही हैं..।"

#, c-format
msgid "Reading %s ..."
msgstr "%s पढ़ रहा हूँ ..।"

msgid "rescale"
msgstr "पुनः मापना"

msgid "Rescales histogram equalized the range of category values in a raster map layer."
msgstr "पुनर्स्केल हिस्टोग्राम ने रैस्टर मानचित्र परत में श्रेणी मानों की सीमा को बराबर कर दिया।"

msgid "The name of the raster map to be rescaled"
msgstr "पुनर्स्केल किए जाने वाले रेखापुंज मानचित्र का नाम"

msgid "The input data range to be rescaled (default: full range of input map)"
msgstr "इनपुट डेटा रेंज को पुनः स्केल किया जाना है (डिफ़ॉल्ट: इनपुट मैप की पूरी रेंज)"

msgid "The resulting raster map name"
msgstr "परिणामी रेखापुंज मानचित्र का नाम"

msgid "The output data range"
msgstr "आउटपुट डेटा रेंज"

msgid "Title for new raster map"
msgstr "नये रेखापुंज मानचित्र का शीर्षक"

#, c-format
msgid "Rescale %s[%d,%d] to %s[%d,%d]"
msgstr "%s[%d,%d] को %s[%d,%d] पर पुनः स्केल करें"

msgid "Rescales the range of category values in a raster map layer."
msgstr "रैस्टर मानचित्र परत में श्रेणी मानों की श्रेणी को पुन: मापता है।"

#, c-format
msgid "Rescale %s[%ld,%ld] to %s[%ld,%ld]"
msgstr "%s[%ld,%ld] को %s[%ld,%ld] पर पुनः स्केल करें"

msgid "fire"
msgstr "आग"

msgid "spread"
msgstr "फैलाना"

msgid "rate of spread"
msgstr "प्रसार की दर"

msgid "model"
msgstr "नमूना"

msgid "Generates rate of spread raster maps."
msgstr "प्रसार रेखापुंज मानचित्रों की दर उत्पन्न करता है।"

msgid "Generates three, or four raster map layers showing the base (perpendicular) rate of spread (ROS), the maximum (forward) ROS, the direction of the maximum ROS, and optionally the maximum potential spotting distance for fire spread simulation."
msgstr "तीन, या चार रेखापुंज मानचित्र परतें उत्पन्न करता है जो प्रसार की आधार (लंबवत) दर (आरओएस), अधिकतम (आगे) आरओएस, अधिकतम आरओएस की दिशा और वैकल्पिक रूप से आग प्रसार सिमुलेशन के लिए अधिकतम संभावित स्पॉटिंग दूरी दिखाती है।"

msgid "Raster map containing fuel models"
msgstr "ईंधन मॉडल युक्त रेखापुंज मानचित्र"

msgid "Name of an existing raster map layer in the user's current mapset search path containing the standard fuel models defined by the USDA Forest Service. Valid values are 1-13; other numbers are recognized as barriers by r.ros."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रैस्टर मैप परत का नाम जिसमें यूएसडीए वन सेवा द्वारा परिभाषित मानक ईंधन मॉडल शामिल हैं। वैध मान 1-13 हैं; अन्य नंबरों को r.ros द्वारा बाधाओं के रूप में पहचाना जाता है।"

msgid "Raster map containing the 1-hour fuel moisture (%)"
msgstr "1 घंटे की ईंधन नमी (%) युक्त रेखापुंज मानचित्र"

msgid "Name of an existing raster map layer in the user's current mapset search path containing the 1-hour (<.25\") fuel moisture (percentage content multiplied by 100)."
msgstr "Name of an existing raster map layer in the user's current mapset search path containing the 1-hour (<.25\\\") fuel moisture (percentage content multiplied by 100)।"

msgid "Raster map containing the 10-hour fuel moisture (%)"
msgstr "10 घंटे की ईंधन नमी युक्त रेखापुंज मानचित्र (%)"

msgid "Name of an existing raster map layer in the user's current mapset search path containing the 10-hour (.25-1\") fuel moisture (percentage content multiplied by 100)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रैस्टर मैप परत का नाम जिसमें 10-घंटे (.25-1\\\") ईंधन नमी (प्रतिशत सामग्री 100 से गुणा) शामिल है।"

msgid "Raster map containing the 100-hour fuel moisture (%)"
msgstr "100-घंटे की ईंधन नमी (%) युक्त रेखापुंज मानचित्र"

msgid "Name of an existing raster map layer in the user's current mapset search path containing the 100-hour (1-3\") fuel moisture (percentage content multiplied by 100)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रैस्टर मैप परत का नाम जिसमें 100-घंटे (1-3\\\") ईंधन नमी (प्रतिशत सामग्री 100 से गुणा) शामिल है।"

msgid "Raster map containing live fuel moisture (%)"
msgstr "जीवित ईंधन नमी युक्त रेखापुंज मानचित्र (%)"

msgid "Name of an existing raster map layer in the user's current mapset search path containing live (herbaceous) fuel moisture (percentage content multiplied by 100)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रैस्टर मैप परत का नाम जिसमें जीवित (जड़ी-बूटी) ईंधन नमी (प्रतिशत सामग्री 100 से गुणा) शामिल है।"

msgid "Raster map containing midflame wind velocities (ft/min)"
msgstr "मध्य ज्वाला पवन वेग (फीट/मिनट) युक्त रेखापुंज मानचित्र"

msgid "Name of an existing raster map layer in the user's current mapset search path containing wind velocities at half of the average flame height (feet/minute)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रैस्टर मैप परत का नाम जिसमें औसत लौ ऊंचाई (फीट/मिनट) के आधे पर हवा का वेग शामिल है।"

msgid "Name of raster map containing wind directions (degree)"
msgstr "हवा की दिशाओं (डिग्री) वाले रेखापुंज मानचित्र का नाम"

msgid "Name of an existing raster map layer in the user's current mapset search path containing wind direction, clockwise from north (degree)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रेखापुंज मानचित्र परत का नाम जिसमें हवा की दिशा, उत्तर से दक्षिणावर्त (डिग्री) शामिल है।"

msgid "Name of raster map containing slope (degree)"
msgstr "ढलान (डिग्री) युक्त रेखापुंज मानचित्र का नाम"

msgid "Name of an existing raster map layer in the user's current mapset search path containing topographic slope (degree)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में स्थलाकृतिक ढलान (डिग्री) युक्त मौजूदा रेखापुंज मानचित्र परत का नाम।"

msgid "Raster map containing aspect (degree, CCW from E)"
msgstr "रेखापुंज मानचित्र जिसमें पहलू (डिग्री, ई से सीसीडब्ल्यू) शामिल है"

msgid "Name of an existing raster map layer in the user's current mapset search path containing topographic aspect, counterclockwise from east (GRASS convention) in degrees."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रेखापुंज मानचित्र परत का नाम जिसमें स्थलाकृतिक पहलू, पूर्व से वामावर्त (ग्रास सम्मेलन) डिग्री में शामिल है।"

msgid "Raster map containing elevation (m, required for spotting)"
msgstr "ऊंचाई युक्त रेखापुंज मानचित्र (एम, स्पॉटिंग के लिए आवश्यक)"

msgid "Name of an existing raster map layer in the user's current mapset search path containing elevation (meters). Option is required from spotting distance computation (when spotting_distance option is provided)"
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में ऊंचाई (मीटर) युक्त मौजूदा रेखापुंज मानचित्र परत का नाम। स्पॉटिंग दूरी की गणना के लिए विकल्प की आवश्यकता होती है (जब स्पॉटिंग_डिस्टेंस विकल्प प्रदान किया जाता है)"

msgid "Output raster map containing base ROS (cm/min)"
msgstr "बेस आरओएस युक्त आउटपुट रैस्टर मानचित्र (सेमी/मिनट)"

msgid "Base (perpendicular) rate of spread (ROS)"
msgstr "प्रसार की आधार (लंबवत) दर (आरओएस)"

msgid "Output raster map containing maximal ROS (cm/min)"
msgstr "अधिकतम आरओएस (सेमी/मिनट) युक्त आउटपुट रैस्टर मानचित्र"

msgid "The maximum (forward) rate of spread (ROS)"
msgstr "प्रसार की अधिकतम (आगे) दर (आरओएस)"

msgid "Output raster map containing directions of maximal ROS (degree)"
msgstr "अधिकतम आरओएस (डिग्री) के निर्देशों वाला आउटपुट रैस्टर मानचित्र"

msgid "The direction of the maximal (forward) rate of spread (ROS)"
msgstr "प्रसार की अधिकतम (आगे) दर की दिशा (आरओएस)"

msgid "Output raster map containing maximal spotting distance (m)"
msgstr "अधिकतम स्पॉटिंग दूरी (एम) युक्त आउटपुट रास्टर मानचित्र"

msgid "The maximal potential spotting distance (requires elevation raster map to be provided)."
msgstr "अधिकतम संभावित स्पॉटिंग दूरी (उन्नयन रेखापुंज मानचित्र प्रदान करने की आवश्यकता है)।"

msgid "No dead fuel moisture is given. At least one of the 1-h, 10-h, 100-h moisture layers is required."
msgstr "कोई मृत ईंधन नमी नहीं दी गई है। 1-एच, 10-एच, 100-एच नमी परतों में से कम से कम एक की आवश्यकता होती है।"

#, c-format
msgid "A wind direction layer should be given if the wind velocity layer <%s> has been given"
msgstr "यदि पवन वेग परत <%s> दी गई है तो हवा की दिशा परत दी जानी चाहिए"

#, c-format
msgid "A wind velocity layer should be given if the wind direction layer <%s> has been given"
msgstr "यदि हवा की दिशा परत <%s> दी गई है तो पवन वेग परत दी जानी चाहिए"

#, c-format
msgid "An aspect layer should be given if the slope layer <%s> has been given"
msgstr "यदि ढलान परत <%s> दी गई है तो एक पहलू परत दी जानी चाहिए"

#, c-format
msgid "A slope layer should be given if the aspect layer <%s> has been given"
msgstr "यदि पहलू परत <%s> दी गई है तो एक ढलान परत दी जानी चाहिए"

msgid "An elevation layer should be given if considering spotting"
msgstr "यदि स्पॉटिंग पर विचार किया जाए तो एक ऊंचाई परत दी जानी चाहिए"

#, c-format
msgid "Raster maps <%s>, <%s> and <%s> created."
msgstr "रेखापुंज मानचित्र <%s>, <%s> और <%s> बनाए गए।"

msgid "Makes each output cell value a accumulationfunction of the values assigned to the corresponding cells in the input raster map layers."
msgstr "प्रत्येक आउटपुट सेल मान को इनपुट रैस्टर मैप परतों में संबंधित सेल को निर्दिष्ट मानों का संचय फ़ंक्शन बनाता है।"

msgid "Existing map to be added to output"
msgstr "मौजूदा मानचित्र को आउटपुट में जोड़ा जाएगा"

msgid "Input file with raster map names, one per line"
msgstr "रेखापुंज मानचित्र नामों के साथ इनपुट फ़ाइल, प्रति पंक्ति एक"

msgid "Scale factor for input"
msgstr "इनपुट के लिए स्केल कारक"

msgid "Shift factor for input"
msgstr "इनपुट के लिए शिफ्ट फैक्टर"

msgid "The raster map specifying the lower accumulation limit, also called baseline"
msgstr "निचली संचय सीमा को निर्दिष्ट करने वाला रेखापुंज मानचित्र, जिसे बेसलाइन भी कहा जाता है"

msgid "The raster map specifying the upper accumulation limit, also called cutoff. Only applied to BEDD computation."
msgstr "ऊपरी संचय सीमा को निर्दिष्ट करने वाला रेखापुंज मानचित्र, जिसे कटऑफ़ भी कहा जाता है। केवल BEDD गणना के लिए लागू।"

msgid "Ignore values outside this range"
msgstr "इस सीमा के बाहर के मानों पर ध्यान न दें"

msgid "Use these limits in case lower and/or upper input maps are not defined"
msgstr "यदि निचले और/या ऊपरी इनपुट मानचित्र परिभाषित नहीं हैं तो इन सीमाओं का उपयोग करें"

msgid "Growing Degree Days or Winkler indices"
msgstr "बढ़ती डिग्री वाले दिन या विंकलर सूचकांक"

msgid "Mean: sum(input maps)/(number of input maps)"
msgstr "माध्य: योग (इनपुट मानचित्र)/(इनपुट मानचित्रों की संख्या)"

msgid "Biologically Effective Degree Days"
msgstr "जैविक रूप से प्रभावी डिग्री दिवस"

msgid "Huglin Heliothermal index"
msgstr "हग्लिन हेलियोथर्मल इंडेक्स"

msgid "Do not keep files open"
msgstr "फ़ाइलें खुली न रखें"

msgid "Create a FCELL map (floating point single precision) as output"
msgstr "आउटपुट के रूप में एक FCELL मैप (फ़्लोटिंग पॉइंट सिंगल प्रिसिजन) बनाएं"

#, c-format
msgid "'%s'=%f must be > '%s'=%f"
msgstr "'%s'=%f > '%s'=%f होना चाहिए"

msgid "Interpolates raster maps located (temporal or spatial) in between input raster maps at specific sampling positions."
msgstr "विशिष्ट नमूना स्थितियों पर इनपुट रेखापुंज मानचित्रों के बीच स्थित (अस्थायी या स्थानिक) रेखापुंज मानचित्रों को प्रक्षेपित करता है।"

msgid "Data point position for each input map"
msgstr "प्रत्येक इनपुट मानचित्र के लिए डेटा बिंदु स्थिति"

msgid "Input file with one input raster map name and data point position per line, field separator between name and sample point is |"
msgstr "एक इनपुट रैस्टर मानचित्र नाम और प्रति पंक्ति डेटा बिंदु स्थिति के साथ इनपुट फ़ाइल, नाम और नमूना बिंदु के बीच फ़ील्ड विभाजक है |"

msgid "Sampling point position for each output map"
msgstr "प्रत्येक आउटपुट मानचित्र के लिए नमूना बिंदु स्थिति"

msgid "Input file with one output raster map name and sample point position per line, field separator between name and sample point is |"
msgstr "एक आउटपुट रैस्टर मानचित्र नाम और प्रति पंक्ति नमूना बिंदु स्थिति के साथ इनपुट फ़ाइल, नाम और नमूना बिंदु के बीच फ़ील्ड विभाजक है |"

msgid "Interpolation method, currently only linear interpolation is supported"
msgstr "इंटरपोलेशन विधि, वर्तमान में केवल रैखिक इंटरपोलेशन समर्थित है"

#, c-format
msgid "Please specify %s= and %s="
msgstr "कृपया %s= और %s= निर्दिष्ट करें"

#, c-format
msgid "Missing point position for %s map <%s> in file <%s> near line %i"
msgstr "लाइन %i के पास फ़ाइल <%s> में %s मानचित्र <%s> के लिए गुम बिंदु स्थिति"

#, c-format
