#, c-format
msgid "Table <%s> already exists, use '%s'"
msgstr "तालिका <%s> पहले से मौजूद है, '%s' का उपयोग करें"

#, c-format
msgid "Copying vector features from <%s>..."
msgstr "<%s> से वेक्टर सुविधाओं की प्रतिलिपि बनाई जा रही है..।"

#, c-format
msgid "No %s features found in vector map <%s>. Verify '%s' parameter."
msgstr "वेक्टर मानचित्र <%s> में कोई %s विशेषता नहीं मिली। '%s' पैरामीटर सत्यापित करें।"

msgid "Collecting input attributes..."
msgstr "इनपुट विशेषताएँ एकत्रित की जा रही हैं..।"

#, c-format
msgid "Unknown column type '%s' of column '%s'"
msgstr "अज्ञात स्तंभ प्रकार '%s' स्तंभ '%s'"

#, c-format
msgid "Unknown column type '%s' of column '%s', values lost"
msgstr "कॉलम '%s' का अज्ञात कॉलम प्रकार '%s', मान खो गए"

msgid "Creates parallel line to input vector lines."
msgstr "वेक्टर रेखाओं को इनपुट करने के लिए समानांतर रेखा बनाता है।"

msgid "Offset along major axis in map units"
msgstr "मानचित्र इकाइयों में प्रमुख अक्ष के साथ ऑफसेट"

msgid "Offset along minor axis in map units"
msgstr "मानचित्र इकाइयों में लघु अक्ष के साथ ऑफसेट"

msgid "Side"
msgstr "ओर"

msgid "Parallel line is on the left"
msgstr "बायीं ओर समांतर रेखा है"

msgid "Parallel line is on the right"
msgstr "समांतर रेखा दाहिनी ओर है"

msgid "Parallel lines on both sides"
msgstr "दोनों ओर समानांतर रेखाएँ"

msgid "Tolerance of arc polylines in map units"
msgstr "मानचित्र इकाइयों में चाप पॉलीलाइनों की सहनशीलता"

msgid "Make outside corners round"
msgstr "बाहरी कोनों को गोल बनायें"

msgid "Create buffer-like parallel lines"
msgstr "बफ़र जैसी समानांतर रेखाएँ बनाएँ"

msgid "Creates a new vector map by combining other vector maps."
msgstr "अन्य वेक्टर मानचित्रों को मिलाकर एक नया वेक्टर मानचित्र बनाता है।"

msgid "Name for output vector map where bounding boxes of input vector maps are written to"
msgstr "आउटपुट वेक्टर मानचित्र का नाम जहां इनपुट वेक्टर मानचित्रों के बाउंडिंग बॉक्स लिखे जाते हैं"

msgid "Do not expect input with topology"
msgstr "टोपोलॉजी के साथ इनपुट की अपेक्षा न करें"

msgid "Applicable when input is points without topology"
msgstr "यह तब लागू होता है जब इनपुट टोपोलॉजी के बिना बिंदु हो"

msgid "Expect z coordinate even when not using topology"
msgstr "टोपोलॉजी का उपयोग न करने पर भी z समन्वय की अपेक्षा करें"

msgid "Applicable when input is points with z coordinate but without topology"
msgstr "यह तब लागू होता है जब इनपुट z निर्देशांक वाले बिंदु हों लेकिन टोपोलॉजी के बिना"

msgid "Copy also attribute table"
msgstr "विशेषता तालिका भी कॉपी करें"

msgid "Only the table of layer 1 is currently supported"
msgstr "वर्तमान में केवल परत 1 की तालिका समर्थित है"

msgid "Append files to existing file (overwriting existing files must be activated)"
msgstr "फ़ाइलों को मौजूदा फ़ाइल में जोड़ें (मौजूदा फ़ाइलों को ओवरराइट करना सक्रिय होना चाहिए)"

#, c-format
msgid "Missing attribute table for vector map <%s>"
msgstr "वेक्टर मानचित्र <%s> के लिए अनुपलब्ध विशेषता तालिका"

#, c-format
msgid "Missing table for <%s>"
msgstr "<%s> के लिए गुम तालिका"

#, c-format
msgid "Key (category) column names differ: <%s> from <%s> and <%s> from <%s>"
msgstr "कुंजी (श्रेणी) कॉलम के नाम भिन्न हैं: <%s> से <%s> और <%s> से <%s>"

#, c-format
msgid "Number of columns differ: %d in <%s> and %d in <%s>"
msgstr "स्तंभों की संख्या भिन्न है: %d में <%s> और %d में <%s>"

#, c-format
msgid "No column <%s> in input map <%s>"
msgstr "इनपुट मैप <%s> में कोई कॉलम <%s> नहीं"

#, c-format
msgid "Column types differ:  <%s> from <%s> is <%s> and <%s> from <%s> is <%s>"
msgstr "कॉलम प्रकार भिन्न होते हैं: <%s> से <%s> है <%s> और <%s> से <%s> है <%s>"

msgid "Length of string columns differ"
msgstr "स्ट्रिंग कॉलम की लंबाई अलग-अलग होती है"

msgid "Key column not found"
msgstr "कुंजी स्तंभ नहीं मिला"

msgid "The output map is not 3D"
msgstr "आउटपुट मैप 3D नहीं है"

#, c-format
msgid "Patching vector map <%s>..."
msgstr "वेक्टर मानचित्र को पैच करना <%s>..।"

#, c-format
msgid "Error reading vector map <%s> - some data may not be correct"
msgstr "वेक्टर मानचित्र <%s> पढ़ने में त्रुटि - कुछ डेटा सही नहीं हो सकता है"

#, c-format
msgid "Building topology for vector map <%s>..."
msgstr "वेक्टर मानचित्र के लिए बिल्डिंग टोपोलॉजी <%s>..।"

msgid "Intersections at borders will have to be snapped"
msgstr "सीमाओं पर चौराहों को तोड़ना होगा"

msgid "Lines common between files will have to be edited"
msgstr "फ़ाइलों के बीच सामान्य पंक्तियों को संपादित करना होगा"

msgid "The header information also may have to be edited"
msgstr "हेडर जानकारी को भी संपादित करना पड़ सकता है"

#, c-format
msgid "%d vector maps patched"
msgstr "%d वेक्टर मानचित्र पैच किए गए"

#, c-format
msgid "Cannot open select cursor: '%s'"
msgstr "चयनित कर्सर नहीं खोल सकता: '%s'"

msgid "Cannot fetch row"
msgstr "पंक्ति नहीं लायी जा सकती"

msgid "Unknown column type"
msgstr "अज्ञात स्तंभ प्रकार"

#, c-format
msgid "Cannot insert new record: '%s'"
msgstr "नया रिकॉर्ड सम्मिलित नहीं किया जा सकता: '%s'"

msgid "Random location perturbations of vector points."
msgstr "वेक्टर बिंदुओं का यादृच्छिक स्थान गड़बड़ी।"

msgid "Distribution of perturbation"
msgstr "विक्षोभ का वितरण"

msgid "Parameter(s) of distribution"
msgstr "वितरण के पैरामीटर"

msgid "If the distribution is uniform, only one parameter, the maximum, is needed. For a normal distribution, two parameters, the mean and standard deviation, are required."
msgstr "यदि वितरण एक समान है, तो केवल एक पैरामीटर, अधिकतम, की आवश्यकता है। सामान्य वितरण के लिए, दो मापदंडों, माध्य और मानक विचलन की आवश्यकता होती है।"

msgid "Minimum deviation in map units"
msgstr "मानचित्र इकाइयों में न्यूनतम विचलन"

msgid "Error scanning arguments"
msgstr "तर्क स्कैन करने में त्रुटि"

msgid "Maximum of uniform distribution must be >= zero"
msgstr "समान वितरण की अधिकतम सीमा >=शून्य होनी चाहिए"

msgid "Standard deviation of normal distribution must be >= zero"
msgstr "सामान्य वितरण का मानक विचलन >=शून्य होना चाहिए"

msgid "Cannot get db link info"
msgstr "डीबी लिंक की जानकारी नहीं मिल सकी"

msgid "normalsv: restoration of uninitialized block"
msgstr "नॉर्मल्सवी: अप्रारंभीकृत ब्लॉक की बहाली"

msgid "normalsv: save of uninitialized block"
msgstr "नॉर्मल्सवी: अप्रारंभीकृत ब्लॉक को सहेजें"

msgid "Vector map profiling tool"
msgstr "वेक्टर मानचित्र प्रोफ़ाइलिंग उपकरण"

msgid "Use features only from specified layer"
msgstr "केवल निर्दिष्ट परत से सुविधाओं का उपयोग करें"

msgid "Path to output text file or - for stdout"
msgstr "आउटपुट टेक्स्ट फ़ाइल का पथ या - stdout के लिए"

msgid "plain;Plain text with pipe separator;csv;CSV (Comma Separated Values);json;JSON (JavaScript Object Notation)"
msgstr "सादा; पाइप विभाजक के साथ सादा पाठ; सीएसवी; सीएसवी (अल्पविराम से अलग किए गए मान); जेएसओएन; जेएसओएन (जावास्क्रिप्ट ऑब्जेक्ट नोटेशन)"

msgid "Buffer (tolerance) for points in map units"
msgstr "मानचित्र इकाइयों में बिंदुओं के लिए बफर (सहिष्णुता)।"

msgid "How far points can be from sampling line"
msgstr "नमूना रेखा से बिंदु कितने दूर हो सकते हैं"

msgid "Name for profile line and buffer output map"
msgstr "प्रोफ़ाइल लाइन और बफ़र आउटपुट मैप का नाम"

msgid "Profile line and buffer around it will be written"
msgstr "इसके चारों ओर प्रोफाइल लाइन और बफर लिखा होगा"

msgid "Do not print column names"
msgstr "कॉलम नाम न छापें"

msgid "Do not print 3D vector data (z values)"
msgstr "3D वेक्टर डेटा (z मान) प्रिंट न करें"

msgid "Only affects 3D vectors"
msgstr "केवल 3डी वैक्टर को प्रभावित करता है"

msgid "Coordinates for profiling line nodes"
msgstr "प्रोफाइलिंग लाइन नोड्स के लिए निर्देशांक"

msgid "Specify profiling line vertices and nodes"
msgstr "प्रोफ़ाइलिंग लाइन शीर्ष और नोड्स निर्दिष्ट करें"

msgid "Profiling line"
msgstr "प्रोफाइलिंग लाइन"

msgid "Profiling line map"
msgstr "प्रोफ़ाइल रेखा मानचित्र"

msgid "Vector map containing profiling line"
msgstr "प्रोफाइलिंग लाइन युक्त वेक्टर मानचित्र"

msgid "WHERE conditions for input profile line map"
msgstr "जहां इनपुट प्रोफाइल लाइन मैप के लिए शर्तें हैं"

msgid "Use to select only one line from profiling line map"
msgstr "प्रोफाइलिंग लाइन मैप से केवल एक लाइन का चयन करने के लिए उपयोग करें"

msgid "Profiling line map layer"
msgstr "प्रोफ़ाइल रेखा मानचित्र परत"

msgid "Layer 0 not supported"
msgstr "परत 0 समर्थित नहीं है"

msgid "Failed to interpreter 'dp' parameter as an integer"
msgstr "'डीपी' पैरामीटर को पूर्णांक के रूप में व्याख्या करने में विफल"

msgid "Tolerance value must be greater than 0"
msgstr "सहनशीलता मान 0 से अधिक होना चाहिए"

#, c-format
msgid "<%s> is not a valid vector map name"
msgstr "<%s> मान्य वेक्टर मानचित्र नाम नहीं है"

msgid "No input profile map name provided, but WHERE conditions for it have been set"
msgstr "कोई इनपुट प्रोफ़ाइल मानचित्र नाम प्रदान नहीं किया गया है, लेकिन इसके लिए WHERE शर्तें निर्धारित की गई हैं"

msgid "Profile input coordinates and vector map are provided. Please provide only one of them"
msgstr "प्रोफ़ाइल इनपुट निर्देशांक और वेक्टर मानचित्र प्रदान किए गए हैं। कृपया उनमें से केवल एक ही प्रदान करें"

msgid "No profile input coordinates nor vector map are provided. Please provide one of them"
msgstr "कोई प्रोफ़ाइल इनपुट निर्देशांक और न ही वेक्टर मानचित्र प्रदान किया गया है। कृपया उनमें से एक प्रदान करें"

msgid "At least profile start and end coordinates are required!"
msgstr "कम से कम प्रोफ़ाइल प्रारंभ और अंत निर्देशांक आवश्यक हैं!"

#, c-format
msgid "No database connection defined for map <%s> layer %d, but WHERE condition is provided"
msgstr "मानचित्र <%s> परत %d के लिए कोई डेटाबेस कनेक्शन परिभाषित नहीं है, लेकिन WHERE शर्त प्रदान की गई है"

msgid "No features match Your query"
msgstr "कोई भी विशेषता आपकी क्वेरी से मेल नहीं खाती"

msgid "Your query matches more than one record in input profiling map. Currently it's not supported. Enhance WHERE conditions to get only one line."
msgstr "आपकी क्वेरी इनपुट प्रोफाइलिंग मैप में एक से अधिक रिकॉर्ड से मेल खाती है। वर्तमान में यह समर्थित नहीं है. केवल एक पंक्ति प्राप्त करने के लिए WHERE शर्तों को बढ़ाएँ।"

msgid "Error while initialising line list"
msgstr "पंक्ति सूची प्रारंभ करते समय त्रुटि"

msgid "Error while reading vector feature from profile line map"
msgstr "प्रोफ़ाइल लाइन मानचित्र से वेक्टर सुविधा पढ़ते समय त्रुटि"

msgid "Your input profile map contains more than one line. Currently it's not supported. Provide WHERE conditions to get only one line."
msgstr "आपके इनपुट प्रोफ़ाइल मानचित्र में एक से अधिक पंक्तियाँ हैं। वर्तमान में यह समर्थित नहीं है. केवल एक पंक्ति प्राप्त करने के लिए WHERE शर्तें प्रदान करें।"

msgid "Failed to convert GRASS line to GEOS line"
msgstr "GRASS लाइन को GEOS लाइन में परिवर्तित करने में विफल"

msgid "Buffering failed"
msgstr "बफ़रिंग विफल"

#, c-format
msgid "Vector map <%s> does not have cat's defined on layer %d"
msgstr "वेक्टर मानचित्र <%s> में परत %d पर बिल्ली परिभाषित नहीं है"

msgid "Can not write data portion to provided output"
msgstr "दिए गए आउटपुट में डेटा भाग नहीं लिख सकता"

msgid "Re-projects a vector map from one project to the current project."
msgstr "एक वेक्टर मानचित्र को एक प्रोजेक्ट से वर्तमान प्रोजेक्ट में पुनः प्रोजेक्ट करता है।"

msgid "Project (location) containing input vector map"
msgstr "प्रोजेक्ट (स्थान) जिसमें इनपुट वेक्टर मानचित्र शामिल है"

msgid "Mapset containing input vector map"
msgstr "इनपुट वेक्टर मानचित्र युक्त मैपसेट"

msgid "Name of input vector map to re-project"
msgstr "पुन: प्रोजेक्ट करने के लिए इनपुट वेक्टर मानचित्र का नाम"

msgid "Maximum segment length in meters in output vector map"
msgstr "आउटपुट वेक्टर मानचित्र में मीटर में अधिकतम खंड लंबाई"

msgid "Increases accuracy of reprojected shapes, disable with smax=0"
msgstr "पुन: प्रक्षेपित आकृतियों की सटीकता बढ़ाता है, smax=0 के साथ अक्षम करें"

msgid "List vector maps in input mapset and exit"
msgstr "इनपुट मैपसेट और निकास में वेक्टर मानचित्रों की सूची बनाएं"

msgid "3D vector maps only"
msgstr "केवल 3डी वेक्टर मानचित्र"

msgid "Assume z coordinate is ellipsoidal height and transform if possible"
msgstr "मान लें कि z निर्देशांक दीर्घवृत्ताकार ऊंचाई है और यदि संभव हो तो परिवर्तन करें"

msgid "Latlon output only, default is -180,180"
msgstr "केवल लैटलॉन आउटपुट, डिफ़ॉल्ट -180,180 है"

msgid "Disable wrapping to -180,180 for latlon output"
msgstr "लैटलॉन आउटपुट के लिए रैपिंग को -180,180 पर अक्षम करें"

msgid "Recommended for massive point projection"
msgstr "बड़े पैमाने पर बिंदु प्रक्षेपण के लिए अनुशंसित"

msgid "Input and output projects can not be the same"
msgstr "इनपुट और आउटपुट प्रोजेक्ट एक जैसे नहीं हो सकते"

msgid "No vector maps found"
msgstr "कोई वेक्टर मानचित्र नहीं मिला"

#, c-format
msgid "Vector map <%s> in project <%s> mapset <%s> not found"
msgstr "प्रोजेक्ट <%s> मैपसेट <%s> में वेक्टर मानचित्र <%s> नहीं मिला"

msgid "Reading input vector map"
msgstr "इनपुट वेक्टर मानचित्र पढ़ना"

#, c-format
msgid "Input vector map <%s> is empty"
msgstr "इनपुट वेक्टर मानचित्र <%s> खाली है"

#, c-format
msgid "Mapset <%s> in input project <%s> - permission denied"
msgstr "इनपुट प्रोजेक्ट <%s> में मैपसेट <%s> - अनुमति अस्वीकृत"

#, c-format
msgid "Mapset <%s> in input project <%s> not found"
msgstr "इनपुट प्रोजेक्ट <%s> में मैपसेट <%s> नहीं मिला"

msgid "Reprojecting primitives ..."
msgstr "आदिम को पुनः अस्वीकार करना..।"

#, c-format
msgid "Unable to re-project vector map <%s> from <%s>"
msgstr "वेक्टर मानचित्र <%s> को <%s> से पुनः प्रोजेक्ट करने में असमर्थ"

msgid "Try to disable wrapping to -180,180 if topological errors occurred"
msgstr "यदि टोपोलॉजिकल त्रुटियां हुईं तो रैपिंग को -180,180 पर अक्षम करने का प्रयास करें"

msgid "Indices for quadrat counts of vector point lists."
