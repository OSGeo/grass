msgstr "संख्यात्मक गणना के पीजोमेट्रिक हेड परिणाम को संग्रहीत करने वाला आउटपुट 3डी रैस्टर मानचित्र"

msgid "Output 3D raster map storing the groundwater filter velocity vector part in x direction [m/s]"
msgstr "आउटपुट 3डी रेखापुंज मानचित्र भूजल फ़िल्टर वेग वेक्टर भाग को x दिशा में संग्रहीत करता है [एम/एस]"

msgid "Output 3D raster map storing the groundwater filter velocity vector part in y direction [m/s]"
msgstr "आउटपुट 3डी रेखापुंज मानचित्र भूजल फ़िल्टर वेग वेक्टर भाग को y दिशा में संग्रहीत करता है [एम/एस]"

msgid "Output 3D raster map storing the groundwater filter velocity vector part in z direction [m/s]"
msgstr "आउटपुट 3डी रेखापुंज मानचित्र भूजल फ़िल्टर वेग वेक्टर भाग को z दिशा में संग्रहीत करता है [एम/एस]"

msgid "Output 3D raster map storing the groundwater budget for each cell [m^3/s]"
msgstr "प्रत्येक कोशिका के लिए भूजल बजट संग्रहीत करने वाला आउटपुट 3डी रैस्टर मानचित्र [m^3/s]"

msgid "Use 3D raster mask (if exists)"
msgstr "3डी रैस्टर मास्क का उपयोग करें (यदि मौजूद है)"

msgid "Numerical calculation program for transient, confined groundwater flow in three dimensions."
msgstr "तीन आयामों में क्षणिक, सीमित भूजल प्रवाह के लिए संख्यात्मक गणना कार्यक्रम।"

msgid ""
"The cholesky solver does not work with sparse matrices.\n"
"Consider to choose a full filled quadratic matrix with flag -f "
msgstr "कोलेस्की सॉल्वर विरल मैट्रिक्स के साथ काम नहीं करता है।\\nफ्लैग -एफ के साथ पूर्ण भरे हुए द्विघात मैट्रिक्स को चुनने पर विचार करें "

msgid "No sink map provided. Initializing zero sink..."
msgstr "कोई सिंक मानचित्र उपलब्ध नहीं कराया गया. शून्य सिंक प्रारंभ किया जा रहा है..।"

#, c-format
msgid "Unable to create 3D raster map <%s>"
msgstr "3D रेखापुंज मानचित्र बनाने में असमर्थ <%s>"

msgid "String representing NULL value data cell (use 'none' if no such value)"
msgstr "शून्य मान डेटा सेल का प्रतिनिधित्व करने वाली स्ट्रिंग (यदि ऐसा कोई मान नहीं है तो 'कोई नहीं' का उपयोग करें)"

#, c-format
msgid "Unsupported GRASS version %s"
msgstr "असमर्थित GRASS संस्करण %s"

#, c-format
msgid "Loading data ...  (%dx%dx%d)"
msgstr "डेटा लोड हो रहा है... (%dx%dx%d)"

msgid "End of file reached while still loading data."
msgstr "डेटा लोड करते समय फ़ाइल का अंत हो गया।"

#, c-format
msgid "Invalid value detected (at col=%d row=%d depth=%d): %s"
msgstr "अमान्य मान पाया गया (col=%d पंक्ति=%d गहराई=%d पर): %s"

#, c-format
msgid "Data exists in input file after fully importing expected data.  [%.4f ...]"
msgstr "अपेक्षित डेटा को पूरी तरह से आयात करने के बाद डेटा इनपुट फ़ाइल में मौजूद है।  [%4f...]"

msgid "Converts a 3D ASCII raster text file into a (binary) 3D raster map."
msgstr "एक 3D ASCII रैस्टर टेक्स्ट फ़ाइल को (बाइनरी) 3D रैस्टर मानचित्र में परिवर्तित करता है।"

msgid "Unable to open 3D raster map"
msgstr "3D रेखापुंज मानचित्र खोलने में असमर्थ"

msgid "Unable to close ASCII file"
msgstr "ASCII फ़ाइल बंद करने में असमर्थ"

msgid "Error reading binary data"
msgstr "बाइनरी डेटा पढ़ने में त्रुटि"

#, c-format
msgid "Loading %s data with %i  bytes ...  (%dx%dx%d)"
msgstr "%s डेटा को %i बाइट्स के साथ लोड किया जा रहा है... (%dx%dx%d)"

msgid "Error flushing tiles"
msgstr "टाइल्स फ्लश करने में त्रुटि"

msgid "Imports a binary raster file into a GRASS 3D raster map."
msgstr "एक बाइनरी रैस्टर फ़ाइल को GRASS 3D रैस्टर मानचित्र में आयात करता है।"

msgid "Name of binary 3D raster file to be imported"
msgstr "आयात की जाने वाली बाइनरी 3डी रैस्टर फ़ाइल का नाम"

msgid "Number of bytes per cell in binary file"
msgstr "बाइनरी फ़ाइल में प्रति सेल बाइट्स की संख्या"

msgid "Byte order in binary file"
msgstr "बाइनरी फ़ाइल में बाइट क्रम"

msgid "Bottom limit of geographic region (outer edge)"
msgstr "भौगोलिक क्षेत्र की निचली सीमा (बाहरी किनारा)"

msgid "Top limit of geographic region (outer edge)"
msgstr "भौगोलिक क्षेत्र की शीर्ष सीमा (बाहरी किनारा)"

msgid "Number of depths"
msgstr "गहराइयों की संख्या"

msgid "Switch the row order in output from north->south to south->north"
msgstr "आउटपुट में पंक्ति क्रम को उत्तर->दक्षिण से दक्षिण->उत्तर पर स्विच करें"

msgid "Switch the depth order in output from bottom->top to top->bottom"
msgstr "आउटपुट में गहराई क्रम को नीचे->ऊपर से ऊपर->नीचे पर स्विच करें"

msgid "Binary data is of type integer"
msgstr "बाइनरी डेटा पूर्णांक प्रकार का होता है"

#, c-format
msgid "bytes=%d; must be 4 or 8 in case of floating point input"
msgstr "बाइट्स=%d; फ़्लोटिंग पॉइंट इनपुट के मामले में 4 या 8 होना चाहिए"

msgid "Integer input doesn't support size=8 in this build"
msgstr "इस बिल्ड में पूर्णांक इनपुट आकार=8 का समर्थन नहीं करता है"

msgid "bytes= must be 1, 2, 4 or 8"
msgstr "बाइट्स = 1, 2, 4 या 8 होना चाहिए"

#, c-format
msgid "File Size %lld ... Total Bytes %lld"
msgstr "फ़ाइल का आकार %lld ... कुल बाइट्स %lld"

#, c-format
msgid "Invalid range <%s> for option %s"
msgstr "विकल्प %s के लिए अमान्य श्रेणी <%s>"

msgid "Creates a 3D raster map from LAS LiDAR points using univariate statistics."
msgstr "यूनीवेरिएट आँकड़ों का उपयोग करके LAS LiDAR बिंदुओं से एक 3D रेखापुंज मानचित्र बनाता है।"

msgid "LiDAR input file in LAS format (*.las or *.laz)"
