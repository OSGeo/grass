msgstr "<%s> में मैपसेट <%s> के लिए ऊंचाई उत्पाद"

#, c-format
msgid "Min computed aspect %.4f, max computed aspect %.4f"
msgstr "न्यूनतम परिकलित पहलू %.4f, अधिकतम परिकलित पहलू %.4f"

#, c-format
