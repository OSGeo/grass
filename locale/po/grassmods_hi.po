msgstr "एक पूर्णांक रेखापुंज मानचित्र बनाएं"

#, c-format
msgid "Minimum %s should be higher than maximum %s, but %s > %s"
msgstr "न्यूनतम %s अधिकतम %s से अधिक होना चाहिए, लेकिन %s > %s"

#, c-format
msgid "Uniform random integer values in range [%s, %s]"
msgstr "[%s, %s] श्रेणी में समान यादृच्छिक पूर्णांक मान"

#, c-format
