msgstr "नये शीर्ष जोड़ें, लेकिन विभाजित न हों"

msgid "Applies only to 'length' option"
msgstr "केवल 'लंबाई' विकल्प पर लागू होता है"

msgid "Force segments to be exactly of given length, except for last one"
msgstr "अंतिम खंड को छोड़कर, खंडों को बिल्कुल दी गई लंबाई के होने के लिए बाध्य करें"

msgid "Use either length or vertices"
msgstr "या तो लंबाई या शीर्ष का उपयोग करें"

#, c-format
msgid "Length must be positive but is %g"
msgstr "लंबाई सकारात्मक होनी चाहिए लेकिन %g है"

#, c-format
msgid "Unknown unit %s"
msgstr "अज्ञात इकाई %s"

msgid "Can not get projection units"
msgstr "प्रक्षेपण इकाइयाँ नहीं मिल सकीं"

#, c-format
msgid "Length in map units: %g"
msgstr "मानचित्र इकाइयों में लंबाई: %g"

#, c-format
msgid "Length in meters: %g"
msgstr "लंबाई मीटर में: %g"

msgid "Number of vertices must be at least 2"
msgstr "शीर्षों की संख्या कम से कम 2 होनी चाहिए"

#, c-format
msgid "Unable to make line segment: %f - %f (line length = %f)"
msgstr "रेखा खंड बनाने में असमर्थ: %f - %f (रेखा की लंबाई = %f)"

msgid "Updates vector map metadata."
msgstr "वेक्टर मानचित्र मेटाडेटा अद्यतन करता है।"

msgid "Organization where vector map was created"
msgstr "वह संगठन जहां वेक्टर मानचित्र बनाया गया था"

msgid "Date of vector map digitization (e.g., \"15 Mar 2007\")"
msgstr "Date of vector map digitization (e.g., \\\"15 Mar 2007\\\")"

msgid "Person who created vector map"
msgstr "वह व्यक्ति जिसने वेक्टर मानचित्र बनाया"

msgid "Vector map title"
msgstr "वेक्टर मानचित्र शीर्षक"

msgid "Date when the source map was originally produced"
msgstr "वह दिनांक जब स्रोत मानचित्र मूल रूप से तैयार किया गया था"

msgid "Vector map scale number (e.g., 24000)"
msgstr "वेक्टर मानचित्र स्केल संख्या (जैसे, 24000)"

msgid "Vector map projection zone"
msgstr "वेक्टर मानचित्र प्रक्षेपण क्षेत्र"

msgid "Vector map digitizing threshold number (e.g., 0.5)"
msgstr "थ्रेसहोल्ड संख्या को डिजिटाइज़ करने वाला वेक्टर मानचित्र (उदाहरण के लिए, 0.5)"

msgid "Text to append to the comment line of the map's metadata file"
msgstr "मानचित्र की मेटाडेटा फ़ाइल की टिप्पणी पंक्ति में जोड़ने के लिए पाठ"

msgid "Command line to store into vector map history file (used for vector scripts)"
msgstr "वेक्टर मानचित्र इतिहास फ़ाइल में संग्रहीत करने के लिए कमांड लाइन (वेक्टर स्क्रिप्ट के लिए प्रयुक्त)"

msgid "Replace comment instead of appending it"
msgstr "टिप्पणी जोड़ने के बजाय उसे बदलें"

msgid "Replace command line instead of appending it"
msgstr "कमांड लाइन को जोड़ने के बजाय बदलें"

#, c-format
msgid "Unable to open history file for vector map <%s>"
msgstr "वेक्टर मानचित्र <%s> के लिए इतिहास फ़ाइल खोलने में असमर्थ"

#, c-format
msgid "%d are too many points. The cross validation would take too much time."
msgstr "%d बहुत अधिक बिंदु हैं। क्रॉस वैलिडेशन में बहुत अधिक समय लगेगा।"

#, c-format
msgid "%d points read in region"
msgstr "क्षेत्र में %d अंक पढ़े गए"

