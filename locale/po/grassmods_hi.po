msgid "Raster map <%s> is of type CELL_TYPE -- you should use r.terraflow.short"
msgstr "रेखापुंज मानचित्र <%s> CELL_TYPE प्रकार का है -- आपको r.terraflow.short का उपयोग करना चाहिए"

msgid "cannot read range"
msgstr "रेंज नहीं पढ़ सकता"

