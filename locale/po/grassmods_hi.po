msgstr "वेक्टर मानचित्र लिखना <%s>..।"

#, c-format
msgid "Stream id %d not set, top is %d, parent is %d"
msgstr "स्ट्रीम आईडी %d सेट नहीं है, शीर्ष %d है, मूल %d है"

