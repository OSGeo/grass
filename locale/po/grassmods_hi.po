msgstr "नमूना रेखापुंज शून्य मानों के लिए ऊँचाई"

#, c-format
msgid "Undefined height for feature %d. Skipping."
msgstr "सुविधा %d के लिए अपरिभाषित ऊँचाई। रस्सी कूदना।"

