#, c-format
msgid "Table <%s> not found in database <%s> using driver <%s>"
msgstr "तालिका <%s> ड्राइवर <%s> का उपयोग करके डेटाबेस <%s> में नहीं मिली"

#, c-format
msgid "Unable to start driver <%s>"
msgstr "ड्राइवर <%s> प्रारंभ करने में असमर्थ"

#, c-format
msgid "Unable to open database <%s>"
msgstr "डेटाबेस <%s> खोलने में असमर्थ"

#, c-format, python-format
msgid "Unable to describe table <%s>"
msgstr "तालिका <%s> का वर्णन करने में असमर्थ"

msgid "Failed to initialize JSON array. Out of memory?"
msgstr "JSON सारणी आरंभ करने में विफल. स्मृति से बाहर?"

msgid "Failed to serialize JSON to pretty format."
msgstr "JSON को सुंदर प्रारूप में क्रमबद्ध करने में विफल।"

msgid "Print type information about the columns"
msgstr "कॉलम के बारे में प्रकार की जानकारी प्रिंट करें"

msgid "Print the name and the type of all the columns for a given table."
msgstr "किसी दी गई तालिका के लिए सभी कॉलमों का नाम और प्रकार प्रिंट करें।"

msgid "Print"
msgstr "छाप"

msgid "Format"
msgstr "प्रारूप"

msgid "database"
msgstr "डेटाबेस"

msgid "attribute table"
msgstr "विशेषता तालिका"

msgid "List all columns for a given table."
msgstr "किसी दी गई तालिका के लिए सभी कॉलम सूचीबद्ध करें।"

msgid "Separator is part of the format."
msgstr "विभाजक प्रारूप का हिस्सा है।"

msgid "connection settings"
msgstr "कनेक्शन सेटिंग्स"

msgid "Prints/sets general DB connection for current mapset."
msgstr "वर्तमान मैपसेट के लिए सामान्य डीबी कनेक्शन प्रिंट/सेट करता है।"

msgid "Print current connection parameters and exit"
msgstr "वर्तमान कनेक्शन पैरामीटर प्रिंट करें और बाहर निकलें"

msgid "Print current connection parameters using shell style and exit [deprecated]"
msgstr "शेल शैली और निकास का उपयोग करके वर्तमान कनेक्शन पैरामीटर प्रिंट करें [बहिष्कृत]"

msgid "This flag is deprecated and will be removed in a future release. Use format=shell instead."
msgstr "यह ध्वज अप्रचलित है और भविष्य में रिलीज़ में हटा दिया जाएगा। इसके बजाय प्रारूप = शेल का प्रयोग करें।"

msgid "Check connection parameters, set if uninitialized, and exit"
msgstr "कनेक्शन पैरामीटर जांचें, यदि प्रारंभ न किया गया हो तो सेट करें और बाहर निकलें"

msgid "Set"
msgstr "तय करना"

msgid "Set from default settings and exit"
msgstr "डिफ़ॉल्ट सेटिंग्स से सेट करें और बाहर निकलें"

msgid "Overwrite current settings if already initialized"
msgstr "यदि पहले से ही आरंभ किया गया है तो वर्तमान सेटिंग्स को अधिलेखित करें"

msgid "Default group of database users to which select privilege is granted"
msgstr "डेटाबेस उपयोगकर्ताओं का डिफ़ॉल्ट समूह जिसे चयन विशेषाधिकार दिया गया है"

msgid "plain;Plain text output;shell;shell script style output;json;JSON (JavaScript Object Notation);"
msgstr "सादा; सादा पाठ आउटपुट; शेल; शेल स्क्रिप्ट शैली आउटपुट; json; JSON (जावास्क्रिप्ट ऑब्जेक्ट नोटेशन);"

msgid "Failed to initialize JSON object. Out of memory?"
msgstr "JSON ऑब्जेक्ट आरंभ करने में विफल. स्मृति से बाहर?"

msgid "Flag 'g' is deprecated and will be removed in a future release. Please use format=shell instead."
msgstr "ध्वज 'जी' को हटा दिया गया है और भविष्य में रिलीज में इसे हटा दिया जाएगा। कृपया इसके बजाय form=shell का उपयोग करें।"

msgid "The -g flag cannot be used with format=json. Please select only one output format."
msgstr "-g ध्वज का उपयोग form=json के साथ नहीं किया जा सकता। कृपया केवल एक आउटपुट स्वरूप चुनें।"

msgid "The -p flag is required when using the format option."
msgstr "प्रारूप विकल्प का उपयोग करते समय -p ध्वज की आवश्यकता होती है।"

msgid "Database connection not defined. Run db.connect."
msgstr "डेटाबेस कनेक्शन परिभाषित नहीं है. db.connect चलाएँ।"

#, c-format
msgid ""
"Default driver / database set to:\n"
"driver: %s\n"
"database: %s"
msgstr "डिफ़ॉल्ट ड्राइवर/डेटाबेस इस पर सेट है:\\nड्राइवर: %s\\nडेटाबेस: %s"

msgid "DB settings already defined, nothing to do"
msgstr "डीबी सेटिंग्स पहले से ही परिभाषित हैं, कुछ नहीं करना है"

msgid "Default driver is not set"
msgstr "डिफ़ॉल्ट ड्राइवर सेट नहीं है"

msgid "Default database is not set"
msgstr "डिफ़ॉल्ट डेटाबेस सेट नहीं है"

msgid "Unable to set default database connection"
msgstr "डिफ़ॉल्ट डेटाबेस कनेक्शन सेट करने में असमर्थ"

msgid "SQL"
msgstr "एसक्यूएल"

msgid "Copy a table."
msgstr "एक तालिका कॉपी करें।"

msgid "Either 'from_table' (optionally with 'where') can be used or 'select' option, but not 'from_table' and 'select' at the same time."
msgstr "या तो 'from_table' (वैकल्पिक रूप से 'कहाँ' के साथ) का उपयोग किया जा सकता है या 'select' विकल्प का उपयोग किया जा सकता है, लेकिन एक ही समय में 'from_table' और 'select' का नहीं।"

msgid "Input driver name"
msgstr "इनपुट ड्राइवर का नाम"

msgid "Input database name"
msgstr "इनपुट डेटाबेस नाम"

msgid "Input table name (only, if 'select' is not used)"
msgstr "इनपुट तालिका नाम (केवल, यदि 'चयन' का उपयोग नहीं किया गया है)"

msgid "Output driver name"
msgstr "आउटपुट ड्राइवर का नाम"

msgid "Output database name"
msgstr "आउटपुट डेटाबेस नाम"

msgid "Output table name"
msgstr "आउटपुट तालिका का नाम"

msgid "Full select statement (only, if 'from_table' and 'where' is not used)"
msgstr "पूर्ण चयन विवरण (केवल, यदि 'from_table' और 'where' का उपयोग नहीं किया गया है)"

msgid "E.g.: SELECT dedek FROM starobince WHERE obec = 'Frimburg'"
msgstr "उदाहरण के लिए: स्टारोबिन्स से डेडेक का चयन करें जहां ओबेक = 'फ़्रिम्बर्ग'"

msgid "Cannot combine 'from_table' and 'select' options"
msgstr "'from_table' और 'select' विकल्पों को संयोजित नहीं किया जा सकता"

msgid "Either 'from_table' or 'select' option must be given."
msgstr "या तो 'from_table' या 'select' विकल्प दिया जाना चाहिए।"

msgid "Cannot combine 'select' and 'where' options"
msgstr "'चयन करें' और 'कहाँ' विकल्पों को संयोजित नहीं किया जा सकता"

msgid "Copy table failed"
msgstr "प्रतिलिपि तालिका विफल रही"

msgid "Creates an empty database."
msgstr "एक खाली डेटाबेस बनाता है।"

msgid "Unable to list databases. Try to define correct connection settings by db.login."
msgstr "डेटाबेस सूचीबद्ध करने में असमर्थ. db.login द्वारा सही कनेक्शन सेटिंग्स को परिभाषित करने का प्रयास करें।"

msgid "No databases found"
msgstr "कोई डेटाबेस नहीं मिला"

msgid "Connection"
msgstr "संबंध"

msgid "Location"
msgstr "जगह"

msgid "Path for SQLite driver, or connection string for PostgreSQL driver"
msgstr "SQLite ड्राइवर के लिए पथ, या PostgreSQL ड्राइवर के लिए कनेक्शन स्ट्रिंग"

msgid "Lists all databases for a given driver and location."
msgstr "किसी दिए गए ड्राइवर और स्थान के लिए सभी डेटाबेस सूचीबद्ध करता है।"

msgid "Failed to initialize pretty JSON string."
msgstr "सुंदर JSON स्ट्रिंग प्रारंभ करने में विफल।"

msgid "Print column names only instead of full column descriptions"
msgstr "पूर्ण कॉलम विवरण के बजाय केवल कॉलम नाम प्रिंट करें"

msgid "json"
msgstr "json"

msgid "Describes a table in detail."
msgstr "एक तालिका का विस्तार से वर्णन करता है।"

msgid "Unable to read dbmscap file"
msgstr "dbmscap फ़ाइल को पढ़ने में असमर्थ"

msgid "Full output"
msgstr "पूर्ण आउटपुट"

msgid "Print drivers and exit"
msgstr "ड्राइवर प्रिंट करें और बाहर निकलें"

msgid "Lists all database drivers."
msgstr "सभी डेटाबेस ड्राइवरों को सूचीबद्ध करता है।"

msgid "Removes an existing database."
msgstr "किसी मौजूदा डेटाबेस को हटा देता है।"

#, c-format
msgid "Unable to open file <%s>: %s"
msgstr "फ़ाइल खोलने में असमर्थ <%s>: %s"

#, c-format
msgid "Error while executing: '%s'"
msgstr "निष्पादित करते समय त्रुटि: '%s'"

msgid "Executes any SQL statement."
msgstr "किसी भी SQL स्टेटमेंट को निष्पादित करता है।"

msgid "For SELECT statements use 'db.select'."
msgstr "SELECT स्टेटमेंट के लिए 'db.select' का उपयोग करें।"

msgid "SQL statement"
msgstr "एसक्यूएल कथन"

msgid "Example: update rybniky set kapri = 'hodne' where kapri = 'malo'"
msgstr "उदाहरण: रिब्निकी सेट को अपडेट करें कापरी = 'होडने' जहां कापरी = 'मालो'"

msgid "Name of file containing SQL statement(s)"
msgstr "SQL कथन वाली फ़ाइल का नाम"

msgid "'-' for standard input"
msgstr "मानक इनपुट के लिए '-'"

msgid "Ignore SQL errors and continue"
msgstr "SQL त्रुटियों पर ध्यान न दें और जारी रखें"

msgid "Errors"
msgstr "त्रुटियाँ"

#, c-format
msgid "You must provide <%s> or <%s> option"
msgstr "आपको <%s> या <%s> विकल्प प्रदान करना होगा"

msgid "Sets user/password for DB driver/database."
msgstr "डीबी ड्राइवर/डेटाबेस के लिए उपयोगकर्ता/पासवर्ड सेट करता है।"

msgid "Username"
msgstr "उपयोगकर्ता नाम"

msgid "Settings"
msgstr "सेटिंग्स"

msgid "Password"
msgstr "पासवर्ड"

msgid "Hostname"
msgstr "होस्ट का नाम"

msgid "Relevant only for pg and mysql driver"
msgstr "केवल पीजी और MySQL ड्राइवर के लिए प्रासंगिक"

msgid "Port"
msgstr "पत्तन"

msgid "Print connection settings and exit"
msgstr "कनेक्शन सेटिंग्स प्रिंट करें और बाहर निकलें"

msgid "Unable to set user/password"
msgstr "उपयोगकर्ता/पासवर्ड सेट करने में असमर्थ"

#, c-format
msgid "The password was stored in file (%s%cdblogin)"
msgstr "पासवर्ड फ़ाइल (%s%cdblogin) में संग्रहीत किया गया था"

#, c-format
msgid "The option %s is not allowed with %s=%s. %s"
msgstr "%s=%s के साथ विकल्प %s की अनुमति नहीं है। %s"

#, c-format
msgid "The flag -%c is not allowed with %s=%s. %s"
msgstr "%s=%s के साथ ध्वज -%c की अनुमति नहीं है। %s"

#, c-format
msgid "Unable to open file <%s> for writing"
msgstr "लिखने के लिए फ़ाइल <%s> खोलने में असमर्थ"

msgid "Test failed."
msgstr "परीक्षण विफल रहा।"

msgid "Test succeeded."
msgstr "परीक्षण सफल रहा।"

msgid "Query"
msgstr "सवाल"

msgid "Name of file containing SQL select statement(s)"
msgstr "SQL चयन कथन युक्त फ़ाइल का नाम"

msgid "Name of table to query"
msgstr "क्वेरी करने के लिए तालिका का नाम"

msgid "Vertical record separator (requires -v flag [deprecated] or format=vertical)"
msgstr "लंबवत रिकॉर्ड विभाजक (-v ध्वज की आवश्यकता है [पदावनत] या प्रारूप = लंबवत)"

msgid "Name for output file (if omitted or \"-\" output to stdout)"
msgstr "आउटपुट फ़ाइल के लिए नाम (यदि छोड़ा गया है या स्टडआउट करने के लिए \\\"-\\\" आउटपुट)"

msgid "Do not include column names in output"
msgstr "आउटपुट में कॉलम नाम शामिल न करें"

msgid "Describe query only (don't run it)"
msgstr "केवल क्वेरी का वर्णन करें (इसे न चलाएं)"

msgid "Vertical output instead of horizontal [deprecated]"
msgstr "क्षैतिज के बजाय लंबवत आउटपुट [बहिष्कृत]"

msgid "Use format=vertical instead."
msgstr "इसके बजाय प्रारूप=वर्टिकल का उपयोग करें।"

msgid "Only test query, do not execute"
msgstr "केवल क्वेरी का परीक्षण करें, निष्पादित न करें"

msgid "Selects data from attribute table."
msgstr "विशेषता तालिका से डेटा का चयन करता है।"

msgid "Performs SQL query statement(s)."
msgstr "SQL क्वेरी स्टेटमेंट निष्पादित करता है।"

#, c-format
msgid "You must provide one of these options: <%s>, <%s>, or <%s>"
msgstr "आपको इनमें से एक विकल्प प्रदान करना होगा: <%s>, <%s>, या <%s>"

msgid "Separator is part of the format"
msgstr "विभाजक प्रारूप का हिस्सा है"

msgid "Vertical separator is part of the format"
msgstr "लंबवत विभाजक प्रारूप का हिस्सा है"

msgid "Null value is part of the format"
msgstr "शून्य मान प्रारूप का हिस्सा है"

msgid "Column names are always included"
msgstr "कॉलम नाम हमेशा शामिल किए जाते हैं"

msgid "Flag 'v' is deprecated and will be removed in a future release. Please use format=vertical instead."
msgstr "ध्वज 'v' को हटा दिया गया है और भविष्य में रिलीज़ में हटा दिया जाएगा। कृपया इसके बजाय प्रारूप=वर्टिकल का उपयोग करें।"

msgid "Flag 'v' is only allowed with format=vertical."
msgstr "ध्वज 'v' की अनुमति केवल प्रारूप=वर्टिकल के साथ है।"

#, c-format
msgid "Unable to list tables from database <%s>"
msgstr "डेटाबेस <%s> से तालिकाओं को सूचीबद्ध करने में असमर्थ"

msgid "No tables found"
msgstr "कोई टेबल नहीं मिली"

msgid "Print tables and exit"
msgstr "टेबल प्रिंट करें और बाहर निकलें"

msgid "System tables instead of user tables"
msgstr "उपयोगकर्ता तालिकाओं के बजाय सिस्टम तालिकाएँ"

msgid "Lists all tables for a given database."
msgstr "किसी दिए गए डेटाबेस के लिए सभी तालिकाओं को सूचीबद्ध करता है।"

#, c-format
msgid "Column '%s' already exists (duplicate name)"
msgstr "कॉलम '%s' पहले से मौजूद है (डुप्लिकेट नाम)"

#, c-format
msgid "Column '%s' does not exist"
msgstr "कॉलम '%s' मौजूद नहीं है"

msgid "Unable to create table"
msgstr "तालिका बनाने में असमर्थ"

msgid "Unable to allocate new cursor"
msgstr "नया कर्सर आवंटित करने में असमर्थ"

msgid "Unable to tokenize new cursor"
msgstr "नये कर्सर को टोकनाइज़ करने में असमर्थ"

#, c-format
msgid "Unable to create DBF database: %s"
msgstr "DBF डेटाबेस बनाने में असमर्थ: %s"

#, c-format
msgid "Cannot open DBF database directory: %s"
msgstr "DBF डेटाबेस निर्देशिका नहीं खोल सकता: %s"

#, c-format
msgid "Unable to open DBF database: %s"
msgstr "DBF डेटाबेस खोलने में असमर्थ: %s"

msgid "SQL parser error"
msgstr "एसक्यूएल पार्सर त्रुटि"

msgid "in statement:"
msgstr "कथन में:"

#, c-format
msgid "Table '%s' doesn't exist."
msgstr "तालिका '%s' मौजूद नहीं है।"

msgid "Unable to load table head."
msgstr "टेबल हेड लोड करने में असमर्थ।"

msgid "Unable to modify table, don't have write permission for DBF file."
msgstr "तालिका को संशोधित करने में असमर्थ, DBF फ़ाइल के लिए लिखने की अनुमति नहीं है।"

#, c-format
msgid "Column '%s' not found"
msgstr "कॉलम '%s' नहीं मिला"

msgid "Incompatible value type."
msgstr "असंगत मान प्रकार।"

msgid "Unable to add column."
msgstr "कॉलम जोड़ने में असमर्थ।"

msgid "Unable to delete column."
