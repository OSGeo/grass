msgstr "ज्ञात कार्य:"

msgid "Raster map calculator."
msgstr "रेखापुंज मानचित्र कैलकुलेटर।"

msgid "Expression to evaluate"
msgstr "मूल्यांकन हेतु अभिव्यक्ति"

msgid "Expression"
msgstr "अभिव्यक्ति"

msgid "The computational region that should be used."
msgstr "वह कम्प्यूटेशनल क्षेत्र जिसका उपयोग किया जाना चाहिए।"

msgid "current uses the current region of the mapset"
msgstr "current मैपसेट के वर्तमान क्षेत्र का उपयोग करता है"

msgid "intersect computes the intersection region between all input maps and uses the smallest resolution"
msgstr "इंटरसेक्ट सभी इनपुट मानचित्रों के बीच प्रतिच्छेदन क्षेत्र की गणना करता है और सबसे छोटे रिज़ॉल्यूशन का उपयोग करता है"

msgid "union computes the union extent of all map regions and uses the smallest resolution"
msgstr "यूनियन सभी मानचित्र क्षेत्रों की यूनियन सीमा की गणना करता है और सबसे छोटे रिज़ॉल्यूशन का उपयोग करता है"

msgid "File containing expression(s) to evaluate"
msgstr "मूल्यांकन करने के लिए अभिव्यक्ति युक्त फ़ाइल"

msgid "Generate random seed (result is non-deterministic) [deprecated]"
msgstr "यादृच्छिक बीज उत्पन्न करें (परिणाम गैर-नियतात्मक है) [बहिष्कृत]"

msgid "This flag is deprecated and will be removed in a future release. Seeding is automatic or use parameter seed."
msgstr "यह ध्वज अप्रचलित है और भविष्य में रिलीज़ में हटा दिया जाएगा। सीडिंग स्वचालित है या पैरामीटर बीज का उपयोग करें।"

msgid "List input and output maps"
msgstr "इनपुट और आउटपुट मानचित्रों की सूची बनाएं"

#, c-format
msgid "%s= and -%c are mutually exclusive"
msgstr "%s= और -%c परस्पर अनन्य हैं"

msgid "parse error"
msgstr "पार्स त्रुटि"

msgid "Flag 's' is deprecated and will be removed in a future release. Seeding is automatic or use parameter seed."
msgstr "ध्वज 's' को हटा दिया गया है और भविष्य में रिलीज़ में हटा दिया जाएगा। सीडिंग स्वचालित है या पैरामीटर बीज का उपयोग करें।"

msgid "r3.mapcalc does not support parallel execution."
msgstr "r3.mapcalc समानांतर निष्पादन का समर्थन नहीं करता है।"

msgid "Parallel execution is not supported with rand() function"
msgstr "रैंड() फ़ंक्शन के साथ समानांतर निष्पादन समर्थित नहीं है"

#, c-format
msgid "<%d> is not valid number of nprocs."
msgstr "<%d> nprocs की वैध संख्या नहीं है।"

msgid "Floating point error(s) occurred in the calculation"
msgstr "गणना में फ़्लोटिंग पॉइंट त्रुटियाँ हुईं"

#, c-format
msgid "Unable to read color file for raster map <%s@%s>"
msgstr "रेखापुंज मानचित्र <%s@%s> के लिए रंग फ़ाइल पढ़ने में असमर्थ"

#, c-format
msgid "Unable to create btree for raster map <%s@%s>"
msgstr "रेखापुंज मानचित्र के लिए btree बनाने में असमर्थ <%s@%s>"

msgid "Error writing data"
msgstr "डेटा लिखने में त्रुटि"

#, c-format
msgid "Unable to close raster map <%s@%s>"
msgstr "रेखापुंज मानचित्र बंद करने में असमर्थ <%s@%s>"

msgid "Unable to close output raster map"
msgstr "आउटपुट रैस्टर मैप बंद करने में असमर्थ"

msgid "reclassification"
msgstr "पुनर्वर्गीकरण"

msgid "Reports presence or absence of a raster mask"
msgstr "रैस्टर मास्क की उपस्थिति या अनुपस्थिति की रिपोर्ट करता है"

msgid "Provides information about the presence of a 2D raster mask as text output or return code"
msgstr "टेक्स्ट आउटपुट या रिटर्न कोड के रूप में 2डी रैस्टर मास्क की उपस्थिति के बारे में जानकारी प्रदान करता है"

msgid "Format for reporting"
msgstr "रिपोर्टिंग के लिए प्रारूप"

msgid "Return code 0 when mask present, 1 otherwise"
msgstr "मास्क मौजूद होने पर कोड 0 लौटाएँ, अन्यथा 1"

#, c-format
msgid "Mask is active"
msgstr "मुखौटा सक्रिय है"

#, c-format
msgid "Mask name: %s"
msgstr "मास्क का नाम: %s"

#, c-format
msgid "Mask is not present"
msgstr "मास्क मौजूद नहीं है"

#, c-format
msgid "If activated, mask name will be: %s"
msgstr "सक्रिय होने पर, मास्क का नाम होगा: %s"

#, c-format
msgid "Mask is a raster reclassified from: %s"
msgstr "मास्क एक रेखापुंज है जिसे पुनर्वर्गीकृत किया गया है: %s"

#, c-format
msgid "Cannot open filter file '%s'"
msgstr "फ़िल्टर फ़ाइल '%s' नहीं खोल सकता"

msgid "Illegal filter matrix size specified"
msgstr "अवैध फ़िल्टर मैट्रिक्स आकार निर्दिष्ट"

msgid "Even filter matrix size specified"
msgstr "यहां तक कि फ़िल्टर मैट्रिक्स आकार भी निर्दिष्ट है"

msgid "Illegal filter matrix"
msgstr "अवैध फ़िल्टर मैट्रिक्स"

msgid "Filter file format error"
msgstr "फ़िल्टर फ़ाइल स्वरूप त्रुटि"

msgid "Duplicate filter divisor specified"
msgstr "डुप्लिकेट फ़िल्टर विभाजक निर्दिष्ट"

msgid "Illegal divisor matrix"
msgstr "अवैध भाजक मैट्रिक्स"

msgid "Duplicate filter type specified"
msgstr "डुप्लिकेट फ़िल्टर प्रकार निर्दिष्ट"

msgid "Illegal filter type specified"
msgstr "अवैध फ़िल्टर प्रकार निर्दिष्ट"

msgid "Duplicate filter start specified"
msgstr "डुप्लिकेट फ़िल्टर प्रारंभ निर्दिष्ट"

#, c-format
msgid "Filter start %s ignored, using UL"
msgstr "UL का उपयोग करते हुए फ़िल्टर प्रारंभ %s को अनदेखा कर दिया गया"

msgid "Illegal filter file format"
msgstr "अवैध फ़िल्टर फ़ाइल स्वरूप"

msgid "Error reading temporary file"
msgstr "अस्थायी फ़ाइल पढ़ने में त्रुटि"

msgid "filter"
msgstr "फ़िल्टर"

msgid "Performs raster map matrix filter."
msgstr "रैस्टर मैप मैट्रिक्स फ़िल्टर निष्पादित करता है।"

msgid "Path to filter file"
msgstr "फ़ाइल को फ़िल्टर करने का पथ"

msgid "Number of times to repeat the filter"
msgstr "फ़िल्टर को दोहराने की संख्या"

msgid "Output raster map title"
msgstr "आउटपुट रेखापुंज मानचित्र शीर्षक"

msgid "Apply filter only to null data values"
msgstr "केवल शून्य डेटा मानों पर फ़िल्टर लागू करें"

msgid "Raster map too small for the size of the filter"
msgstr "फ़िल्टर के आकार के लिए रेखापुंज मानचित्र बहुत छोटा है"

msgid "Unable to create temporary file"
msgstr "अस्थायी फ़ाइल बनाने में असमर्थ"

#, c-format
msgid "Writing raster map <%s>"
msgstr "रेखापुंज मानचित्र लिखना <%s>"

msgid "Finds the mode of values in a cover map within areas assigned the same category value in a user-specified base map."
msgstr "उपयोगकर्ता द्वारा निर्दिष्ट बेस मैप में समान श्रेणी मान निर्दिष्ट क्षेत्रों के भीतर कवर मैप में मानों का मोड ढूँढता है।"

msgid "Base map to be reclassified"
msgstr "आधार मानचित्र को पुनः वर्गीकृत किया जाएगा"

msgid "Coverage map"
msgstr "कवरेज मानचित्र"

msgid "Output map"
msgstr "आउटपुट मानचित्र"

#, c-format
msgid "%s: Unable to read category labels"
msgstr "%s: श्रेणी लेबल पढ़ने में असमर्थ"

#, c-format
msgid "Unable to read color table for %s"
msgstr "%s के लिए रंग तालिका पढ़ने में असमर्थ"

msgid "reading r.stats output"
msgstr "r.stats आउटपुट पढ़ना"

#, c-format
msgid "Unknown method <%s>"
msgstr "अज्ञात विधि <%s>"

#, c-format
msgid "Invalid out_type enumeration: %d"
msgstr "अमान्य आउट_टाइप गणना: %d"

msgid "neighbor"
msgstr "पड़ोसी"

msgid "focal statistics"
msgstr "फोकल आँकड़े"

msgid "Makes each cell category value a function of the category values assigned to the cells around it, and stores new cell values in an output raster map layer."
msgstr "प्रत्येक सेल श्रेणी मान को उसके आस-पास की कोशिकाओं को निर्दिष्ट श्रेणी मानों का एक फ़ंक्शन बनाता है, और नए सेल मानों को आउटपुट रैस्टर मैप परत में संग्रहीत करता है।"

msgid "Neighborhood operation"
msgstr "पड़ोस का ऑपरेशन"

msgid "Gaussian weighting function"
msgstr "गॉसियन वेटिंग फ़ंक्शन"

msgid "No weighting"
msgstr "कोई भार नहीं"

msgid "Exponential weighting function"
msgstr "घातांकीय भार फ़ंक्शन"

msgid "File with a custom weighting matrix"
msgstr "कस्टम वेटिंग मैट्रिक्स के साथ फ़ाइल करें"

msgid "Factor used in the selected weighting function (ignored for none and file)"
msgstr "चयनित वेटिंग फ़ंक्शन में प्रयुक्त कारक (किसी के लिए भी और फ़ाइल पर ध्यान नहीं दिया गया)"

msgid "Do not align output with the input"
msgstr "आउटपुट को इनपुट के साथ संरेखित न करें"

msgid "Neighborhood size must be positive"
msgstr "पड़ोस का आकार सकारात्मक होना चाहिए"

msgid "Neighborhood size must be odd"
msgstr "पड़ोस का आकार विषम होना चाहिए"

msgid "File with weighting matrix is missing."
msgstr "वेटिंग मैट्रिक्स वाली फ़ाइल गायब है।"

#, c-format
msgid "Weighting function '%s' requires a %s."
msgstr "वेटिंग फ़ंक्शन '%s' के लिए %s की आवश्यकता होती है।"

#, c-format
msgid "%s= and %s= must have the same number of values"
msgstr "%s= और %s= में मानों की संख्या समान होनी चाहिए"

#, c-format
msgid "Computing %s weights..."
msgstr "%s वज़न की गणना..।"

#, c-format
msgid "Method %s not compatible with weighing window, using weight mask instead"
msgstr "विधि %s वज़न विंडो के साथ संगत नहीं है, इसके स्थान पर वेट मास्क का उपयोग किया जा रहा है"

#, c-format
msgid "Opening selection map <%s>"
msgstr "चयन मानचित्र खुल रहा है <%s>"

#, c-format
msgid "Unable to open weights file %s"
msgstr "वज़न फ़ाइल %s खोलने में असमर्थ"

#, c-format
msgid "Error reading weights file %s"
msgstr "वजन फ़ाइल पढ़ने में त्रुटि %s"

msgid "Manages NULL-values of given raster map."
msgstr "दिए गए रेखापुंज मानचित्र के शून्य-मान प्रबंधित करता है।"

msgid "Name of raster map for which to edit null values"
msgstr "रेखापुंज मानचित्र का नाम जिसके लिए शून्य मान संपादित करना है"

msgid "List of cell values to be set to NULL"
msgstr "NULL पर सेट किए जाने वाले सेल मानों की सूची"

msgid "The value to replace the null value by"
msgstr "शून्य मान को प्रतिस्थापित करने वाला मान"

msgid "Only do the work if the map is floating-point"
msgstr "यदि मानचित्र फ़्लोटिंग-पॉइंट है तो ही कार्य करें"

msgid "Check"
msgstr "जाँच करना"

msgid "Only do the work if the map is integer"
msgstr "यदि मानचित्र पूर्णांक है तो ही कार्य करें"

msgid "Only do the work if the map doesn't have a NULL-value bitmap file"
msgstr "कार्य केवल तभी करें जब मानचित्र में शून्य-मान बिटमैप फ़ाइल न हो"

msgid "Create NULL-value bitmap file validating all data cells"
msgstr "सभी डेटा सेल को मान्य करते हुए शून्य-मूल्य बिटमैप फ़ाइल बनाएं"

msgid "Remove NULL-value bitmap file"
msgstr "शून्य-मान बिटमैप फ़ाइल हटाएँ"

msgid "Re-create NULL-value bitmap file (to compress or uncompress)"
msgstr "शून्य-मान बिटमैप फ़ाइल को पुनः बनाएँ (संपीड़ित या असंपीड़ित करने के लिए)"

#, c-format
msgid "Raster map <%s> is a reclass of map <%s@%s>. Consider to generate a copy with r.mapcalc. Exiting."
msgstr "रेखापुंज मानचित्र <%s> मानचित्र <%s@%s> का पुनर्वर्ग है। r.mapcalc के साथ एक प्रतिलिपि बनाने पर विचार करें। बाहर निकलना।"

#, c-format
msgid "<%s> is a virtual raster map. Consider to generate a copy with r.mapcalc. Exiting."
msgstr "<%s> एक आभासी रेखापुंज मानचित्र है। r.mapcalc के साथ एक प्रतिलिपि बनाने पर विचार करें। बाहर निकलना।"

#, c-format
msgid "Raster map <%s> is not in your mapset <%s>"
msgstr "रैस्टर मानचित्र <%s> आपके मैपसेट <%s> में नहीं है"

#, c-format
msgid "%s is illegal entry for null"
msgstr "%s शून्य के लिए अवैध प्रविष्टि है"

#, c-format
msgid "Raster map <%s> already has a null bitmap file"
msgstr "रैस्टर मानचित्र <%s> में पहले से ही एक शून्य बिटमैप फ़ाइल है"

