msgstr "फ़ील्ड विभाजक (प्रारूप: इनपुट[,आउटपुट])"

msgid "Input projection parameters (PROJ.4 style)"
msgstr "इनपुट प्रक्षेपण पैरामीटर (PROJ.4 शैली)"

msgid "Projections"
msgstr "अनुमान"

msgid "Output projection parameters (PROJ.4 style)"
msgstr "आउटपुट प्रक्षेपण पैरामीटर (PROJ.4 शैली)"

msgid "Use LL WGS84 as input and current location as output projection"
msgstr "इनपुट के रूप में LL WGS84 और आउटपुट प्रक्षेपण के रूप में वर्तमान स्थान का उपयोग करें"

msgid "Use current location as input and LL WGS84 as output projection"
msgstr "इनपुट के रूप में वर्तमान स्थान और आउटपुट प्रक्षेपण के रूप में LL WGS84 का उपयोग करें"

msgid "Output long/lat in decimal degrees, or other projections with many decimal places"
msgstr "दशमलव डिग्री में लंबा/अक्षांश आउटपुट, या कई दशमलव स्थानों के साथ अन्य अनुमान"

msgid "Include input coordinates in output file"
msgstr "आउटपुट फ़ाइल में इनपुट निर्देशांक शामिल करें"

