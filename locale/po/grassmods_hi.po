msgstr "अवैध पैरामीटर पारित किए गए हैं"

msgid "File could not be re-opened"
msgstr "फ़ाइल दोबारा नहीं खोली जा सकी"

msgid "Prepared file could not be read"
msgstr "तैयार फ़ाइल पढ़ी नहीं जा सकी"

msgid "Unable to write segment file"
msgstr "खंड फ़ाइल लिखने में असमर्थ"

msgid "Unable to read segment file"
msgstr "खंड फ़ाइल को पढ़ने में असमर्थ"

