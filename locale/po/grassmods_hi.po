msgid "Area without category: %G (%d areas)\n"
msgstr "श्रेणी रहित क्षेत्र: %G (%d क्षेत्र)\\n\n"

#, c-format
msgid "Area without category: %G (%d areas)"
msgstr "श्रेणी रहित क्षेत्र: %G (%d क्षेत्र)"

