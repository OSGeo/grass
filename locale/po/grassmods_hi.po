msgstr "वेक्टर मानचित्र में चयनित सुविधाओं को स्थानांतरित करें"

msgid "Move vertex of selected vector lines"
msgstr "चयनित वेक्टर रेखाओं के शीर्ष को स्थानांतरित करें"

msgid "Remove vertex from selected vector lines"
msgstr "चयनित वेक्टर रेखाओं से शीर्ष हटाएँ"

msgid "Add new vertex to selected vector lines"
msgstr "चयनित वेक्टर रेखाओं में नया शीर्ष जोड़ें"

msgid "Break/split vector lines"
msgstr "वेक्टर रेखाओं को तोड़ें/विभाजित करें"

msgid "Merge selected vector lines"
msgstr "चयनित वेक्टर रेखाओं को मर्ज करें"

msgid "Select lines and print their ID's"
msgstr "पंक्तियाँ चुनें और उनकी आईडी प्रिंट करें"

msgid "Set new categories to selected vector features for defined layer"
msgstr "परिभाषित परत के लिए चयनित वेक्टर सुविधाओं के लिए नई श्रेणियां सेट करें"

msgid "Delete categories from selected vector features for defined layer"
msgstr "परिभाषित परत के लिए चयनित वेक्टर सुविधाओं से श्रेणियां हटाएं"

msgid "Copy selected features"
msgstr "चयनित सुविधाओं की प्रतिलिपि बनाएँ"

msgid "Snap vector features in given threshold"
msgstr "दी गई सीमा में स्नैप वेक्टर सुविधाएँ"

msgid "Flip direction of selected vector lines"
msgstr "चयनित वेक्टर रेखाओं की फ़्लिप दिशा"

msgid "Connect two lines"
msgstr "दो लाइनें कनेक्ट करें"

msgid "Extend lines"
msgstr "पंक्तियाँ बढ़ाएँ"

msgid "Extend end nodes"
msgstr "अंत नोड्स बढ़ाएँ"

msgid "Extend start nodes"
msgstr "प्रारंभ नोड्स बढ़ाएँ"

msgid "Z bulk-labeling (automated assignment of z coordinate to vector lines)"
msgstr "Z बल्क-लेबलिंग (वेक्टर रेखाओं के लिए z निर्देशांक का स्वचालित असाइनमेंट)"

msgid "Change feature type (point<->centroid, line<->boundary)"
msgstr "सुविधा प्रकार बदलें (बिंदु<->केन्द्रक, रेखा<->सीमा)"

msgid "Delete selected areas from vector map (based on selected centroids)"
msgstr "वेक्टर मानचित्र से चयनित क्षेत्रों को हटाएं (चयनित केन्द्रक के आधार पर)"

msgid "Name of file containing data in GRASS ASCII vector format"
msgstr "GRASS ASCII वेक्टर प्रारूप में डेटा वाली फ़ाइल का नाम"

msgid "Difference in x,y,z direction for moving feature or vertex"
msgstr "चलती सुविधा या शीर्ष के लिए x,y,z दिशा में अंतर"

msgid "Threshold distance (coords,snap,query)"
msgstr "दहलीज दूरी (कोर्डर्स, स्नैप, क्वेरी)"

msgid "'-1' for threshold based on the current resolution settings"
msgstr "वर्तमान रिज़ॉल्यूशन सेटिंग्स के आधार पर सीमा के लिए '-1'"

msgid "List of point coordinates"
msgstr "बिंदु निर्देशांक की सूची"

msgid "Bounding box for selecting features"
msgstr "सुविधाओं के चयन के लिए बाउंडिंग बॉक्स"

msgid "Polygon for selecting features"
msgstr "सुविधाओं के चयन के लिए बहुभुज"

msgid "Query tool"
msgstr "क्वेरी उपकरण"

msgid "For 'shorter' use negative threshold value, positive value for 'longer'"
msgstr "'छोटे' के लिए नकारात्मक सीमा मान का उपयोग करें, 'लंबे' के लिए सकारात्मक मान का उपयोग करें"

msgid "Select only lines or boundaries shorter/longer than threshold distance"
msgstr "केवल सीमा दूरी से छोटी/लंबी रेखाओं या सीमाओं का चयन करें"

msgid "Select dangles shorter/longer than threshold distance"
msgstr "दहलीज दूरी से छोटे/लंबे लटकनों का चयन करें"

