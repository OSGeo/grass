msgid "Name for output topographic convergence index (tci) raster map"
msgstr "आउटपुट स्थलाकृतिक अभिसरण सूचकांक (टीसीआई) रेखापुंज मानचित्र का नाम"

msgid "SFD (D8) flow (default is MFD)"
msgstr "SFD (D8) प्रवाह (डिफ़ॉल्ट MFD है)"

msgid "SFD: single flow direction, MFD: multiple flow direction"
msgstr "एसएफडी: एकल प्रवाह दिशा, एमएफडी: एकाधिक प्रवाह दिशा"

