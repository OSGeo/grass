msgstr "प्रत्येक कोण के लिए अलग आउटपुट (0, 45, 90, 135)"

msgid "Angles are counterclockwise from east: 0 is East to West, 45 is North-East to South-West"
msgstr "कोण पूर्व से वामावर्त हैं: 0 पूर्व से पश्चिम है, 45 उत्तर-पूर्व से दक्षिण-पश्चिम है"

msgid "Calculate all textural measurements"
msgstr "सभी बनावटी मापों की गणना करें"

msgid "Allow NULL cells in a moving window"
msgstr "चलती हुई विंडो में NULL सेल की अनुमति दें"

msgid "This will also avoid cropping along edges of the current region"
msgstr "इससे वर्तमान क्षेत्र के किनारों पर फसल काटने से भी बचा जा सकेगा"

msgid "Size of the moving window must be > 0"
msgstr "चलती हुई विंडो का आकार > 0 होना चाहिए"

msgid "Size of the moving window must be odd"
msgstr "चलती हुई खिड़की का आकार विषम होना चाहिए"

msgid "The distance between two samples must be > 0"
msgstr "दो नमूनों के बीच की दूरी > 0 होनी चाहिए"

msgid "The distance between two samples must be smaller than the size of the moving window"
msgstr "दो नमूनों के बीच की दूरी चलती खिड़की के आकार से छोटी होनी चाहिए"

msgid "Nothing to compute. Use at least one textural measure."
msgstr "गणना करने के लिए कुछ भी नहीं. कम से कम एक बनावटी माप का उपयोग करें।"

msgid "At least one of the requested output maps exists. Use --o to overwrite."
msgstr "अनुरोधित आउटपुट मानचित्रों में से कम से कम एक मौजूद है। अधिलेखित करने के लिए --o का प्रयोग करें।"

#, c-format
msgid "Too many categories (found: %i, max: %i). Try to rescale or reclassify the map"
msgstr "बहुत सारी श्रेणियाँ (मिलीं: %i, अधिकतम: %i)। मानचित्र को पुनः स्केल या पुनः वर्गीकृत करने का प्रयास करें"

msgid "Input raster must be of type CELL."
msgstr "इनपुट रैस्टर सेल प्रकार का होना चाहिए।"

