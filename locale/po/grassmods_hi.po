msgstr "टाइल्स की चौड़ाई (कॉलम)"

msgid "Height of tiles (rows)"
msgstr "टाइल्स की ऊँचाई (पंक्तियाँ)"

msgid "Overlap of tiles"
msgstr "टाइल्स का ओवरलैप"

#, c-format
