msgid "This scale does not change the values itself but only how precisely they are stored, for example 0.01 will preserve two decimal places"
msgstr "यह पैमाना स्वयं मानों को नहीं बदलता है, बल्कि केवल यह बदलता है कि वे कितनी सटीकता से संग्रहीत हैं, उदाहरण के लिए 0.01 दो दशमलव स्थानों को संरक्षित करेगा"

msgid "Internal scale to apply to z values"
msgstr "z मानों पर लागू करने के लिए आंतरिक पैमाना"

msgid "Limit export to the current region"
msgstr "निर्यात को वर्तमान क्षेत्र तक सीमित करें"

msgid "Ignore color table"
msgstr "रंग तालिका पर ध्यान न दें"

msgid "Ignore color table even when set and not other options are present"
msgstr "सेट होने पर भी रंग तालिका पर ध्यान न दें और अन्य विकल्प मौजूद न हों"

msgid "Name of input vector map to export"
msgstr "निर्यात करने के लिए इनपुट वेक्टर मानचित्र का नाम"

msgid "Feature type(s)"
msgstr "फ़ीचर प्रकार"

msgid "Combination of types is not supported by all output formats. Default is to use first type found in input vector map."
msgstr "प्रकारों का संयोजन सभी आउटपुट स्वरूपों द्वारा समर्थित नहीं है। डिफ़ॉल्ट इनपुट वेक्टर मानचित्र में पाए गए पहले प्रकार का उपयोग करना है।"

msgid "Name of output OGR datasource"
msgstr "आउटपुट ओजीआर डेटास्रोत का नाम"

msgid ""
"For example: ESRI Shapefile: filename or directory for storage\n"
"\t\t\tPostGIS database: connection string"
msgstr "For example: ESRI Shapefile: filename or directory for storage\\n\\t\\t\\tPostGIS database: connection string"

msgid "Data format to write"
msgstr "लिखने के लिए डेटा प्रारूप"

msgid "Name for output OGR layer. If not specified, input name is used"
msgstr "आउटपुट ओजीआर परत का नाम। यदि निर्दिष्ट नहीं है, तो इनपुट नाम का उपयोग किया जाता है"

msgid ""
"For example: ESRI Shapefile: shapefile name\n"
"\t\t\tPostGIS database: table name"
msgstr "उदाहरण के लिए: ईएसआरआई शेपफाइल: शेपफाइल नाम\\n\\t\\t\\tपोस्टजीआईएस डेटाबेस: टेबल नाम"

msgid "Optionally change default output type"
msgstr "वैकल्पिक रूप से डिफ़ॉल्ट आउटपुट प्रकार बदलें"

msgid "export area boundaries as linestrings"
msgstr "लिनेस्ट्रिंग्स के रूप में निर्यात क्षेत्र की सीमाएं"

msgid "export lines as polygons"
msgstr "बहुभुज के रूप में निर्यात लाइनें"

msgid "OGR dataset creation option (format specific, NAME=VALUE)"
msgstr "OGR डेटासेट निर्माण विकल्प (प्रारूप विशिष्ट, NAME=VALUE)"

msgid "OGR layer creation option (format specific, NAME=VALUE)"
msgstr "OGR परत निर्माण विकल्प (प्रारूप विशिष्ट, NAME=VALUE)"

msgid "Method to use for export, default is fast export, use slow export in case of problems with the fast method"
msgstr "निर्यात के लिए उपयोग करने की विधि, डिफ़ॉल्ट तेज़ निर्यात है, तेज़ विधि के साथ समस्याओं के मामले में धीमी निर्यात का उपयोग करें"

msgid "new, faster method"
msgstr "नई, तेज़ विधि"

msgid "old, slower method"
msgstr "पुरानी, धीमी विधि"

msgid "Open an existing OGR datasource for update"
msgstr "अद्यतन के लिए मौजूदा OGR डेटास्रोत खोलें"

msgid "Append to existing layer"
msgstr "मौजूदा परत में जोड़ें"

msgid "A new OGR layer is created if it does not exist"
msgstr "यदि यह मौजूद नहीं है तो एक नई OGR परत बनाई जाती है"

msgid "Skip export of GRASS category ID ('cat') attribute"
msgstr "GRASS श्रेणी आईडी ('बिल्ली') विशेषता का निर्यात छोड़ें"

msgid "Also export features without category (not labeled). Otherwise only features with category are exported."
msgstr "बिना श्रेणी (लेबल नहीं) के भी सुविधाएँ निर्यात करें। अन्यथा केवल श्रेणी वाली सुविधाएँ ही निर्यात की जाती हैं।"

msgid "Use ESRI-style .prj file format (applies to Shapefile output only)"
msgstr "ESRI-शैली .prj फ़ाइल स्वरूप का उपयोग करें (केवल शेपफ़ाइल आउटपुट पर लागू होता है)"

msgid "Force 2D output even if input is 3D (applies to Shapefile output only)"
msgstr "इनपुट 3डी होने पर भी 2डी आउटपुट को बाध्य करें (केवल शेपफाइल आउटपुट पर लागू होता है)"

msgid "Export vector data as multi-features"
msgstr "वेक्टर डेटा को बहु-सुविधाओं के रूप में निर्यात करें"

msgid "Create a new empty layer in defined OGR datasource and exit. Nothing is read from input."
msgstr "परिभाषित ओजीआर डेटास्रोत में एक नई खाली परत बनाएं और बाहर निकलें। इनपुट से कुछ भी नहीं पढ़ा जाता है।"

msgid "List supported output formats and exit"
msgstr "समर्थित आउटपुट स्वरूपों की सूची बनाएं और बाहर निकलें"

#, c-format
msgid "Cannot select attributes for cat = %d"
msgstr "बिल्ली के लिए विशेषताओं का चयन नहीं किया जा सकता = %d"

#, c-format
msgid "No database record for cat = %d and export of 'cat' disabled"
msgstr "cat = %d के लिए कोई डेटाबेस रिकॉर्ड नहीं है और 'cat' का निर्यात अक्षम है"

#, c-format
msgid "OGR driver <%s> not available"
msgstr "OGR ड्राइवर <%s> उपलब्ध नहीं है"

#, c-format
msgid "Creation of output OGR datasource <%s> failed"
msgstr "आउटपुट OGR डेटास्रोत <%s> का निर्माण विफल रहा"

#, c-format
msgid "Creation of OGR layer <%s> failed"
msgstr "OGR परत <%s> का निर्माण विफल रहा"

msgid "Failed to create OGR feature"
msgstr "OGR सुविधा बनाने में विफल"

#, c-format
msgid "Unable to export multi-features. No category index for layer %d."
msgstr "बहु-सुविधाएँ निर्यात करने में असमर्थ. परत %d के लिए कोई श्रेणी सूचकांक नहीं।"

