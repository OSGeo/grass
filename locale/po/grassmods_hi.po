msgstr "इनपुट रैस्टर सेल प्रकार का होना चाहिए"

#, c-format
msgid "Empty input map <%s>"
msgstr "खाली इनपुट मानचित्र <%s>"

msgid "Calculating statistics"
msgstr "आँकड़ों की गणना"

msgid "Writing output"
msgstr "लेखन आउटपुट"

msgid "Converts a raster map layer into a GRASS ASCII text file."
msgstr "रैस्टर मैप परत को GRASS ASCII टेक्स्ट फ़ाइल में परिवर्तित करता है।"

msgid "Name for output ASCII grid map (use out=- for stdout)"
msgstr "आउटपुट ASCII ग्रिड मैप के लिए नाम (stdout के लिए out=- का उपयोग करें)"

