msgstr "क्षेत्र में %lu अंक मिले।"

msgid "history"
msgstr "इतिहास"

msgid "Outputs basic information about a raster map."
msgstr "रास्टर मानचित्र के बारे में बुनियादी जानकारी आउटपुट करता है।"

msgid "Print raster array information"
msgstr "रेखापुंज सरणी जानकारी प्रिंट करें"

msgid "Print range"
msgstr "प्रिंट रेंज"

msgid "Print stats"
msgstr "आँकड़े प्रिंट करें"

msgid "Print raster history instead of info"
msgstr "जानकारी के बजाय रेखापुंज इतिहास प्रिंट करें"

msgid "The output format for flags -g, -r, -s, and -e currently defaults to 'shell', but this will change to 'plain' in a future release. To avoid unexpected behaviour, specify the format explicitly."
msgstr "झंडे -जी, -आर, -एस, और -ई के लिए आउटपुट प्रारूप वर्तमान में 'शेल' में डिफ़ॉल्ट है, लेकिन यह भविष्य के रिलीज में 'सादा' में बदल जाएगा। अप्रत्याशित व्यवहार से बचने के लिए, प्रारूप स्पष्ट रूप से निर्दिष्ट करें।"

msgid "Cannot allocate memory for string"
msgstr "स्ट्रिंग के लिए मेमोरी आवंटित नहीं की जा सकती"

msgid "Both maps have nothing in common. Check the computational region."
msgstr "दोनों मानचित्रों में कुछ भी समान नहीं है। कम्प्यूटेशनल क्षेत्र की जाँच करें।"

msgid "Calculates error matrix and kappa parameter for accuracy assessment of classification result."
msgstr "वर्गीकरण परिणाम के सटीकता मूल्यांकन के लिए त्रुटि मैट्रिक्स और कप्पा पैरामीटर की गणना करता है।"

msgid "Name of raster map containing classification result"
msgstr "वर्गीकरण परिणाम वाले रेखापुंज मानचित्र का नाम"

msgid "Name of raster map containing reference classes"
msgstr "संदर्भ वर्गों वाले रेखापुंज मानचित्र का नाम"

msgid "Name for output file containing error matrix and kappa"
msgstr "त्रुटि मैट्रिक्स और कप्पा युक्त आउटपुट फ़ाइल का नाम"

msgid "Title for error matrix and kappa"
msgstr "त्रुटि मैट्रिक्स और कप्पा के लिए शीर्षक"

msgid "Wide report"
msgstr "विस्तृत रिपोर्ट"

msgid "132 columns (default: 80)"
msgstr "132 कॉलम (डिफ़ॉल्ट: 80)"

msgid "No header in the report"
msgstr "रिपोर्ट में कोई हेडर नहीं"

msgid "Print Matrix only"
msgstr "केवल मैट्रिक्स प्रिंट करें"

msgid "When JSON output format is requested, all formatting flags are ignored"
msgstr "जब JSON आउटपुट फॉर्मेट का अनुरोध किया जाता है, तो सभी फ़ॉर्मेटिंग फ़्लैग को अनदेखा कर दिया जाता है"

#, c-format
msgid "Cannot open file <%s> to write cats and counts (error matrix)"
msgstr "बिल्लियाँ और गिनती लिखने के लिए फ़ाइल <%s> नहीं खोल सकता (त्रुटि मैट्रिक्स)"

#, c-format
msgid "Cannot open file <%s> to write header"
msgstr "हेडर लिखने के लिए फ़ाइल <%s> नहीं खोल सकता"

#, c-format
msgid "Cannot open file <%s> to write JSON output"
msgstr "JSON आउटपुट लिखने के लिए फ़ाइल <%s> नहीं खोल सकता"

msgid "Failed to serialize JSON"
msgstr "JSON को क्रमबद्ध करने में विफल"

#, c-format
msgid "Cannot open file <%s> to write kappa and relevant parameters"
msgstr "कप्पा और प्रासंगिक पैरामीटर लिखने के लिए फ़ाइल <%s> नहीं खोल सकता"

#, c-format
msgid "Can't open file <%s> to write label"
msgstr "लेबल लिखने के लिए फ़ाइल <%s> नहीं खोल सकता"

