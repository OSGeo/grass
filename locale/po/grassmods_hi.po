msgstr "स्वतः उत्पन्न यादृच्छिक बीज इस पर सेट: %ld"

#, c-format
msgid "Fractal dimension of %.2lf must be between 2 and 3."
msgstr "%.2lf का फ्रैक्टल आयाम 2 और 3 के बीच होना चाहिए।"

msgid "Unable to allocate data buffer. Check current region with g.region."
msgstr "डेटा बफ़र आवंटित करने में असमर्थ. जी.क्षेत्र के साथ वर्तमान क्षेत्र की जाँच करें।"

msgid "Preliminary surface calculations..."
msgstr "प्रारंभिक सतह गणना..।"

