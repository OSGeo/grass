msgstr "रास्टर मानचित्र पर कंट्रास्ट भारित किनारे घनत्व सूचकांक की गणना करता है"

msgid "landscape structure analysis"
msgstr "भूदृश्य संरचना विश्लेषण"

msgid "patch index"
msgstr "पैच सूचकांक"

msgid "Configuration file"
msgstr "कॉन्फ़िगरेशन फ़ाइल"

msgid "Name of file that contains the weight to calculate the index"
msgstr "फ़ाइल का नाम जिसमें सूचकांक की गणना करने के लिए वजन शामिल है"

msgid "Row cache is too small"
msgstr "पंक्ति कैश बहुत छोटा है"

msgid "Cannot create random access file"
msgstr "रैंडम एक्सेस फ़ाइल नहीं बनाई जा सकती"

#, c-format
msgid "Cannot create %s directory"
msgstr "%s निर्देशिका नहीं बनाई जा सकती"

#, c-format
msgid "Filepath '%s%s' exceeds max length"
msgstr "फ़ाइलपथ '%s%s' अधिकतम लंबाई से अधिक है"

#, c-format
msgid "Filepath '%s%s%c%s' exceeds max length"
msgstr "फ़ाइलपथ '%s_PH_1__%c%s' अधिकतम लंबाई से अधिक है"

#, c-format
msgid "Cannot create %s output"
msgstr "%s आउटपुट नहीं बना सकता"

#, c-format
msgid "Cannot find configuration file <%s>"
msgstr "कॉन्फ़िगरेशन फ़ाइल <%s> नहीं मिल सकी"

msgid "Cannot read setup file"
msgstr "सेटअप फ़ाइल नहीं पढ़ सकता"

msgid "Unable to parse configuration file (sampling frame)"
msgstr "कॉन्फ़िगरेशन फ़ाइल (नमूना फ़्रेम) को पार्स करने में असमर्थ"

