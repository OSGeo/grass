msgstr "संपादित करने के लिए वेक्टर मानचित्र का नाम"

msgid "Tool"
msgstr "औजार"

msgid "Create new (empty) vector map"
msgstr "नया (खाली) वेक्टर मानचित्र बनाएं"

msgid "Add new features to existing vector map"
msgstr "मौजूदा वेक्टर मानचित्र में नई सुविधाएँ जोड़ें"

