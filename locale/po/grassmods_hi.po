msgstr "बिना बंद बाहरी बहुभुज वलय को बंद करना"

#, c-format
msgid "Feature (cat %d): degenerated polygon (%d vertices)"
msgstr "फ़ीचर (बिल्ली %d): विकृत बहुभुज (%d शीर्ष)"

msgid "Found unclosed inner polygon ring, can be closed when cleaning polygons is not disabled"
msgstr "खुला आंतरिक बहुभुज रिंग पाया गया, जब बहुभुज की सफाई अक्षम नहीं है तो इसे बंद किया जा सकता है"

msgid "Closing unclosed inner polygon ring"
msgstr "बिना बंद आंतरिक बहुभुज वलय को बंद करना"

#, c-format
msgid "Degenerate island (%d vertices)"
msgstr "पतित द्वीप (%d शीर्ष)"

msgid "Unable calculate centroid"
msgstr "केन्द्रक की गणना करने में असमर्थ"

msgid "No centroid written for polygon with 0 vertices"
msgstr "0 शीर्षों वाले बहुभुज के लिए कोई केन्द्रक नहीं लिखा गया है"

msgid "Unable to write part of geometry"
msgstr "ज्यामिति का भाग लिखने में असमर्थ"

#, c-format
msgid "Skipping unsupported geometry type '%s'"
msgstr "असमर्थित ज्यामिति प्रकार '%s' को छोड़ना"

msgid "Imports vector data into a GRASS vector map using OGR library."
msgstr "OGR लाइब्रेरी का उपयोग करके वेक्टर डेटा को GRASS वेक्टर मानचित्र में आयात करता है।"

msgid ""
"Examples:\n"
"\t\tESRI Shapefile: directory containing shapefiles\n"
"\t\tMapInfo File: directory containing mapinfo files"
msgstr "उदाहरण:\\n\\t\\tESRI शेपफ़ाइल: निर्देशिका जिसमें शेपफ़ाइलें हैं\\n\\t\\tMapInfo फ़ाइल: निर्देशिका जिसमें मैपइन्फो फ़ाइलें हैं"

msgid ""
"Examples:\n"
"\t\tESRI Shapefile: shapefile name\n"
"\t\tMapInfo File: mapinfo file name"
msgstr "उदाहरण:\\n\\t\\tESRI शेपफ़ाइल: शेपफ़ाइल नाम\\n\\t\\tMapInfo फ़ाइल: मैपइन्फो फ़ाइल नाम"

msgid "Minimum size of area to be imported (square meters)"
msgstr "आयात किए जाने वाले क्षेत्र का न्यूनतम आकार (वर्ग मीटर)"

msgid "Smaller areas and islands are ignored. Should be greater than snap^2"
msgstr "छोटे क्षेत्रों और द्वीपों को नजरअंदाज कर दिया जाता है। स्नैप^2 से बड़ा होना चाहिए"

msgid "Optionally change default input type"
msgstr "वैकल्पिक रूप से डिफ़ॉल्ट इनपुट प्रकार बदलें"

msgid "import area centroids as points"
msgstr "क्षेत्र केन्द्रक को बिंदुओं के रूप में आयात करें"

msgid "import area boundaries as lines"
msgstr "क्षेत्र की सीमाओं को रेखाओं के रूप में आयात करें"

msgid "import lines as area boundaries"
msgstr "क्षेत्र सीमाओं के रूप में आयात लाइनें"

msgid "import points as centroids"
msgstr "केन्द्रक के रूप में आयात बिंदु"

msgid "'-1' for no snap"
msgstr "बिना किसी स्नैप के '-1'"

msgid "List of column names to be used instead of original names, first is used for category column"
msgstr "मूल नामों के स्थान पर उपयोग किए जाने वाले कॉलम नामों की सूची, पहले श्रेणी कॉलम के लिए उपयोग की जाती है"

msgid "Name of column used for categories"
msgstr "श्रेणियों के लिए प्रयुक्त कॉलम का नाम"

msgid "If not given, categories are generated as unique values and stored in 'cat' column"
msgstr "यदि नहीं दिया गया है, तो श्रेणियां अद्वितीय मानों के रूप में उत्पन्न होती हैं और 'बिल्ली' कॉलम में संग्रहीत होती हैं"

msgid "Name of geometry column"
msgstr "ज्यामिति स्तंभ का नाम"

msgid "If not given, all geometry columns from the input are used"
msgstr "यदि नहीं दिया गया है, तो इनपुट से सभी ज्यामिति कॉलम का उपयोग किया जाता है"

msgid "Do not clean polygons (not recommended)"
msgstr "बहुभुज साफ़ न करें (अनुशंसित नहीं)"

msgid "Force 2D output even if input is 3D"
msgstr "भले ही इनपुट 3D हो, 2D आउटपुट को बाध्य करें"

msgid "Useful if input is 3D but all z coordinates are identical"
msgstr "यदि इनपुट 3डी है लेकिन सभी z निर्देशांक समान हैं तो उपयोगी है"

msgid "Change column names to lowercase characters"
msgstr "कॉलम नामों को लोअरकेस वर्णों में बदलें"

#, c-format
msgid "Using OGR driver '%s/%s'"
msgstr "OGR ड्राइवर '%s/%s' का उपयोग करना"

