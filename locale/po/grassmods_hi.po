msgid "<%s> is integer raster map (CELL)"
msgstr "<%s> पूर्णांक रेखापुंज मानचित्र (CELL) है"

#, c-format
msgid "<%s> is integer raster map (CELL). Using null=%d."
msgstr "<%s> पूर्णांक रेखापुंज मानचित्र (CELL) है। null=%d का उपयोग करना।"

#, c-format
msgid "<%s> is floating pointing raster map"
msgstr "<%s> फ्लोटिंग पॉइंटिंग रैस्टर मैप है"

#, c-format
msgid "Writing new null file for raster map <%s>..."
msgstr "रेखापुंज मानचित्र के लिए नई शून्य फ़ाइल लिख रहा हूँ <%s>..।"

#, c-format
msgid "Raster map <%s> modified."
msgstr "रेखापुंज मानचित्र <%s> संशोधित।"

msgid "The NULL file is already compressed, nothing to do."
msgstr "NULL फ़ाइल पहले से ही संपीड़ित है, कुछ नहीं करना है।"

msgid "The NULL file is already uncompressed, nothing to do."
msgstr "NULL फ़ाइल पहले से ही असंपीड़ित है, कुछ नहीं करना है।"

#, c-format
msgid "Removing null file for raster map <%s>..."
msgstr "रेखापुंज मानचित्र <%s>... के लिए शून्य फ़ाइल हटाई जा रही है"

#, c-format
msgid "%s: %s: illegal value spec"
msgstr "%s: %s: अवैध मूल्य विशिष्टता"

#, c-format
msgid "%s: illegal value spec"
msgstr "%s: अवैध मूल्य विशिष्टता"

#, c-format
msgid "Writing new data for raster map <%s>..."
msgstr "रेखापुंज मानचित्र के लिए नया डेटा लिख रहा हूं <%s>..।"

