msgstr "प्रोफ़ाइल डेटा लिखने में विफल"

msgid "Failed to profile the computation, please check the parameters"
msgstr "गणना प्रोफ़ाइल करने में विफल, कृपया पैरामीटर जांचें"

#, c-format
msgid "Region resolution shouldn't be lesser than map %s resolution. Run g.region raster=%s to set proper resolution"
msgstr "क्षेत्र रिज़ॉल्यूशन मानचित्र %s रिज़ॉल्यूशन से कम नहीं होना चाहिए। उचित रिज़ॉल्यूशन सेट करने के लिए g.region raster=%s चलाएँ"

#, c-format
msgid "Internal error in %s()"
msgstr "%s() में आंतरिक त्रुटि"

msgid "Generates a raster map containing distances to nearest raster features and/or the value of the nearest non-null cell."
msgstr "एक रेखापुंज मानचित्र तैयार करता है जिसमें निकटतम रेखापुंज सुविधाओं की दूरी और/या निकटतम गैर-शून्य सेल का मान शामिल होता है।"

msgid "Name for distance output raster map"
msgstr "दूरी आउटपुट रैस्टर मानचित्र का नाम"

msgid "Name for value output raster map"
msgstr "मान आउटपुट रैस्टर मानचित्र का नाम"

msgid "Minimum distance threshold"
msgstr "न्यूनतम दूरी सीमा"

msgid "Maximum distance threshold"
msgstr "अधिकतम दूरी सीमा"

msgid "Output distances in meters instead of map units"
msgstr "मानचित्र इकाइयों के बजाय मीटर में आउटपुट दूरी"

msgid "Calculate distance to nearest NULL cell"
msgstr "निकटतम NULL सेल से दूरी की गणना करें"

#, c-format
msgid "Invalid %s value '%s', ignoring."
msgstr "अमान्य %s मान '%s', अनदेखी।"

#. GTC error because given minimum_distance is not smaller than
#. * given maximum_distance
#, c-format
msgid "'%s' must be smaller than '%s'."
msgstr "'%s' '%s' से छोटा होना चाहिए।"

msgid "Distance output is required for distance to NULL cells"
msgstr "NULL सेल्स की दूरी के लिए डिस्टेंस आउटपुट आवश्यक है"

msgid "Value output is meaningless for distance to NULL cells"
msgstr "NULL सेल्स की दूरी के लिए वैल्यू आउटपुट अर्थहीन है"

msgid "At least one of distance= and value= must be given"
msgstr "दूरी= और मान= में से कम से कम एक अवश्य दिया जाना चाहिए"

msgid "metric=geodesic is only valid for lat/lon"
msgstr "मेट्रिक=जियोडेसिक केवल अक्षांश/देशांतर के लिए मान्य है"

#, c-format
msgid "Unknown metric: '%s'"
msgstr "अज्ञात मीट्रिक: '%s'"

#, c-format
msgid "Output distance in meters for lat/lon is only possible with '%s=%s'"
msgstr "अक्षांश/देशांतर के लिए मीटर में आउटपुट दूरी केवल '%s=%s' के साथ संभव है"

#, c-format
msgid "Unable to create temporary file <%s>"
msgstr "अस्थायी फ़ाइल <%s> बनाने में असमर्थ"

msgid "Name of input raster map with initial piezometric head in [m]"
msgstr "[एम] में प्रारंभिक पीज़ोमेट्रिक हेड के साथ इनपुट रास्टर मानचित्र का नाम"

msgid "Name of input raster map providing boundary condition status: 0-inactive, 1-active, 2-dirichlet"
msgstr "सीमा स्थिति स्थिति प्रदान करने वाले इनपुट रास्टर मानचित्र का नाम: 0-निष्क्रिय, 1-सक्रिय, 2-डिरिचलेट"

msgid "Name of input raster map with x-part of the hydraulic conductivity tensor in [m/s]"
msgstr "[एम/एस] में हाइड्रोलिक चालकता टेंसर के एक्स-भाग के साथ इनपुट रास्टर मानचित्र का नाम"

msgid "Name of input raster map with y-part of the hydraulic conductivity tensor in [m/s]"
msgstr "[एम/एस] में हाइड्रोलिक चालकता टेंसर के वाई-भाग के साथ इनपुट रास्टर मानचित्र का नाम"

msgid "Name of input raster map with water sources and sinks in [m^3/s]"
msgstr "[m^3/s] में जल स्रोतों और सिंक के साथ इनपुट रास्टर मानचित्र का नाम"

msgid "Name of input raster map with storativity for confined or effective porosity for unconfined groundwater flow booth in [-] "
msgstr "[-] में अप्रतिबंधित भूजल प्रवाह बूथ के लिए सीमित या प्रभावी सरंध्रता के लिए भंडारण क्षमता के साथ इनपुट रास्टर मानचित्र का नाम "

msgid "Recharge"
msgstr "फिर से दाम लगाना"

msgid "Recharge input raster map e.g: 6*10^-9 per cell in [m^3/s*m^2]"
msgstr "रिचार्ज इनपुट रैस्टर मैप जैसे: 6*10^-9 प्रति सेल [m^3/s*m^2]"

msgid "Name of input raster map describing the top surface of the aquifer in [m]"
msgstr "[एम] में जलभृत की ऊपरी सतह का वर्णन करने वाले इनपुट रास्टर मानचित्र का नाम"

msgid "Name of input raster map describing the bottom surface of the aquifer in [m]"
msgstr "[एम] में जलभृत की निचली सतह का वर्णन करने वाले इनपुट रास्टर मानचित्र का नाम"

msgid "Output raster map storing the numerical result [m]"
msgstr "संख्यात्मक परिणाम संग्रहीत करने वाला आउटपुट रैस्टर मानचित्र [एम]"

msgid "Output raster map to store the groundwater filter velocity vector part in x direction [m/s]"
msgstr "भूजल फ़िल्टर वेग वेक्टर भाग को x दिशा में संग्रहीत करने के लिए आउटपुट रैस्टर मानचित्र [एम/एस]"

msgid "Output raster map to store the groundwater filter velocity vector part in y direction [m/s]"
msgstr "भूजल फ़िल्टर वेग वेक्टर भाग को y दिशा में संग्रहीत करने के लिए आउटपुट रैस्टर मानचित्र [एम/एस]"

msgid "Output raster map to store the groundwater budget for each cell [m^3/s]"
msgstr "प्रत्येक कोशिका के लिए भूजल बजट संग्रहीत करने के लिए आउटपुट रैस्टर मानचित्र [m^3/s]"

msgid "The type of groundwater flow"
msgstr "भूजल प्रवाह का प्रकार"

msgid "Name of input raster map providing the height of the river bed in [m]"
msgstr "[एम] में नदी तल की ऊंचाई प्रदान करने वाले इनपुट रास्टर मानचित्र का नाम"

msgid "Name of input raster map providing the water level (head) of the river with leakage connection in [m]"
msgstr "[एम] में रिसाव कनेक्शन के साथ नदी का जल स्तर (हेड) प्रदान करने वाले इनपुट रास्टर मानचित्र का नाम"

msgid "Name of input raster map providing the leakage coefficient of the river bed in [1/s]."
msgstr "[1/एस] में नदी तल का रिसाव गुणांक प्रदान करने वाले इनपुट रेखापुंज मानचित्र का नाम।"

msgid "Name of input raster map providing the height of the drainage bed in [m]"
msgstr "[एम] में जल निकासी बिस्तर की ऊंचाई प्रदान करने वाले इनपुट रास्टर मानचित्र का नाम"

msgid "Name of input raster map providing the leakage coefficient of the drainage bed in [1/s]"
msgstr "[1/एस] में जल निकासी बिस्तर के रिसाव गुणांक प्रदान करने वाले इनपुट रास्टर मानचित्र का नाम"

msgid "The maximum number of iterations in the linearization approach"
msgstr "रैखिककरण दृष्टिकोण में पुनरावृत्तियों की अधिकतम संख्या"

msgid "Allocate a full quadratic linear equation system, default is a sparse linear equation system."
msgstr "एक पूर्ण द्विघात रैखिक समीकरण प्रणाली आवंटित करें, डिफ़ॉल्ट एक विरल रैखिक समीकरण प्रणाली है।"

msgid "groundwater flow"
msgstr "भूजल प्रवाह"

msgid "Numerical calculation program for transient, confined and unconfined groundwater flow in two dimensions."
msgstr "दो आयामों में क्षणिक, सीमित और अप्रतिबंधित भूजल प्रवाह के लिए संख्यात्मक गणना कार्यक्रम।"

msgid "Please provide river_head, river_leak and river_bed maps"
msgstr "कृपया नदी_मुख, नदी_रिसाव और नदी_तल मानचित्र प्रदान करें"

msgid "Please provide drain_head and drain_leak maps"
msgstr "कृपया ड्रेन_हेड और ड्रेन_लीक मानचित्र प्रदान करें"

msgid "The cholesky solver dos not work with sparse matrices. You may choose a full filled quadratic matrix, flag -f."
msgstr "कोलेस्की सॉल्वर विरल मैट्रिक्स के साथ काम नहीं करता है। आप एक पूर्ण भरा हुआ द्विघात मैट्रिक्स, फ़्लैग -एफ चुन सकते हैं।"

msgid "Failed to initialize geometry data"
msgstr "ज्यामिति डेटा आरंभ करने में विफल"

msgid "Failed to allocate LES callback"
msgstr "एलईएस कॉलबैक आवंटित करने में विफल"

msgid "Failed to allocate gwflow data structure"
msgstr "Gwflow डेटा संरचना आवंटित करने में विफल"

#, c-format
msgid "Calculation time: %g"
msgstr "गणना समय: %g"

msgid "Unable to create and solve the linear equation system"
msgstr "रैखिक समीकरण प्रणाली बनाने और हल करने में असमर्थ"

#, c-format
msgid "Calculation of unconfined groundwater flow loop %i"
msgstr "अप्रतिबंधित भूजल प्रवाह लूप %i की गणना"

#, c-format
msgid "Maximum difference between this and last increment: %g"
msgstr "इस और अंतिम वेतन वृद्धि के बीच अधिकतम अंतर: %g"

msgid "Failed to compute gradient field"
msgstr "ग्रेडिएंट फ़ील्ड की गणना करने में विफल"

msgid "Unable to create the linear equation system"
msgstr "रैखिक समीकरण प्रणाली बनाने में असमर्थ"

msgid "Generates red, green and blue (RGB) raster map layers combining hue, intensity and saturation (HIS) values from user-specified input raster map layers."
msgstr "उपयोगकर्ता द्वारा निर्दिष्ट इनपुट रैस्टर मैप परतों से रंग, तीव्रता और संतृप्ति (एचआईएस) मानों को मिलाकर लाल, हरा और नीला (आरजीबी) रैस्टर मैप परतें उत्पन्न करता है।"

msgid "Name of output layer to be used for red"
msgstr "लाल रंग के लिए उपयोग की जाने वाली आउटपुट परत का नाम"

msgid "Name of output layer to be used for green"
msgstr "हरे रंग के लिए उपयोग की जाने वाली आउटपुट परत का नाम"

msgid "Name of output layer to be used for blue"
msgstr "नीले रंग के लिए उपयोग की जाने वाली आउटपुट परत का नाम"

#, c-format
msgid "No such color <%s>"
msgstr "ऐसा कोई रंग नहीं <%s>"

msgid "solar"
msgstr "सौर"

msgid "sun position"
msgstr "सूर्य स्थिति"

msgid "Computes horizon angle height from a digital elevation model."
msgstr "डिजिटल उन्नयन मॉडल से क्षितिज कोण ऊंचाई की गणना करता है।"

msgid "The module has two different modes of operation: 1. Computes the entire horizon around a single point whose coordinates are given with the 'coord' option. The horizon height (in radians). 2. Computes one or more raster maps of the horizon height in a single direction. The input for this is the angle (in degrees), which is measured counterclockwise with east=0, north=90 etc. The output is the horizon height in radians."
msgstr "मॉड्यूल में संचालन के दो अलग-अलग तरीके हैं: 1. एक बिंदु के चारों ओर संपूर्ण क्षितिज की गणना करता है जिसके निर्देशांक 'समन्वय' विकल्प के साथ दिए गए हैं। क्षितिज की ऊँचाई (रेडियन में)। 2. एक ही दिशा में क्षितिज ऊंचाई के एक या अधिक रेखापुंज मानचित्रों की गणना करता है। इसके लिए इनपुट कोण (डिग्री में) है, जिसे पूर्व = 0, उत्तर = 90 आदि के साथ वामावर्त मापा जाता है। आउटपुट रेडियन में क्षितिज की ऊंचाई है।"

msgid "Direction in which you want to know the horizon height"
msgstr "जिस दिशा में आप क्षितिज की ऊँचाई जानना चाहते हैं"

msgid "Angle step size for multidirectional horizon [degrees]"
msgstr "बहुदिशात्मक क्षितिज के लिए कोण चरण का आकार [डिग्री]"

msgid "Start angle for multidirectional horizon [degrees]"
msgstr "बहुदिशात्मक क्षितिज के लिए प्रारंभ कोण [डिग्री]"

msgid "Raster mode"
msgstr "रास्टर मोड"

msgid "End angle for multidirectional horizon [degrees]"
msgstr "बहुदिशात्मक क्षितिज के लिए अंतिम कोण [डिग्री]"

msgid "For horizon rasters, read from the DEM an extra buffer around the present region"
msgstr "क्षितिज रेखापुंज के लिए, डीईएम से वर्तमान क्षेत्र के आसपास एक अतिरिक्त बफर पढ़ें"

msgid "For horizon rasters, read from the DEM an extra buffer eastward the present region"
msgstr "क्षितिज रेखापुंज के लिए, डीईएम से वर्तमान क्षेत्र के पूर्व की ओर एक अतिरिक्त बफर पढ़ें"

msgid "For horizon rasters, read from the DEM an extra buffer westward the present region"
