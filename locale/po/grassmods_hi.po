msgstr "पहलू रेखापुंज मानचित्र <%s> पूर्ण"

#, c-format
msgid "Min computed slope %.4f, max computed slope %.4f"
msgstr "न्यूनतम गणना की गई ढलान % .4f, अधिकतम गणना की गई ढलान % .4f"

#, c-format
msgid "Slope raster map <%s> complete"
msgstr "ढलान रेखापुंज मानचित्र <%s> पूर्ण"

#, c-format
msgid "Profile curve raster map <%s> complete"
msgstr "प्रोफ़ाइल वक्र रेखापुंज मानचित्र <%s> पूर्ण"

#, c-format
msgid "Tangential curve raster map <%s> complete"
msgstr "स्पर्शरेखीय वक्र रेखापुंज मानचित्र <%s> पूर्ण"

#, c-format
msgid "E-W slope raster map <%s> complete"
msgstr "E-W ढलान रेखापुंज मानचित्र <%s> पूर्ण"

#, c-format
msgid "N-S slope raster map <%s> complete"
msgstr "एन-एस ढलान रेखापुंज मानचित्र <%s> पूर्ण"

#, c-format
msgid "Dxx raster map <%s> complete"
msgstr "Dxx रेखापुंज मानचित्र <%s> पूर्ण"

#, c-format
msgid "Dyy raster map <%s> complete"
msgstr "डाई रेखापुंज मानचित्र <%s> पूर्ण"

#, c-format
msgid "Dxy raster map <%s> complete"
msgstr "Dxy रेखापुंज मानचित्र <%s> पूर्ण"

msgid "smoothing"
msgstr "चौरसाई"

msgid "edge detection"
msgstr "किनारे का पता लगाना"

msgid "denoise"
msgstr "denoise"

msgid "Smoothing with anisotropic diffusion"
msgstr "अनिसोट्रोपिक प्रसार के साथ चौरसाई"

msgid "Gradient magnitude threshold (in map units)"
msgstr "क्रमिक परिमाण सीमा (मानचित्र इकाइयों में)"

msgid "Diffusion"
msgstr "प्रसार"

msgid "Rate of diffusion"
msgstr "प्रसार की दर"

msgid "Number of diffusion steps"
msgstr "प्रसार चरणों की संख्या"

msgid "Diffusivity function"
msgstr "विसरणशीलता समारोह"

msgid "Preserve details with Tukey"
msgstr "तुकी के साथ विवरण सुरक्षित रखें"

msgid "Wrong computational region"
msgstr "ग़लत कम्प्यूटेशनल क्षेत्र"

msgid "Computational region is too small!"
msgstr "कम्प्यूटेशनल क्षेत्र बहुत छोटा है!"

msgid "Computational region is too large!"
msgstr "कम्प्यूटेशनल क्षेत्र बहुत बड़ा है!"

msgid "Smoothed map"
msgstr "चिकना नक्शा"

#, c-format
msgid "Seek error on temp file. %d: %s"
msgstr "अस्थायी फ़ाइल पर त्रुटि की तलाश करें। %d: %s"

#, c-format
msgid "There was an error reading data from a temporary file. %d: %s"
msgstr "एक अस्थायी फ़ाइल से डेटा पढ़ने में त्रुटि हुई। %d: %s"

#, c-format
msgid "There was an error writing data from a temporary file. %d: %s"
msgstr "एक अस्थायी फ़ाइल से डेटा लिखने में त्रुटि हुई। %d: %s"

msgid "Error fetching data from a disk cache"
msgstr "डिस्क कैश से डेटा लाने में त्रुटि"

msgid "Insufficient memory to hold processed data. Either increase available memory with the \"memory\" parameter or reduce size of the computational region."
msgstr "संसाधित डेटा रखने के लिए अपर्याप्त मेमोरी. या तो \\\"मेमोरी\\\" पैरामीटर के साथ उपलब्ध मेमोरी बढ़ाएं या कम्प्यूटेशनल क्षेत्र का आकार कम करें।"

msgid "Using disk for temporary data storage"
msgstr "अस्थायी डेटा भंडारण के लिए डिस्क का उपयोग करना"

#, c-format
msgid "Error creating row cache. %d: %s"
msgstr "पंक्ति कैश बनाने में त्रुटि. %d: %s"

msgid "Error creating row cache"
msgstr "पंक्ति कैश बनाने में त्रुटि"

msgid "Keeping temporary data in RAM"
msgstr "RAM में अस्थायी डेटा रखना"

#, c-format
msgid "Error cleaning up row cache. %d: %s"
msgstr "पंक्ति कैश साफ़ करने में त्रुटि. %d: %s"

msgid "The initial concentration in [kg/m^3]"
msgstr "प्रारंभिक सांद्रता [किग्रा/मीटर^3] में"

msgid "The piezometric head in [m]"
msgstr "[एम] में पीजोमेट्रिक हेड"

msgid "The x-part of the hydraulic conductivity tensor in [m/s]"
msgstr "[एम/एस] में हाइड्रोलिक चालकता टेंसर का एक्स-भाग"

msgid "The y-part of the hydraulic conductivity tensor in [m/s]"
msgstr "[एम/एस] में हाइड्रोलिक चालकता टेंसर का वाई-भाग"

msgid "The status for each cell, = 0 - inactive cell, 1 - active cell, 2 - dirichlet- and 3 - transfer boundary condition"
msgstr "प्रत्येक कोशिका की स्थिति, = 0 - निष्क्रिय कोशिका, 1 - सक्रिय कोशिका, 2 - डिरिचलेट- और 3 - स्थानांतरण सीमा स्थिति"

msgid "The x-part of the diffusion tensor in [m^2/s]"
msgstr "[m^2/s] में प्रसार टेंसर का x-भाग"

msgid "The y-part of the diffusion tensor in [m^2/s]"
msgstr "[m^2/s] में प्रसार टेंसर का y-भाग"

msgid "Water flow"
msgstr "जल प्रवाह"

msgid "Groundwater sources and sinks in [m^3/s]"
msgstr "भूजल स्रोत और कुंड [m^3/s]"

msgid "Concentration sources and sinks bounded to a water source or sink in [kg/s]"
msgstr "सांद्रण स्रोत और सिंक जल स्रोत से बंधे हैं या सिंक [किग्रा/सेकंड] में हैं"

msgid "Concentration of inner sources and inner sinks in [kg/s] (i.e. a chemical reaction)"
msgstr "आंतरिक स्रोतों और आंतरिक सिंक की सांद्रता [किलो/सेकंड] में (यानी एक रासायनिक प्रतिक्रिया)"

msgid "Retardation factor [-]"
msgstr "मंदता कारक [-]"

msgid "Effective porosity [-]"
msgstr "प्रभावी सरंध्रता [-]"

msgid "Top surface of the aquifer in [m]"
msgstr "जलभृत की ऊपरी सतह [एम] में"

msgid "Bottom surface of the aquifer in [m]"
msgstr "जलभृत की निचली सतह [एम] में"

msgid "The resulting concentration of the numerical solute transport calculation will be written to this map. [kg/m^3]"
msgstr "संख्यात्मक विलेय परिवहन गणना की परिणामी सांद्रता इस मानचित्र पर लिखी जाएगी। [किलो/मीटर^3]"

msgid "Calculate and store the groundwater filter velocity vector part in x direction [m/s]\n"
msgstr "भूजल फ़िल्टर वेग वेक्टर भाग की गणना करें और उसे x दिशा [m/s]\\n में संग्रहित करें\n"

msgid "Calculate and store the groundwater filter velocity vector part in y direction [m/s]\n"
msgstr "भूजल फ़िल्टर वेग वेक्टर भाग की गणना करें और उसे y दिशा [m/s]\\n में संग्रहित करें\n"

msgid "The longditudinal dispersivity length. [m]"
msgstr "अनुदैर्ध्य फैलाव लंबाई. [एम]"

msgid "The transversal dispersivity length. [m]"
msgstr "अनुप्रस्थ फैलाव लंबाई. [एम]"

msgid "Use this number of time loops if the CFL flag is off. The timestep will become dt/loops."
msgstr "यदि सीएफएल ध्वज बंद है तो इस संख्या में टाइम लूप का उपयोग करें। टाइमस्टेप dt/लूप बन जाएगा।"

msgid "Set the flow stabilizing scheme (full or exponential upwinding)."
msgstr "प्रवाह स्थिरीकरण योजना (पूर्ण या घातीय अपवाइंडिंग) सेट करें।"

msgid "Use a full filled quadratic linear equation system, default is a sparse linear equation system."
msgstr "पूर्ण रूप से भरे हुए द्विघात रैखिक समीकरण प्रणाली का उपयोग करें, डिफ़ॉल्ट एक विरल रैखिक समीकरण प्रणाली है।"

msgid "Use the Courant-Friedrichs-Lewy criteria for time step calculation"
msgstr "समय चरण गणना के लिए कूरेंट-फ्रेडरिक-लेवी मानदंड का उपयोग करें"

msgid "solute transport"
msgstr "विलेय परिवहन"

msgid "Numerical calculation program for transient, confined and unconfined solute transport in two dimensions"
msgstr "दो आयामों में क्षणिक, सीमित और अप्रतिबंधित विलेय परिवहन के लिए संख्यात्मक गणना कार्यक्रम"

msgid "The direct LU solver do not work with sparse matrices"
msgstr "प्रत्यक्ष LU सॉल्वर विरल मैट्रिक्स के साथ काम नहीं करता है"

msgid "The direct Gauss solver do not work with sparse matrices"
msgstr "प्रत्यक्ष गॉस सॉल्वर विरल मैट्रिक्स के साथ काम नहीं करता है"

#, c-format
msgid "The Courant-Friedrichs-Lewy criteria is %g it should be within [0:1]"
msgstr "कूरेंट-फ्रेडरिक-लेवी मानदंड %g है, इसे [0:1] के भीतर होना चाहिए"

#, c-format
msgid "The largest stable time step is %g"
msgstr "सबसे बड़ा स्थिर समय चरण %g है"

#, c-format
msgid "Number of inner loops is %g"
msgstr "आंतरिक लूपों की संख्या %g है"

#, c-format
msgid "Time step for each loop %g"
msgstr "प्रत्येक लूप के लिए समय चरण %g"

#, c-format
msgid "The time step is to large: %gs. The largest time step should be of size %gs."
msgstr "समय का चरण बहुत बड़ा है: %gs। सबसे बड़ा समय कदम आकार %gs का होना चाहिए।"

#, c-format
msgid "Time step %i with time sum %g"
msgstr "समय चरण %i समय योग के साथ %g"

msgid "Could not create and solve the linear equation system"
msgstr "रैखिक समीकरण प्रणाली का निर्माण एवं समाधान नहीं हो सका"

msgid "Simulates elliptically anisotropic spread."
msgstr "अण्डाकार अनिसोट्रोपिक प्रसार का अनुकरण करता है।"

msgid "Generates a raster map of the cumulative time of spread, given raster maps containing the rates of spread (ROS), the ROS directions and the spread origins. It optionally produces raster maps to contain backlink UTM coordinates for tracing spread paths. Usable for fire spread simulations."
msgstr "प्रसार के संचयी समय का एक रेखापुंज मानचित्र तैयार करता है, जिसमें प्रसार की दर (आरओएस), आरओएस दिशाएं और प्रसार की उत्पत्ति वाले रेखापुंज मानचित्र दिए जाते हैं। यह वैकल्पिक रूप से प्रसार पथों का पता लगाने के लिए बैकलिंक यूटीएम निर्देशांक रखने के लिए रेखापुंज मानचित्र तैयार करता है। आग प्रसार सिमुलेशन के लिए प्रयोग करने योग्य।"

msgid "Raster map containing base ROS (cm/min)"
msgstr "आधार ROS युक्त रेखापुंज मानचित्र (सेमी/मिनट)"

msgid "Name of an existing raster map layer in the user's current mapset search path containing the ROS values in the directions perpendicular to maximum ROSes' (cm/minute). These ROSes are also the ones without the effect of directional factors."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रास्टर मैप परत का नाम जिसमें अधिकतम ROSes' (सेमी/मिनट) के लंबवत दिशाओं में ROS मान शामिल हैं। ये गुलाब दिशात्मक कारकों के प्रभाव से रहित भी हैं।"

msgid "Raster map containing maximal ROS (cm/min)"
msgstr "अधिकतम आरओएस युक्त रेखापुंज मानचित्र (सेमी/मिनट)"

msgid "Name of an existing raster map layer in the user's current mapset search path containing the maximum ROS values (cm/minute)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में अधिकतम आरओएस मान (सेमी/मिनट) वाले मौजूदा रैस्टर मैप परत का नाम।"

msgid "Raster map containing directions of maximal ROS (degree)"
msgstr "अधिकतम आरओएस (डिग्री) की दिशाओं वाला रेखापुंज मानचित्र"

msgid "Name of an existing raster map layer in the user's current mapset search path containing directions of the maximum ROSes, clockwise from north (degree)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रेखापुंज मानचित्र परत का नाम जिसमें उत्तर से दक्षिणावर्त (डिग्री) अधिकतम ROSes की दिशाएं शामिल हैं।"

msgid "Raster map containing starting sources"
msgstr "आरंभिक स्रोतों से युक्त रेखापुंज मानचित्र"

msgid "Name of an existing raster map layer in the user's current mapset search path containing starting locations of the spread phenomenon. Any positive integers in this map are recognized as starting sources (seeds)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रेखापुंज मानचित्र परत का नाम जिसमें प्रसार घटना के शुरुआती स्थान शामिल हैं। इस मानचित्र में किसी भी सकारात्मक पूर्णांक को प्रारंभिक स्रोत (बीज) के रूप में पहचाना जाता है।"

msgid "Raster map containing maximal spotting distance (m, required with -s)"
msgstr "अधिकतम स्पॉटिंग दूरी वाला रेखापुंज मानचित्र (एम, -एस के साथ आवश्यक)"

msgid "Name of an existing raster map layer in the user's current mapset search path containing the maximum potential spotting distances (meters)."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रैस्टर मैप परत का नाम जिसमें अधिकतम संभावित स्पॉटिंग दूरी (मीटर) शामिल है।"

msgid "Raster map containing midflame wind speed (ft/min, required with -s)"
msgstr "मध्य ज्वाला हवा की गति (फीट/मिनट, -s के साथ आवश्यक) युक्त रेखापुंज मानचित्र"

msgid "Raster map containing fine fuel moisture of the cell receiving a spotting firebrand (%, required with -s)"
msgstr "स्पॉटिंग फायरब्रांड प्राप्त करने वाले सेल की बारीक ईंधन नमी वाला रेखापुंज मानचित्र (%, -s के साथ आवश्यक)"

msgid "Basic sampling window size needed to meet certain accuracy (3)"
msgstr "कुछ सटीकता को पूरा करने के लिए आवश्यक बुनियादी नमूना विंडो आकार (3)"

msgid "An odd integer ranging 3 - 15 indicating the basic sampling window size within which all cells will be considered to see whether they will be reached by the current spread cell. The default number is 3 which means a 3x3 window."
msgstr "3 - 15 तक का एक विषम पूर्णांक मूल नमूना विंडो आकार को दर्शाता है जिसके भीतर सभी कोशिकाओं पर यह देखने के लिए विचार किया जाएगा कि क्या वे वर्तमान प्रसार सेल तक पहुंच पाएंगे। डिफ़ॉल्ट संख्या 3 है जिसका अर्थ है 3x3 विंडो।"

msgid "Sampling density for additional computing (range: 0.0 - 1.0 (0.5))"
msgstr "अतिरिक्त कंप्यूटिंग के लिए नमूनाकरण घनत्व (सीमा: 0.0 - 1.0 (0.5))"

msgid "A decimal number ranging 0.0 - 1.0 indicating additional sampling cells will be considered to see whether they will be reached by the current spread cell. The closer to 1.0 the decimal number is, the longer the program will run and the higher the simulation accuracy will be. The default number is 0.5."
msgstr "अतिरिक्त नमूना कोशिकाओं को इंगित करने वाली 0.0 - 1.0 तक की दशमलव संख्या पर यह देखने के लिए विचार किया जाएगा कि क्या वे वर्तमान प्रसार सेल तक पहुंच पाएंगे। दशमलव संख्या 1.0 के जितनी करीब होगी, प्रोग्राम उतना ही अधिक समय तक चलेगा और सिमुलेशन सटीकता उतनी ही अधिक होगी। डिफ़ॉल्ट संख्या 0.5 है।"

msgid "Initial time for current simulation (0) (min)"
msgstr "वर्तमान सिमुलेशन के लिए प्रारंभिक समय (0) (मिनट)"

msgid "A non-negative number specifying the initial time for the current spread simulation (minutes). This is useful when multiple phase simulation is conducted. The default time is 0."
msgstr "वर्तमान प्रसार सिमुलेशन (मिनट) के लिए प्रारंभिक समय निर्दिष्ट करने वाली एक गैर-नकारात्मक संख्या। यह तब उपयोगी होता है जब एकाधिक चरण सिमुलेशन आयोजित किया जाता है। डिफ़ॉल्ट समय 0 है।"

msgid "Simulating time duration LAG (fill the region) (min)"
msgstr "समय अवधि LAG का अनुकरण (क्षेत्र भरें) (न्यूनतम)"

msgid "A non-negative integer specifying the simulating duration time lag (minutes). The default is infinite, but the program will terminate when the current geographic region/mask has been filled. It also controls the computational time, the shorter the time lag, the faster the program will run."
msgstr "अनुकरण अवधि समय अंतराल (मिनट) को निर्दिष्ट करने वाला एक गैर-नकारात्मक पूर्णांक। डिफ़ॉल्ट अनंत है, लेकिन वर्तमान भौगोलिक क्षेत्र/मास्क भर जाने पर प्रोग्राम समाप्त हो जाएगा। यह कम्प्यूटेशनल समय को भी नियंत्रित करता है, समय अंतराल जितना कम होगा, प्रोग्राम उतनी ही तेजी से चलेगा।"

msgid "Name of raster map as a display backdrop"
msgstr "प्रदर्शन पृष्ठभूमि के रूप में रेखापुंज मानचित्र का नाम"

msgid "Name of an existing raster map layer in the user's current mapset search path to be used as the background on which the \"live\" movement will be shown."
msgstr "उपयोगकर्ता के वर्तमान मैपसेट खोज पथ में मौजूदा रास्टर मैप परत का नाम पृष्ठभूमि के रूप में उपयोग किया जाएगा जिस पर \"लाइव\" आंदोलन दिखाया जाएगा।"

msgid "Raster map to contain output spread time (min)"
msgstr "आउटपुट प्रसार समय (न्यूनतम) रखने के लिए रेखापुंज मानचित्र"

msgid "Name of the new raster map layer to contain the results of the cumulative spread time needed for a phenomenon to reach each cell from the starting sources (minutes)."
msgstr "आरंभिक स्रोतों (मिनटों) से प्रत्येक कोशिका तक पहुंचने के लिए किसी घटना के लिए आवश्यक संचयी प्रसार समय के परिणामों को शामिल करने के लिए नई रेखापुंज मानचित्र परत का नाम।"

msgid "Name of raster map to contain X back coordinates"
msgstr "X बैक निर्देशांक को समाहित करने वाले रेखापुंज मानचित्र का नाम"

msgid "Name of the new raster map layer to contain the results of backlink information in UTM easting coordinates for each cell."
msgstr "प्रत्येक सेल के लिए यूटीएम ईस्टिंग निर्देशांक में बैकलिंक जानकारी के परिणामों को शामिल करने के लिए नई रैस्टर मैप परत का नाम।"

msgid "Name of raster map to contain Y back coordinates"
msgstr "Y बैक निर्देशांक को समाहित करने वाले रेखापुंज मानचित्र का नाम"

msgid "Name of the new raster map layer to contain the results of backlink information in UTM northing coordinates for each cell."
msgstr "प्रत्येक सेल के लिए यूटीएम नॉर्थिंग निर्देशांक में बैकलिंक जानकारी के परिणामों को शामिल करने के लिए नई रैस्टर मैप परत का नाम।"

msgid "DISPLAY 'live' spread process on screen"
msgstr "स्क्रीन पर 'लाइव' प्रसार प्रक्रिया प्रदर्शित करें"

msgid "Display the 'live' simulation on screen. A graphics window must be opened and selected before using this option."
msgstr "स्क्रीन पर 'लाइव' सिमुलेशन प्रदर्शित करें। इस विकल्प का उपयोग करने से पहले एक ग्राफ़िक्स विंडो खोली और चुनी जानी चाहिए।"

msgid "Consider spotting effect (for wildfires)"
msgstr "स्पॉटिंग प्रभाव पर विचार करें (जंगल की आग के लिए)"

msgid "Use start raster map values in output spread time raster map"
msgstr "आउटपुट स्प्रेड टाइम रैस्टर मैप में स्टार्ट रैस्टर मैप मानों का उपयोग करें"

msgid "Designed to be used with output of previous run of r.spread when computing spread iteratively. The values in start raster map are considered as time. Allowed values in raster map are from zero to the value of init_time option. If not enabled, init_time is used in the area of start raster map"
msgstr "पुनरावर्ती रूप से प्रसार की गणना करते समय आर.स्प्रेड के पिछले रन के आउटपुट के साथ उपयोग करने के लिए डिज़ाइन किया गया। प्रारंभ रेखापुंज मानचित्र में मानों को समय माना जाता है। रेखापुंज मानचित्र में अनुमत मान शून्य से init_time विकल्प के मान तक हैं। यदि सक्षम नहीं है, तो init_time का उपयोग स्टार्ट रैस्टर मैप के क्षेत्र में किया जाता है"

msgid "Reading inputs..."
msgstr "इनपुट पढ़ रहा है..।"

#, c-format
msgid "Maximum of start raster map is grater than init_time (%d > %d)"
msgstr "प्रारंभ रेखापुंज मानचित्र का अधिकतम भाग init_time (%d > %d) से अधिक है"

#, c-format
msgid "Minimum of start raster map is less than zero (%d < 0)"
msgstr "न्यूनतम प्रारंभ रेखापुंज मानचित्र शून्य से कम है (%d < 0)"

#, c-format
msgid "Reading %s..."
msgstr "पढ़ रहा हूँ %s..।"

msgid "Recursively traces the least cost path backwards to cells from which the cumulative cost was determined."
msgstr "पुनरावर्ती रूप से उन कोशिकाओं तक न्यूनतम लागत पथ का पता लगाता है जहां से संचयी लागत निर्धारित की गई थी।"

msgid "Name of raster map containing back-path easting information"
msgstr "रास्टर मानचित्र का नाम जिसमें बैक-पाथ ईस्टिंग जानकारी शामिल है"

msgid "Name of raster map containing back-path northing information"
msgstr "रास्टर मानचित्र का नाम जिसमें बैक-पाथ नॉर्थिंग जानकारी शामिल है"

msgid "The map E and N grid coordinates of starting points"
msgstr "मानचित्र ई और एन ग्रिड शुरुआती बिंदुओं के निर्देशांक"

#, c-format
msgid "Reading the input map -%s- and -%s- and creating some temporary files..."
msgstr "इनपुट मैप -%s- और -%s- को पढ़ना और कुछ अस्थायी फ़ाइलें बनाना..।"

msgid "Finding the least cost paths ..."
msgstr "कम से कम लागत वाले रास्ते ढूँढना..।"

#, c-format
msgid "Writing the output map  -%s-..."
msgstr "आउटपुट मैप लिखना -%s-..।"

msgid "Calculates category or object oriented statistics."
msgstr "श्रेणी या वस्तु उन्मुख आँकड़ों की गणना करता है।"

msgid "Method of object-based statistic"
msgstr "वस्तु-आधारित सांख्यिकी की विधि"

msgid "Resultant raster map"
msgstr "परिणामी रेखापुंज मानचित्र"

msgid "Cover values extracted from the category labels of the cover map"
msgstr "कवर मानचित्र के श्रेणी लेबल से निकाले गए कवर मान"

msgid "This module currently only works for integer (CELL) maps"
msgstr "यह मॉड्यूल वर्तमान में केवल पूर्णांक (सेल) मानचित्रों के लिए काम करता है"

msgid "o_adev: No data in array"
msgstr "o_adev: सरणी में कोई डेटा नहीं"

msgid "o_kurto: No data in array"
msgstr "o_kurto: सरणी में कोई डेटा नहीं"

msgid "o_var: No data in array"
msgstr "o_var: सरणी में कोई डेटा नहीं"

msgid "o_skew: No data in array"
msgstr "o_skew: सरणी में कोई डेटा नहीं"

msgid "Reading r.stats output"
msgstr "r.stats आउटपुट पढ़ना"

msgid "Computing histograms"
msgstr "हिस्टोग्राम की गणना"

msgid "No cells found where both base and cover are not NULL"
msgstr "ऐसा कोई सेल नहीं मिला जहां आधार और आवरण दोनों शून्य न हों"

msgid "Printing quantiles"
msgstr "मुद्रण मात्राएँ"

msgid "Generating reclass maps"
msgstr "पुनर्वर्गीकृत मानचित्र तैयार करना"

msgid "Writing output maps"
msgstr "आउटपुट मानचित्र लिखना"

msgid "Compute category quantiles using two passes."
msgstr "दो पासों का उपयोग करके श्रेणी मात्राओं की गणना करें।"

msgid "Resultant raster map(s)"
msgstr "परिणामी रेखापुंज मानचित्र"

msgid "Create reclass map with statistics as category labels"
msgstr "श्रेणी लेबल के रूप में आँकड़ों के साथ पुनर्वर्गीकृत मानचित्र बनाएँ"

msgid "Do not create output maps; just print statistics"
msgstr "आउटपुट मानचित्र न बनाएं; बस आँकड़े छापो"

msgid "Print statistics in table format [deprecated]"
msgstr "तालिका प्रारूप में आँकड़े प्रिंट करें [अप्रत्याशित]"

msgid "This flag is deprecated and will be removed in a future release. Use format=csv instead."
msgstr "यह ध्वज अप्रचलित है और भविष्य में रिलीज़ में हटा दिया जाएगा। इसके बजाय प्रारूप = सीएसवी का प्रयोग करें।"

#, c-format
msgid "Either -%c or %s= must be given"
msgstr "या तो -%c या %s= दिया जाना चाहिए"

msgid "Flag 't' is deprecated and will be removed in a future release. Please use format=csv instead."
msgstr "ध्वज 't' को हटा दिया गया है और भविष्य में रिलीज़ में हटा दिया जाएगा। कृपया इसके बजाय प्रारूप = सीएसवी का उपयोग करें।"

msgid "The -t flag cannot be used with format=json. Please select only one output format."
msgstr "-t ध्वज का उपयोग form=json के साथ नहीं किया जा सकता। कृपया केवल एक आउटपुट स्वरूप चुनें।"

#, c-format
msgid "Number of quantiles (%d) does not match number of output maps (%d)"
msgstr "मात्राओं की संख्या (%d) आउटपुट मानचित्रों की संख्या से मेल नहीं खाती (%d)"

msgid "The base map must be an integer (CELL) map"
msgstr "आधार मानचित्र एक पूर्णांक (CELL) मानचित्र होना चाहिए"

#, c-format
msgid "Unable to read range of base map <%s>"
msgstr "आधार मानचित्र की सीमा को पढ़ने में असमर्थ <%s>"

#, c-format
msgid "Base map <%s> has many categories (%d), computation might be slow and might need a lot of memory"
msgstr "बेस मैप <%s> में कई श्रेणियां हैं (%d), गणना धीमी हो सकती है और बहुत अधिक मेमोरी की आवश्यकता हो सकती है"

msgid "Calculates category or object oriented statistics (accumulator-based statistics)."
msgstr "श्रेणी या वस्तु उन्मुख आँकड़ों (संचायक-आधारित आँकड़े) की गणना करता है।"

#, c-format
msgid "Unable to read category file of cover map <%s>"
msgstr "कवर मानचित्र की श्रेणी फ़ाइल को पढ़ने में असमर्थ <%s>"

msgid "First pass"
msgstr "पहला पास"

msgid "Second pass"
msgstr "दूसरा पास"

msgid "Generating reclass map"
msgstr "पुनर्वर्गीकृत मानचित्र तैयार करना"

msgid "Writing output map"
msgstr "आउटपुट मैप लिखना"

msgid "Generates area statistics for raster map."
msgstr "रेखापुंज मानचित्र के लिए क्षेत्र आँकड़े उत्पन्न करता है।"

msgid "Print area totals in square meters"
msgstr "क्षेत्रफल का योग वर्ग मीटर में प्रिंट करें"

msgid "Print cell counts (sortable)"
msgstr "सेल संख्या प्रिंट करें (क्रमबद्ध)"

msgid "Print approximate (total percent may not be 100%) percents"
msgstr "अनुमानित (कुल प्रतिशत 100% नहीं हो सकता) प्रतिशत प्रिंट करें"

msgid "Print category labels"
msgstr "श्रेणी लेबल प्रिंट करें"

msgid "One cell (range) per line"
msgstr "प्रति पंक्ति एक सेल (रेंज)।"

msgid "Print grid coordinates (east and north)"
msgstr "प्रिंट ग्रिड निर्देशांक (पूर्व और उत्तर)"

msgid "Coordinates"
msgstr "COORDINATES"

msgid "Print x and y (column and row)"
msgstr "x और y प्रिंट करें (कॉलम और पंक्ति)"

msgid "Indexing starts with 1: first column and row are 1"
msgstr "अनुक्रमण 1 से प्रारंभ होता है: पहला कॉलम और पंक्ति 1 हैं"

msgid "Print averaged values instead of intervals (floating-point maps only)"
msgstr "अंतराल के बजाय औसत मान प्रिंट करें (केवल फ़्लोटिंग-पॉइंट मानचित्र)"

msgid "Print raw indexes of floating-point ranges (floating-point maps only)"
msgstr "फ़्लोटिंग-पॉइंट रेंज के कच्चे इंडेक्स प्रिंट करें (केवल फ़्लोटिंग-पॉइंट मानचित्र)"

#, c-format
msgid "'%s' must be greater than zero; using %s=255"
msgstr "'%s' शून्य से बड़ा होना चाहिए; %s=255 का उपयोग करते हुए"

#, c-format
msgid "Raster map <%s> is reading as integer map! Flag '-%c' and/or '%s' option will be ignored."
msgstr "रेखापुंज मानचित्र <%s> पूर्णांक मानचित्र के रूप में पढ़ रहा है! ध्वज '-%c' और/या '%s' विकल्प पर ध्यान नहीं दिया जाएगा।"

#, c-format
msgid "Cats for raster map <%s> are either missing or have no explicit labels. Using %s=%d."
msgstr "रेखापुंज मानचित्र <%s> के लिए बिल्लियाँ या तो गायब हैं या उनमें कोई स्पष्ट लेबल नहीं है। %s=%d का उपयोग करना।"

#, c-format
msgid "Flag '-%c' was given, using cats fp ranges of raster map <%s>, ignoring '%s' option"
msgstr "रैस्टर मैप <%s> की कैट्स एफपी रेंज का उपयोग करते हुए, '%s' विकल्प को अनदेखा करते हुए, ध्वज '-%c' दिया गया था"

