msgstr "इनपुट और आउटपुट रैस्टर मैप समान नहीं हो सकते"

#, c-format
msgid "Input map <%s@%s> is all NULL, skipping"
msgstr "इनपुट मानचित्र <%s@%s> बिल्कुल शून्य है, छोड़ दिया गया है"

msgid "No raster map name found in input file"
msgstr "इनपुट फ़ाइल में कोई रेखापुंज मानचित्र नाम नहीं मिला"

msgid "Only one raster map name found in input file"
msgstr "इनपुट फ़ाइल में केवल एक रेखापुंज मानचित्र नाम मिला"

msgid "Raster map not found"
msgstr "रास्टर मानचित्र नहीं मिला"

msgid "Only one raster map name found"
msgstr "केवल एक रेखापुंज मानचित्र नाम मिला"

msgid "All input maps only contain NULL, cannot continue"
msgstr "सभी इनपुट मानचित्रों में केवल NULL होता है, जारी नहीं रखा जा सकता"

msgid "Input maptypes are different"
msgstr "इनपुट मैपटाइप भिन्न हैं"

msgid "Input ns resolutions are different"
msgstr "इनपुट एनएस रिज़ॉल्यूशन अलग हैं"

msgid "Input ew resolutions are different"
msgstr "इनपुट और रिज़ॉल्यूशन अलग-अलग हैं"

msgid "Processing lines... "
msgstr "प्रसंस्करण लाइनें... "

msgid "Vect runs out of region and re-enters - this case is not yet implemented."
msgstr "वेक्ट क्षेत्र से बाहर चला जाता है और पुनः प्रवेश करता है - यह मामला अभी तक लागू नहीं हुआ है।"

msgid "trying to divide by zero...no unique solution for system...skipping..."
msgstr "शून्य से विभाजित करने का प्रयास...सिस्टम के लिए कोई अनोखा समाधान नहीं...छोड़ना..।"

msgid "Generates stream channels."
msgstr "स्ट्रीम चैनल उत्पन्न करता है।"

msgid "Takes vector stream data, transforms it to raster and subtracts depth from the output DEM."
msgstr "वेक्टर स्ट्रीम डेटा लेता है, इसे रैस्टर में बदलता है और आउटपुट डीईएम से गहराई घटाता है।"

msgid "Name of input raster elevation map"
msgstr "इनपुट रेखापुंज उन्नयन मानचित्र का नाम"

msgid "Name of input vector map containing stream(s)"
msgstr "स्ट्रीम युक्त इनपुट वेक्टर मानचित्र का नाम"

msgid "Name for output vector map for adjusted stream points"
msgstr "समायोजित स्ट्रीम बिंदुओं के लिए आउटपुट वेक्टर मानचित्र का नाम"

msgid "Stream width (in meters)"
msgstr "धारा की चौड़ाई (मीटर में)"

msgid "Default is raster cell width"
msgstr "डिफ़ॉल्ट रैस्टर सेल चौड़ाई है"

msgid "Additional stream depth (in meters)"
msgstr "अतिरिक्त धारा गहराई (मीटर में)"

msgid "No flat areas allowed in flow direction"
msgstr "प्रवाह की दिशा में किसी समतल क्षेत्र की अनुमति नहीं है"

#, c-format
msgid "Invalid width value '%s' - using default."
msgstr "अमान्य चौड़ाई मान '%s' - डिफ़ॉल्ट का उपयोग कर रहा है।"

#, c-format
msgid "Invalid depth value '%s' - using default."
msgstr "अमान्य गहराई मान '%s' - डिफ़ॉल्ट का उपयोग कर रहा है।"

#, c-format
msgid "Lat/Long project is not supported by %s. Please reproject map first."
msgstr "अक्षांश/लंबा प्रोजेक्ट %s द्वारा समर्थित नहीं है। कृपया पहले मानचित्र दोबारा प्रोजेक्ट करें।"

msgid "Writing raster map..."
msgstr "रेखापुंज मानचित्र लिख रहा हूँ..।"

#, c-format
msgid "Reading <%s> in <%s>"
msgstr "<%s> को <%s> में पढ़ना"

msgid "category"
msgstr "वर्ग"

msgid "Manages category values and labels associated with user-specified raster map layers."
msgstr "उपयोगकर्ता द्वारा निर्दिष्ट रेखापुंज मानचित्र परतों से जुड़े श्रेणी मान और लेबल प्रबंधित करता है।"

msgid "Comma separated value list"
msgstr "अल्पविराम से अलग की गई मान सूची"

msgid "Example: 1.4,3.8,13"
msgstr "उदाहरण: 1.4,3.8,13"

msgid "Raster map from which to copy category table"
msgstr "रेखापुंज मानचित्र जिससे श्रेणी तालिका की प्रतिलिपि बनाई जाए"

msgid "File containing category label rules (or \"-\" to read from stdin)"
msgstr "श्रेणी लेबल नियमों वाली फ़ाइल (या stdin से पढ़ने के लिए \\\"-\\\")"

msgid "Output format ('plain', 'json')"
msgstr "आउटपुट स्वरूप ('सादा', 'json')"

msgid "When the value is not 'plain' or 'json', the value is used as a default label or format string for dynamic labeling. This usage is deprecated and will be removed in a future release. Use parameter 'label_format' instead."
msgstr "जब मान 'सादा' या 'json' नहीं होता है, तो मान का उपयोग डायनामिक लेबलिंग के लिए डिफ़ॉल्ट लेबल या प्रारूप स्ट्रिंग के रूप में किया जाता है। यह उपयोग अस्वीकृत कर दिया गया है और भविष्य में रिलीज़ में हटा दिया जाएगा। इसके बजाय पैरामीटर 'लेबल_फॉर्मेट' का उपयोग करें।"

msgid "Default label or format string for dynamic labeling"
msgstr "डायनामिक लेबलिंग के लिए डिफ़ॉल्ट लेबल या प्रारूप स्ट्रिंग"

msgid "Used when no explicit label exists for the category"
msgstr "इसका उपयोग तब किया जाता है जब श्रेणी के लिए कोई स्पष्ट लेबल मौजूद न हो"

msgid "Dynamic label coefficients"
msgstr "गतिशील लेबल गुणांक"

msgid "Two pairs of category multiplier and offsets, for $1 and $2"
msgstr "$1 और $2 के लिए श्रेणी गुणक और ऑफसेट के दो जोड़े"

msgid "Color format for output values or none."
msgstr "आउटपुट मानों के लिए रंग प्रारूप या कोई नहीं।"

msgid "The usage of 'format' for dynamic labeling is deprecated and will be removed in a future release. Please use the 'label_format' parameter instead."
msgstr "डायनामिक लेबलिंग के लिए 'प्रारूप' का उपयोग अस्वीकार कर दिया गया है और भविष्य में रिलीज़ में इसे हटा दिया जाएगा। कृपया इसके बजाय 'label_format' पैरामीटर का उपयोग करें।"

#, c-format
msgid "Raster map <%s> not found in current mapset"
msgstr "वर्तमान मैपसेट में रेखापुंज मानचित्र <%s> नहीं मिला"

#, c-format
msgid "Unable to read category file of raster map <%s@%s>"
msgstr "रेखापुंज मानचित्र की श्रेणी फ़ाइल को पढ़ने में असमर्थ <%s@%s>"

#, c-format
msgid "Category table for <%s> set from <%s>"
msgstr "<%s> के लिए श्रेणी तालिका <%s> से सेट की गई"

#, c-format
msgid ""
"Incorrect format of input rules. Is the first column numeric? Or check separators. Invalid line is:\n"
"%s"
msgstr "इनपुट नियमों का गलत प्रारूप. क्या पहला कॉलम संख्यात्मक है? या विभाजकों की जाँच करें. अमान्य पंक्ति है:\\n%s"

#, c-format
msgid "Unable to read category file of raster map <%s> in <%s>"
msgstr "<%s> में रेखापुंज मानचित्र <%s> की श्रेणी फ़ाइल को पढ़ने में असमर्थ"

#, c-format
msgid "Unable to read colors for input map %s"
msgstr "इनपुट मानचित्र %s के लिए रंग पढ़ने में असमर्थ"

msgid "The map is floating point! Ignoring cats list, using values list"
msgstr "मानचित्र फ़्लोटिंग पॉइंट है! मान सूची का उपयोग करते हुए, बिल्लियों की सूची को अनदेखा करना"

msgid "Parameter 'values' is required for floating point map!"
msgstr "फ़्लोटिंग पॉइंट मानचित्र के लिए पैरामीटर 'मान' आवश्यक है!"

msgid "circle"
msgstr "वृत्त"

msgid "Creates a raster map containing concentric rings around a given point."
msgstr "किसी दिए गए बिंदु के चारों ओर संकेंद्रित वलय वाला एक रेखापुंज मानचित्र बनाता है।"

msgid "The coordinate of the center (east,north)"
msgstr "केंद्र का निर्देशांक (पूर्व, उत्तर)"

msgid "Minimum radius for ring/circle map (in meters)"
msgstr "रिंग/सर्कल मानचित्र के लिए न्यूनतम त्रिज्या (मीटर में)"

msgid "Maximum radius for ring/circle map (in meters)"
msgstr "रिंग/सर्कल मानचित्र के लिए अधिकतम त्रिज्या (मीटर में)"

msgid "Data value multiplier"
msgstr "डेटा मान गुणक"

msgid "Generate binary raster map"
msgstr "बाइनरी रैस्टर मैप जनरेट करें"

msgid "Generate binary pattern only (useful for creating mask)"
msgstr "केवल बाइनरी पैटर्न उत्पन्न करें (मास्क बनाने के लिए उपयोगी)"

msgid "Please specify a radius in which min < max"
msgstr "कृपया एक दायरा निर्दिष्ट करें जिसमें न्यूनतम <अधिकतम हो"

msgid "Please specify min and/or max radius when using the binary flag"
msgstr "कृपया बाइनरी फ़्लैग का उपयोग करते समय न्यूनतम और/या अधिकतम त्रिज्या निर्दिष्ट करें"

#, c-format
msgid "Raster map <%s> created."
msgstr "रेखापुंज मानचित्र <%s> बनाया गया।"

msgid "Pass 2 of 2..."
msgstr "2 में से 2 पास करें..।"

#, c-format
msgid "%d initial clumps"
msgstr "%d प्रारंभिक क्लंप"

msgid "Pass 1 of 2..."
msgstr "2 में से 1 पास करें..।"

#, c-format
msgid "%d-band clumping with threshold %g"
msgstr "%d-बैंड क्लम्पिंग थ्रेशोल्ड के साथ %g"

msgid "reclass"
msgstr "पुनर्वर्गीकरण"

msgid "clumps"
msgstr "गुच्छों"

msgid "Recategorizes data in a raster map by grouping cells that form physically discrete areas into unique categories."
msgstr "भौतिक रूप से अलग-अलग क्षेत्रों को बनाने वाली कोशिकाओं को अद्वितीय श्रेणियों में समूहित करके रैस्टर मानचित्र में डेटा को पुन: वर्गीकृत करता है।"

msgid "Title for output raster map"
msgstr "आउटपुट रैस्टर मानचित्र के लिए शीर्षक"

msgid "Threshold to identify similar cells"
msgstr "समान कोशिकाओं की पहचान करने के लिए दहलीज"

msgid "Valid range: 0 = identical to < 1 = maximal difference"
msgstr "वैध सीमा: 0 = <1 के समान = अधिकतम अंतर"

msgid "Minimum clump size in cells"
msgstr "कोशिकाओं में न्यूनतम क्लंप आकार"

msgid "Clumps smaller than minsize will be merged to form larger clumps"
msgstr "छोटे आकार से छोटे गुच्छों को मिलाकर बड़े गुच्छे बनाए जाएंगे"

msgid "Clump also diagonal cells"
msgstr "झुरमुट भी विकर्ण कोशिकाओं"

msgid "Clumps are also traced along diagonal neighboring cells"
msgstr "विकर्ण पड़ोसी कोशिकाओं के साथ गुच्छों का भी पता लगाया जाता है"

msgid "Print only the number of clumps in shell script style"
msgstr "शेल स्क्रिप्ट शैली में केवल क्लंपों की संख्या प्रिंट करें"

#, c-format
msgid "Valid range for option <%s> is 0 <= value < 1"
msgstr "विकल्प <%s> के लिए मान्य सीमा 0 <= मान <1 है"

#, c-format
msgid "Input raster name <%s> is too long"
msgstr "इनपुट रैस्टर नाम <%s> बहुत लंबा है"

#, c-format
msgid "Title <%s> is too long"
msgstr "शीर्षक <%s> बहुत लंबा है"

#, c-format
msgid "%d clump."
msgid_plural "%d clumps."
msgstr[0] ""
msgstr[1] ""

msgid "Minimum size must be larger than 1"
msgstr "न्यूनतम आकार 1 से बड़ा होना चाहिए"

msgid "Loading input ..."
msgstr "इनपुट लोड हो रहा है..।"

#, c-format
msgid "Merging clumps smaller than %d cells..."
msgstr "%d कोशिकाओं से छोटे गुच्छों का विलय..।"

#, c-format
msgid "Renumbering remaining %d clumps..."
msgstr "शेष %d क्लंपों को पुनः क्रमांकित किया जा रहा है..।"

msgid "Tabulates the mutual occurrence (coincidence) of categories for two raster map layers."
msgstr "दो रेखापुंज मानचित्र परतों के लिए श्रेणियों की पारस्परिक घटना (संयोग) को सारणीबद्ध करता है।"

msgid "Name of first input raster map"
msgstr "प्रथम इनपुट रेखापुंज मानचित्र का नाम"

msgid "Name of second input raster map"
msgstr "दूसरे इनपुट रास्टर मानचित्र का नाम"

msgid "Unit of measure"
msgstr "माप की इकाई"

msgid "c(ells), p(ercent), x(percent of category [column]), y(percent of category [row]), a(cres), h(ectares), k(square kilometers), m(square miles)"
msgstr "c(ells), p(ercent), x(श्रेणी [स्तंभ] का प्रतिशत), y(श्रेणी [पंक्ति] का प्रतिशत), a(cres), h(ectares), k(वर्ग किलोमीटर), m(वर्ग मील)"

msgid "Wide report, 132 columns (default: 80)"
msgstr "विस्तृत रिपोर्ट, 132 कॉलम (डिफ़ॉल्ट: 80)"

#, c-format
msgid "Tabulating Coincidence between '%s' and '%s'"
msgstr "'%s' और '%s' के बीच संयोग को सारणीबद्ध करना"

msgid "Unable to create any tempfiles"
msgstr "कोई भी टेम्पफ़ाइल बनाने में असमर्थ"

msgid "Unable to run r.stats"
msgstr "r.stats चलाने में असमर्थ"

msgid "Unexpected output from r.stats"
msgstr "r.stats से अप्रत्याशित आउटपुट"

msgid "Unable to open tempfile"
msgstr "टेम्पफ़ाइल खोलने में असमर्थ"

#, c-format
msgid "Preparing report ..."
msgstr "रिपोर्ट तैयार हो रही है..।"

msgid "Exports the color table associated with a 3D raster map."
msgstr "3डी रेखापुंज मानचित्र से संबद्ध रंग तालिका निर्यात करता है।"

msgid "Path to output rules file"
msgstr "आउटपुट नियम फ़ाइल का पथ"

msgid "If not given write to standard output"
msgstr "यदि नहीं दिया गया है तो मानक आउटपुट पर लिखें"

msgid "Output values as percentages"
msgstr "आउटपुट मान प्रतिशत के रूप में"

#, c-format
msgid "Unable to read color table for raster3d map <%s>"
msgstr "Raster3D मानचित्र <%s> के लिए रंग तालिका पढ़ने में असमर्थ"

msgid "Exports the color table associated with a raster map."
msgstr "रास्टर मानचित्र से संबद्ध रंग तालिका निर्यात करता है।"

#, c-format
msgid "Unable to read color table for raster map <%s>"
