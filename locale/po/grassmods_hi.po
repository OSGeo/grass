msgid "Directions numbered from 1 to 8"
msgstr "दिशाएँ 1 से 8 तक क्रमांकित हैं"

msgid "Name for output basins raster map"
msgstr "आउटपुट बेसिन रेखापुंज मानचित्र का नाम"

msgid "Name for output stream segments raster map"
msgstr "आउटपुट स्ट्रीम सेगमेंट रैस्टर मैप का नाम"

