#, c-format
msgid "Bug in UI description. Description for option <%s> missing"
msgstr "यूआई विवरण में बग. विकल्प <%s> का विवरण गायब है"

#, c-format
msgid "Bug in UI description. Option '%s' in <%s> does not exist"
msgstr "यूआई विवरण में बग. <%s> में विकल्प '%s' मौजूद नहीं है"

msgid "Use either --quiet or --verbose flag, not both. Assuming --verbose."
msgstr "या तो --quiet या --verbose ध्वज का प्रयोग करें, दोनों का नहीं। मान लीजिए--शब्दशः।"

msgid "Use either --quiet or --verbose flag, not both. Assuming --quiet."
msgstr "या तो --quiet या --verbose ध्वज का प्रयोग करें, दोनों का नहीं। मान लीजिए--शांत।"

msgid "Use either --qq or --verbose flag, not both. Assuming --qq."
msgstr "या तो --qq या --verbose ध्वज का प्रयोग करें, दोनों का नहीं। मान लीजिए--qq।"

#, c-format
msgid "Sorry <%s> is not a valid option"
msgstr "क्षमा करें <%s> वैध विकल्प नहीं है"

msgid "Your installation doesn't include GUI, exiting."
msgstr "आपके इंस्टॉलेशन में GUI, निकास शामिल नहीं है।"

msgid "ERROR"
msgstr "गलती"

msgid "Unable to determine program name"
msgstr "प्रोग्राम का नाम निर्धारित करने में असमर्थ"

#, c-format
msgid "%s: Sorry, <%c> is not a valid flag"
msgstr "%s: क्षमा करें, <%c> वैध ध्वज नहीं है"

#, c-format
msgid "Please update the usage of <%s>: flag <%c> has been renamed to <%s>"
