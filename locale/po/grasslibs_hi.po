msgid "Option <%s> does not accept multiple answers"
msgstr "विकल्प <%s> एकाधिक उत्तरों को स्वीकार नहीं करता है"

#, c-format
msgid ""
"Illegal range syntax for parameter <%s>\n"
"\tPresented as: %s"
msgstr "पैरामीटर <%s>\\n\\tके लिए अवैध श्रेणी वाक्यविन्यास इस प्रकार प्रस्तुत किया गया है: %s"

#, fuzzy, c-format
msgid ""
"Value <%s> out of range for parameter <%s>\n"
"\tLegal range: %s"
msgstr ""
"पैरामीटर <%s>\n"
"\tकानूनी सीमा के लिए मान <%s> सीमा से बाहर: %s"

#, c-format
msgid "Missing value for parameter <%s>"
msgstr "पैरामीटर <%s> के लिए गुम मान"

#, c-format
msgid "Invalid value <%s> for parameter <%s>"
msgstr "पैरामीटर <%s> के लिए अमान्य मान <%s>"

