msgid "Please update the usage of <%s>: flag <%c> has been renamed to option <%s>"
msgstr "कृपया <%s> के उपयोग को अपडेट करें: ध्वज <%c> का नाम बदलकर विकल्प <%s> कर दिया गया है"

#, c-format
msgid "%s: Sorry, <%s=> is ambiguous"
msgstr "%s: क्षमा करें, <%s=> अस्पष्ट है"

#, c-format
msgid "Option <%s=> matches"
msgstr "विकल्प <%s=> मेल खाता है"

#, c-format
msgid "Please update the usage of <%s>: option <%s> has been renamed to flag <%s>"
msgstr "कृपया <%s> के उपयोग को अपडेट करें: विकल्प <%s> का नाम बदलकर ध्वज <%s> कर दिया गया है"

#, c-format
msgid "Please update the usage of <%s>: option <%s> has been renamed to flag <%c>"
msgstr "कृपया <%s> के उपयोग को अपडेट करें: विकल्प <%s> का नाम बदलकर ध्वज <%c> कर दिया गया है"

#, c-format
msgid "Please update the usage of <%s>: option <%s> has been renamed to <%s>"
msgstr "कृपया <%s> के उपयोग को अपडेट करें: विकल्प <%s> का नाम बदलकर <%s> कर दिया गया है"

#, c-format
msgid "%s: Sorry, <%s> is not a valid parameter"
