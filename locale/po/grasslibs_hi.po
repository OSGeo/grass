msgstr "GRASS को OpenMP समर्थन के साथ संकलित नहीं किया गया है, समानांतर गणना अक्षम है। केवल एक धागे का उपयोग किया जाएगा।"

#, c-format
msgid "G__open(read): mapset <%s> doesn't match xmapset <%s>"
msgstr "G__open(पढ़ें): मैपसेट <%s> xmapset <%s> से मेल नहीं खाता"

#, c-format
msgid "G__open(read): Unable to open '%s': %s"
msgstr "G__open(पढ़ें): '%s' खोलने में असमर्थ: %s"

#, c-format
msgid "G__open(write): xmapset <%s> != G_mapset() <%s>"
msgstr "G__open(लिखें): xmapset <%s> != G_mapset() <%s>"

#, c-format
msgid "G__open(write): Unable to open '%s': %s"
msgstr "G__open(लिखें): '%s' खोलने में असमर्थ: %s"

#, c-format
msgid "File read/write operation failed: %s (%d)"
msgstr "फ़ाइल पढ़ने/लिखने की कार्रवाई विफल: %s (%d)"

#, c-format
msgid "G__open_misc(read): mapset <%s> doesn't match xmapset <%s>"
msgstr "G__open_misc(पढ़ें): मैपसेट <%s> xmapset <%s> से मेल नहीं खाता"

#, c-format
msgid "G__open_misc(write): xmapset <%s> != G_mapset() <%s>"
msgstr "G__open_misc(लिखें): xmapset <%s> != G_mapset() <%s>"

msgid "Bug in UI description. Missing module description"
msgstr "यूआई विवरण में बग. गुम मॉड्यूल विवरण"

msgid "Bug in UI description. Missing option key"
msgstr "यूआई विवरण में बग. विकल्प कुंजी गुम है"

#, c-format
msgid "Bug in UI description. Option key <%s> is not valid"
