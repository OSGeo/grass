msgid ""
"Value <%s> ambiguous for parameter <%s>\n"
"\tValid options: %s"
msgstr ""
"मान <%s> पैरामीटर <%s>\n"
"\tमान्य विकल्पों के लिए अस्पष्ट: %s"

#, c-format
msgid ""
"Required parameter <%s> not set:\n"
"\t(%s)"
msgstr ""
"आवश्यक पैरामीटर <%s> सेट नहीं है:\n"
"\t(%s)"

#, c-format
msgid ""
"Option <%s> must be provided in multiples of %d\n"
"\tYou provided %d item(s): %s"
msgstr ""
"विकल्प <%s> को %d के गुणकों में प्रदान किया जाना चाहिए\n"
"\tआपने %d आइटम प्रदान किए हैं: %s"

#, c-format
msgid "option <%s>: <%s> exists. To overwrite, use the --overwrite flag"
msgstr "विकल्प <%s>: <%s> मौजूद है। ओवरराइट करने के लिए --ओवरराइट ध्वज का उपयोग करें"

#, c-format
msgid "%s= is not a separator option"
msgstr "%s= विभाजक विकल्प नहीं है"

